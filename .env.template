# ============================================================================
# RIG Pipeline — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.template .env
#
# Required: At least one of OPENAI_API_KEY or ANTHROPIC_API_KEY
# Optional: OLLAMA_AVAILABLE (set to true if Ollama + Llama3 is installed)
# ============================================================================

# OpenAI API key — used for obligation tuple extraction (GPT-4o)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API key — used for auto-annotation (Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Ollama availability — set to true only if Ollama is installed with llama3
# The pipeline works fine without it; this is optional for local model comparison
OLLAMA_AVAILABLE=false
