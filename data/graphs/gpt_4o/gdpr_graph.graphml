  <key id="d0" for="graph" attr.name="doc_id" attr.type="string" />
  <graph edgedefault="directed">
    <node id="OBL-0001">
      <data key="d1">obligation</data>
      <data key="d2">it must be considered in relation to its function in society and be balanced against
other fundamental rights, in accordance with the principle of proportionality.</data>
      <data key="d3">Preamble</data>
    </node>
    <node id="OBL-0002">
      <data key="d1">obligation</data>
      <data key="d2">Regarding the
processing of personal data for compliance with a legal obligation, for the performance of a task carried out in
the public interest or in the exercise of official authority vested in the controller, Member States should be
allowed to maintain or introduce national provisions to further specify the application of the rules of this
Regulation.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Maintain or introduce national provisions to further specify the application of the rules of this Regulation</data>
    </node>
    <node id="SUBJ:Member States">
      <data key="d1">subject</data>
      <data key="d5">Member States</data>
    </node>
    <node id="COND:OBL-0002">
      <data key="d1">condition</data>
      <data key="d5">Processing of personal data for compliance with a legal obligation, for the performance of a task carried out in the public interest or in the exercise of official authority vested in the controller</data>
    </node>
    <node id="OBL-0003">
      <data key="d1">obligation</data>
      <data key="d2">The proper functioning of the internal market
requires that the free movement of personal data within the Union is not restricted or prohibited for reasons
connected with the protection of natural persons with regard to the processing of personal data.</data>
      <data key="d3">Preamble</data>
    </node>
    <node id="OBL-0004">
      <data key="d1">obligation</data>
      <data key="d2">4.5.2016 EN Official Journal of the European Union L 119/5
(23) In order to ensure that natural persons are not deprived of the protection to which they are entitled under this
Regulation, the processing of personal data of data subjects who are in the Union by a controller or a processor
not established in the Union should be subject to this Regulation where the processing activities are related to
offering goods or services to such data subjects irrespective of whether connected to a payment.</data>
      <data key="d3">Preamble</data>
      <data key="d4">processing of personal data should be subject to this Regulation</data>
    </node>
    <node id="SUBJ:controller or processor not established in the Union">
      <data key="d1">subject</data>
      <data key="d5">controller or processor not established in the Union</data>
    </node>
    <node id="COND:OBL-0004">
      <data key="d1">condition</data>
      <data key="d5">processing activities are related to offering goods or services to data subjects in the Union</data>
    </node>
    <node id="OBL-0005">
      <data key="d1">obligation</data>
      <data key="d2">(31) Public authorities to which personal data are disclosed in accordance with a legal obligation for the exercise of
their official mission, such as tax and customs authorities, financial investigation units, independent adminis­
trative authorities, or financial market authorities responsible for the regulation and supervision of securities
markets should not be regarded as recipients if they receive personal data which are necessary to carry out a
particular inquiry in the general interest, in accordance with Union or Member State law.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Not be regarded as recipients</data>
    </node>
    <node id="SUBJ:Public authorities">
      <data key="d1">subject</data>
      <data key="d5">Public authorities</data>
    </node>
    <node id="COND:OBL-0005">
      <data key="d1">condition</data>
      <data key="d5">If they receive personal data necessary to carry out a particular inquiry in the general interest, in accordance with Union or Member State law</data>
    </node>
    <node id="OBL-0006">
      <data key="d1">obligation</data>
      <data key="d2">If the data subject's consent is to be
given following a request by electronic means, the request must be clear, concise and not unnecessarily disruptive
to the use of the service for which it is provided.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Ensure the request is clear, concise and not unnecessarily disruptive</data>
    </node>
    <node id="SUBJ:The entity requesting consent">
      <data key="d1">subject</data>
      <data key="d5">The entity requesting consent</data>
    </node>
    <node id="COND:OBL-0006">
      <data key="d1">condition</data>
      <data key="d5">If the data subject's consent is to be given following a request by electronic means</data>
    </node>
    <node id="OBL-0007">
      <data key="d1">obligation</data>
      <data key="d2">In order to ensure that the personal data are not kept longer than necessary, time limits
should be established by the controller for erasure or for a periodic review.</data>
      <data key="d3">Preamble</data>
      <data key="d4">establish time limits for erasure or for a periodic review</data>
    </node>
    <node id="SUBJ:controller">
      <data key="d1">subject</data>
      <data key="d5">controller</data>
    </node>
    <node id="COND:OBL-0007">
      <data key="d1">condition</data>
      <data key="d5">to ensure that the personal data are not kept longer than necessary</data>
    </node>
    <node id="OBL-0008">
      <data key="d1">obligation</data>
      <data key="d2">Every reasonable step should be taken
to ensure that personal data which are inaccurate are rectified or deleted.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Ensure that personal data which are inaccurate are rectified or deleted</data>
    </node>
    <node id="SUBJ:The regulated entity or actor">
      <data key="d1">subject</data>
      <data key="d5">The regulated entity or actor</data>
    </node>
    <node id="COND:OBL-0008">
      <data key="d1">condition</data>
      <data key="d5">Every reasonable step should be taken</data>
    </node>
    <node id="OBL-0009">
      <data key="d1">obligation</data>
      <data key="d2">(40) In order for processing to be lawful, personal data should be processed on the basis of the consent of the data
subject concerned or some other legitimate basis, laid down by law, either in this Regulation or in other Union or
L 119/8 EN Official Journal of the European Union 4.5.2016
Member State law as referred to in this Regulation, including the necessity for compliance with the legal
obligation to which the controller is subject or the necessity for the performance of a contract to which the data
subject is party or in order to take steps at the request of the data subject prior to entering into a contract.</data>
      <data key="d3">Preamble</data>
      <data key="d4">process personal data on the basis of consent or some other legitimate basis</data>
    </node>
    <node id="COND:OBL-0009">
      <data key="d1">condition</data>
      <data key="d5">for processing to be lawful</data>
    </node>
    <node id="OBL-0010">
      <data key="d1">obligation</data>
      <data key="d2">In particular in the context of a written declaration
on another matter, safeguards should ensure that the data subject is aware of the fact that and the extent to
which consent is given.</data>
      <data key="d3">Preamble</data>
    </node>
    <node id="OBL-0011">
      <data key="d1">obligation</data>
      <data key="d2">(43) In order to ensure that consent is freely given, consent should not provide a valid legal ground for the processing
of personal data in a specific case where there is a clear imbalance between the data subject and the controller, in
particular where the controller is a public authority and it is therefore unlikely that consent was freely given in
all the circumstances of that specific situation.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Consent should not provide a valid legal ground for the processing of personal data</data>
    </node>
    <node id="COND:OBL-0011">
      <data key="d1">condition</data>
      <data key="d5">There is a clear imbalance between the data subject and the controller</data>
    </node>
    <node id="EXC:OBL-0011">
      <data key="d1">exception</data>
      <data key="d5">In particular where the controller is a public authority</data>
    </node>
    <node id="OBL-0012">
      <data key="d1">obligation</data>
      <data key="d2">(45) Where processing is carried out in accordance with a legal obligation to which the controller is subject or where
processing is necessary for the performance of a task carried out in the public interest or in the exercise of
official authority, the processing should have a basis in Union or Member State law.</data>
      <data key="d3">Preamble</data>
      <data key="d4">processing should have a basis in Union or Member State law</data>
    </node>
    <node id="COND:OBL-0012">
      <data key="d1">condition</data>
      <data key="d5">processing is carried out in accordance with a legal obligation or necessary for the performance of a task in the public interest or in the exercise of official authority</data>
    </node>
    <node id="OBL-0013">
      <data key="d1">obligation</data>
      <data key="d2">A law as a basis for several processing operations based on a
legal obligation to which the controller is subject or where processing is necessary for the performance of a task
carried out in the public interest or in the exercise of an official authority may be sufficient.</data>
      <data key="d3">Preamble</data>
    </node>
    <node id="OBL-0014">
      <data key="d1">obligation</data>
      <data key="d2">However, such transmission in the legitimate interest of the
controller or further processing of personal data should be prohibited if the processing is not compatible with a
legal, professional or other binding obligation of secrecy.</data>
      <data key="d3">Preamble</data>
      <data key="d4">prohibited from further processing of personal data</data>
    </node>
    <node id="COND:OBL-0014">
      <data key="d1">condition</data>
      <data key="d5">if the processing is not compatible with a legal, professional or other binding obligation of secrecy</data>
    </node>
    <node id="EXC:OBL-0014">
      <data key="d1">exception</data>
      <data key="d5">legitimate interest of the controller</data>
    </node>
    <node id="OBL-0015">
      <data key="d1">obligation</data>
      <data key="d2">Such personal data should not be processed, unless processing is allowed in
specific cases set out in this Regulation, taking into account that Member States law may lay down specific
provisions on data protection in order to adapt the application of the rules of this Regulation for compliance
with a legal obligation or for the performance of a task carried out in the public interest or in the exercise of
official authority vested in the controller.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Personal data should not be processed</data>
    </node>
    <node id="SUBJ:The regulated entity or actor (e.g., 'bank', 'broker-dealer')">
      <data key="d1">subject</data>
      <data key="d5">The regulated entity or actor (e.g., 'bank', 'broker-dealer')</data>
    </node>
    <node id="COND:OBL-0015">
      <data key="d1">condition</data>
      <data key="d5">Unless processing is allowed in specific cases set out in this Regulation</data>
    </node>
    <node id="EXC:OBL-0015">
      <data key="d1">exception</data>
      <data key="d5">Member States law may lay down specific provisions on data protection for compliance with a legal obligation or for the performance of a task carried out in the public interest or in the exercise of official authority vested in the controller</data>
    </node>
    <node id="OBL-0016">
      <data key="d1">obligation</data>
      <data key="d2">Therefore, this Regulation should provide for
harmonised conditions for the processing of special categories of personal data concerning health, in respect of
specific needs, in particular where the processing of such data is carried out for certain health-related purposes
4.5.2016 EN Official Journal of the European Union L 119/11
by persons subject to a legal obligation of professional secrecy.</data>
      <data key="d3">Preamble</data>
      <data key="d4">process special categories of personal data concerning health</data>
    </node>
    <node id="SUBJ:persons">
      <data key="d1">subject</data>
      <data key="d5">persons</data>
    </node>
    <node id="COND:OBL-0016">
      <data key="d1">condition</data>
      <data key="d5">where the processing is carried out for certain health-related purposes</data>
    </node>
    <node id="EXC:OBL-0016">
      <data key="d1">exception</data>
      <data key="d5">subject to a legal obligation of professional secrecy</data>
    </node>
    <node id="OBL-0017">
      <data key="d1">obligation</data>
      <data key="d2">Where the personal data are collected from the
data subject, the data subject should also be informed whether he or she is obliged to provide the personal data
and of the consequences, where he or she does not provide such data.</data>
      <data key="d3">Preamble</data>
      <data key="d4">be informed whether he or she is obliged to provide the personal data and of the consequences</data>
    </node>
    <node id="SUBJ:data subject">
      <data key="d1">subject</data>
      <data key="d5">data subject</data>
    </node>
    <node id="COND:OBL-0017">
      <data key="d1">condition</data>
      <data key="d5">where the personal data are collected from the data subject</data>
    </node>
    <node id="OBL-0018">
      <data key="d1">obligation</data>
      <data key="d2">(62) However, it is not necessary to impose the obligation to provide information where the data subject already
possesses the information, where the recording or disclosure of the personal data is expressly laid down by law
or where the provision of information to the data subject proves to be impossible or would involve a dispropor­
tionate effort.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Provide information</data>
    </node>
    <node id="COND:OBL-0018">
      <data key="d1">condition</data>
      <data key="d5">Where the data subject already possesses the information, where the recording or disclosure of the personal data is expressly laid down by law, or where the provision of information to the data subject proves to be impossible or would involve a disproportionate effort</data>
    </node>
    <node id="EXC:OBL-0018">
      <data key="d1">exception</data>
      <data key="d5">It is not necessary to impose the obligation</data>
    </node>
    <node id="OBL-0019">
      <data key="d1">obligation</data>
      <data key="d2">However, the further retention of the personal data
should be lawful where it is necessary, for exercising the right of freedom of expression and information, for
compliance with a legal obligation, for the performance of a task carried out in the public interest or in the
exercise of official authority vested in the controller, on the grounds of public interest in the area of public
health, for archiving purposes in the public interest, scientific or historical research purposes or statistical
purposes, or for the establishment, exercise or defence of legal claims.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Further retention of the personal data should be lawful</data>
    </node>
    <node id="SUBJ:The regulated entity or actor (e.g., 'data controller')">
      <data key="d1">subject</data>
      <data key="d5">The regulated entity or actor (e.g., 'data controller')</data>
    </node>
    <node id="COND:OBL-0019">
      <data key="d1">condition</data>
      <data key="d5">Where it is necessary for exercising the right of freedom of expression and information, compliance with a legal obligation, performance of a task in the public interest, exercise of official authority, public interest in public health, archiving purposes, scientific or historical research purposes, statistical purposes, or establishment, exercise or defence of legal claims</data>
    </node>
    <node id="OBL-0020">
      <data key="d1">obligation</data>
      <data key="d2">It
should therefore not apply where the processing of the personal data is necessary for compliance with a legal
obligation to which the controller is subject or for the performance of a task carried out in the public interest or
in the exercise of an official authority vested in the controller.</data>
      <data key="d3">Preamble</data>
    </node>
    <node id="OBL-0021">
      <data key="d1">obligation</data>
      <data key="d2">The data subject's right to transmit or receive
personal data concerning him or her should not create an obligation for the controllers to adopt or maintain
processing systems which are technically compatible.</data>
      <data key="d3">Preamble</data>
    </node>
    <node id="OBL-0022">
      <data key="d1">obligation</data>
      <data key="d2">(78) The protection of the rights and freedoms of natural persons with regard to the processing of personal data
require that appropriate technical and organisational measures be taken to ensure that the requirements of this
Regulation are met.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Take appropriate technical and organisational measures</data>
    </node>
    <node id="COND:OBL-0022">
      <data key="d1">condition</data>
      <data key="d5">To ensure that the requirements of this Regulation are met</data>
    </node>
    <node id="OBL-0023">
      <data key="d1">obligation</data>
      <data key="d2">(89) Directive 95/46/EC provided for a general obligation to notify the processing of personal data to the supervisory
authorities.</data>
      <data key="d3">Preamble</data>
      <data key="d4">notify the processing of personal data to the supervisory authorities</data>
    </node>
    <node id="SUBJ:Directive 95/46/EC">
      <data key="d1">subject</data>
      <data key="d5">Directive 95/46/EC</data>
    </node>
    <node id="OBL-0024">
      <data key="d1">obligation</data>
      <data key="d2">While that obligation produces administrative and financial burdens, it did not in all cases contribute
to improving the protection of personal data.</data>
      <data key="d3">Preamble</data>
    </node>
    <node id="OBL-0025">
      <data key="d1">obligation</data>
      <data key="d2">In such cases, a data protection impact assessment should not be mandatory.</data>
      <data key="d3">Preamble</data>
      <data key="d4">A data protection impact assessment should not be mandatory</data>
    </node>
    <node id="COND:OBL-0025">
      <data key="d1">condition</data>
      <data key="d5">In such cases</data>
    </node>
    <node id="OBL-0026">
      <data key="d1">obligation</data>
      <data key="d2">Consequently the transfer of
personal data to that third country or international organisation should be prohibited, unless the requirements in
this Regulation relating to transfers subject to appropriate safeguards, including binding corporate rules, and
derogations for specific situations are fulfilled.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Prohibit the transfer of personal data to that third country or international organisation</data>
    </node>
    <node id="SUBJ:The regulated entity">
      <data key="d1">subject</data>
      <data key="d5">The regulated entity</data>
    </node>
    <node id="COND:OBL-0026">
      <data key="d1">condition</data>
      <data key="d5">Unless the requirements in this Regulation relating to transfers subject to appropriate safeguards, including binding corporate rules, and derogations for specific situations are fulfilled</data>
    </node>
    <node id="OBL-0027">
      <data key="d1">obligation</data>
      <data key="d2">(138) The application of such mechanism should be a condition for the lawfulness of a measure intended to produce
legal effects by a supervisory authority in those cases where its application is mandatory.</data>
      <data key="d3">Preamble</data>
      <data key="d4">Apply such mechanism</data>
    </node>
    <node id="SUBJ:supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">supervisory authority</data>
    </node>
    <node id="COND:OBL-0027">
      <data key="d1">condition</data>
      <data key="d5">In cases where its application is mandatory</data>
    </node>
    <node id="OBL-0028">
      <data key="d1">obligation</data>
      <data key="d2">In the context of judicial remedies relating to the
application of this Regulation, national courts which consider a decision on the question necessary to enable
them to give judgment, may, or in the case provided for in Article 267 TFEU, must, request the Court of Justice
to give a preliminary ruling on the interpretation of Union law, including this Regulation.</data>
      <data key="d3">Article 263</data>
      <data key="d4">request the Court of Justice to give a preliminary ruling on the interpretation of Union law</data>
    </node>
    <node id="SUBJ:national courts">
      <data key="d1">subject</data>
      <data key="d5">national courts</data>
    </node>
    <node id="COND:OBL-0028">
      <data key="d1">condition</data>
      <data key="d5">consider a decision on the question necessary to enable them to give judgment</data>
    </node>
    <node id="EXC:OBL-0028">
      <data key="d1">exception</data>
      <data key="d5">in the case provided for in Article 267 TFEU</data>
    </node>
    <node id="OBL-0029">
      <data key="d1">obligation</data>
      <data key="d2">Furthermore, where a
decision of a supervisory authority implementing a decision of the Board is challenged before a national court
and the validity of the decision of the Board is at issue, that national court does not have the power to declare
the Board's decision invalid but must refer the question of validity to the Court of Justice in accordance with
Article 267 TFEU as interpreted by the Court of Justice, where it considers the decision invalid.</data>
      <data key="d3">Article 263</data>
      <data key="d4">must refer the question of validity to the Court of Justice</data>
    </node>
    <node id="SUBJ:national court">
      <data key="d1">subject</data>
      <data key="d5">national court</data>
    </node>
    <node id="COND:OBL-0029">
      <data key="d1">condition</data>
      <data key="d5">where a decision of a supervisory authority implementing a decision of the Board is challenged and the validity of the decision of the Board is at issue</data>
    </node>
    <node id="OBL-0030">
      <data key="d1">obligation</data>
      <data key="d2">Those safeguards should ensure that technical and organisational
measures are in place in order to ensure, in particular, the principle of data minimisation.</data>
      <data key="d3">Article 263</data>
      <data key="d4">Ensure that technical and organisational measures are in place</data>
    </node>
    <node id="COND:OBL-0030">
      <data key="d1">condition</data>
      <data key="d5">To ensure the principle of data minimisation</data>
    </node>
    <node id="OBL-0031">
      <data key="d1">obligation</data>
      <data key="d2">Public authorities or public or private
bodies that hold records of public interest should be services which, pursuant to Union or Member State law,
have a legal obligation to acquire, preserve, appraise, arrange, describe, communicate, promote, disseminate and
provide access to records of enduring value for general public interest.</data>
      <data key="d3">Article 263</data>
      <data key="d4">Acquire, preserve, appraise, arrange, describe, communicate, promote, disseminate and provide access to records of enduring value</data>
    </node>
    <node id="SUBJ:Public authorities or public or private bodies">
      <data key="d1">subject</data>
      <data key="d5">Public authorities or public or private bodies</data>
    </node>
    <node id="COND:OBL-0031">
      <data key="d1">condition</data>
      <data key="d5">Hold records of public interest</data>
    </node>
    <node id="OBL-0032">
      <data key="d1">obligation</data>
      <data key="d2">(164) As regards the powers of the supervisory authorities to obtain from the controller or processor access to
personal data and access to their premises, Member States may adopt by law, within the limits of this Regulation,
specific rules in order to safeguard the professional or other equivalent secrecy obligations, in so far as necessary
to reconcile the right to the protection of personal data with an obligation of professional secrecy.</data>
      <data key="d3">Article 263</data>
      <data key="d4">Adopt by law specific rules to safeguard professional or other equivalent secrecy obligations</data>
    </node>
    <node id="COND:OBL-0032">
      <data key="d1">condition</data>
      <data key="d5">Within the limits of this Regulation and in so far as necessary to reconcile the right to the protection of personal data with an obligation of professional secrecy</data>
    </node>
    <node id="OBL-0033">
      <data key="d1">obligation</data>
      <data key="d2">The free movement of personal data within the Union shall be neither restricted nor prohibited for reasons
connected with the protection of natural persons with regard to the processing of personal data.</data>
      <data key="d3">CHAPTER I</data>
      <data key="d4">Shall not restrict or prohibit the free movement of personal data</data>
    </node>
    <node id="SUBJ:The Union">
      <data key="d1">subject</data>
      <data key="d5">The Union</data>
    </node>
    <node id="COND:OBL-0033">
      <data key="d1">condition</data>
      <data key="d5">For reasons connected with the protection of natural persons with regard to the processing of personal data</data>
    </node>
    <node id="OBL-0034">
      <data key="d1">obligation</data>
      <data key="d2">Regulation (EC) No 45/2001 and other Union legal acts applicable to such processing of personal
data shall be adapted to the principles and rules of this Regulation in accordance with Article 98.</data>
      <data key="d3">CHAPTER I</data>
      <data key="d4">shall be adapted to the principles and rules of this Regulation</data>
    </node>
    <node id="SUBJ:Regulation (EC) No 45/2001 and other Union legal acts">
      <data key="d1">subject</data>
      <data key="d5">Regulation (EC) No 45/2001 and other Union legal acts</data>
    </node>
    <node id="COND:OBL-0034">
      <data key="d1">condition</data>
      <data key="d5">applicable to such processing of personal data</data>
    </node>
    <node id="OBL-0035">
      <data key="d1">obligation</data>
      <data key="d2">This Regulation shall be without prejudice to the application of Directive 2000/31/EC, in particular of the liability
rules of intermediary service providers in Articles 12 to 15 of that Directive.</data>
      <data key="d3">CHAPTER I</data>
    </node>
    <node id="OBL-0036">
      <data key="d1">obligation</data>
      <data key="d2">(5) ‘pseudonymisation’ means the processing of personal data in such a manner that the personal data can no longer
be attributed to a specific data subject without the use of additional information, provided that such additional
information is kept separately and is subject to technical and organisational measures to ensure that the personal
data are not attributed to an identified or identifiable natural person;</data>
      <data key="d3">Article 4</data>
      <data key="d4">Keep additional information separately and subject to technical and organisational measures</data>
    </node>
    <node id="COND:OBL-0036">
      <data key="d1">condition</data>
      <data key="d5">When processing personal data in a manner that it can no longer be attributed to a specific data subject without additional information</data>
    </node>
    <node id="OBL-0037">
      <data key="d1">obligation</data>
      <data key="d2">L 119/34 EN Official Journal of the European Union 4.5.2016
framework of a particular inquiry in accordance with Union or Member State law shall not be regarded as
recipients;</data>
      <data key="d3">Article 51</data>
      <data key="d4">Shall not be regarded as recipients</data>
    </node>
    <node id="COND:OBL-0037">
      <data key="d1">condition</data>
      <data key="d5">Framework of a particular inquiry in accordance with Union or Member State law</data>
    </node>
    <node id="OBL-0038">
      <data key="d1">obligation</data>
      <data key="d2">the processing of those data by those public authorities shall be in compliance with the applicable data
protection rules according to the purposes of the processing;</data>
      <data key="d3">Article 51</data>
      <data key="d4">processing of data in compliance with the applicable data protection rules</data>
    </node>
    <node id="SUBJ:public authorities">
      <data key="d1">subject</data>
      <data key="d5">public authorities</data>
    </node>
    <node id="COND:OBL-0038">
      <data key="d1">condition</data>
      <data key="d5">according to the purposes of the processing</data>
    </node>
    <node id="OBL-0039">
      <data key="d1">obligation</data>
      <data key="d2">Personal data shall be:
(a) processed lawfully, fairly and in a transparent manner in relation to the data subject (‘lawfulness, fairness and
transparency’);</data>
      <data key="d3">CHAPTER II</data>
      <data key="d4">processed lawfully, fairly and in a transparent manner</data>
    </node>
    <node id="SUBJ:Personal data">
      <data key="d1">subject</data>
      <data key="d5">Personal data</data>
    </node>
    <node id="COND:OBL-0039">
      <data key="d1">condition</data>
      <data key="d5">in relation to the data subject</data>
    </node>
    <node id="OBL-0040">
      <data key="d1">obligation</data>
      <data key="d2">further processing for archiving purposes in the public interest, scientific or historical research
purposes or statistical purposes shall, in accordance with Article 89(1), not be considered to be incompatible with
the initial purposes (‘purpose limitation’);</data>
      <data key="d3">CHAPTER II</data>
      <data key="d4">Further processing for archiving purposes in the public interest, scientific or historical research purposes or statistical purposes shall not be considered to be incompatible with the initial purposes</data>
    </node>
    <node id="COND:OBL-0040">
      <data key="d1">condition</data>
      <data key="d5">In accordance with Article 89(1)</data>
    </node>
    <node id="OBL-0041">
      <data key="d1">obligation</data>
      <data key="d2">every reasonable step must be taken to ensure that personal data that
are inaccurate, having regard to the purposes for which they are processed, are erased or rectified without delay
(‘accuracy’);</data>
      <data key="d3">CHAPTER II</data>
      <data key="d4">Take every reasonable step to ensure that inaccurate personal data are erased or rectified</data>
    </node>
    <node id="COND:OBL-0041">
      <data key="d1">condition</data>
      <data key="d5">Having regard to the purposes for which they are processed</data>
    </node>
    <node id="DL:OBL-0041">
      <data key="d1">deadline</data>
      <data key="d5">Without delay</data>
    </node>
    <node id="OBL-0042">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall be responsible for, and be able to demonstrate compliance with, paragraph 1 (‘accountability’).</data>
      <data key="d3">Article 6</data>
      <data key="d4">be responsible for, and be able to demonstrate compliance with, paragraph 1 (‘accountability’)</data>
    </node>
    <node id="OBL-0043">
      <data key="d1">obligation</data>
      <data key="d2">Processing shall be lawful only if and to the extent that at least one of the following applies:
(a) the data subject has given consent to the processing of his or her personal data for one or more specific purposes;</data>
      <data key="d3">Article 6</data>
      <data key="d4">Ensure processing is lawful</data>
    </node>
    <node id="SUBJ:Processor">
      <data key="d1">subject</data>
      <data key="d5">Processor</data>
    </node>
    <node id="COND:OBL-0043">
      <data key="d1">condition</data>
      <data key="d5">At least one of the specified conditions applies</data>
    </node>
    <node id="OBL-0044">
      <data key="d1">obligation</data>
      <data key="d2">(c) processing is necessary for compliance with a legal obligation to which the controller is subject;</data>
      <data key="d3">Article 6</data>
      <data key="d4">processing is necessary for compliance with a legal obligation</data>
    </node>
    <node id="OBL-0045">
      <data key="d1">obligation</data>
      <data key="d2">Point (f) of the first subparagraph shall not apply to processing carried out by public authorities in the performance of
their tasks.</data>
      <data key="d3">Article 6</data>
      <data key="d4">Point (f) of the first subparagraph shall not apply</data>
    </node>
    <node id="COND:OBL-0045">
      <data key="d1">condition</data>
      <data key="d5">in the performance of their tasks</data>
    </node>
    <node id="OBL-0046">
      <data key="d1">obligation</data>
      <data key="d2">The basis for the processing referred to in point (c) and (e) of paragraph 1 shall be laid down by:
(a) Union law;</data>
      <data key="d3">Article 6</data>
      <data key="d4">The basis for the processing shall be laid down</data>
    </node>
    <node id="COND:OBL-0046">
      <data key="d1">condition</data>
      <data key="d5">Referred to in point (c) and (e) of paragraph 1</data>
    </node>
    <node id="OBL-0047">
      <data key="d1">obligation</data>
      <data key="d2">The purpose of the processing shall be determined in that legal basis or, as regards the processing referred to in point (e)
of paragraph 1, shall be necessary for the performance of a task carried out in the public interest or in the exercise of
official authority vested in the controller.</data>
      <data key="d3">Article 6</data>
    </node>
    <node id="OBL-0048">
      <data key="d1">obligation</data>
      <data key="d2">The Union or the Member State law shall meet an objective of
public interest and be proportionate to the legitimate aim pursued.</data>
      <data key="d3">Article 9</data>
    </node>
    <node id="OBL-0049">
      <data key="d1">obligation</data>
      <data key="d2">Where the processing for a purpose other than that for which the personal data have been collected is not based
on the data subject's consent or on a Union or Member State law which constitutes a necessary and proportionate
measure in a democratic society to safeguard the objectives referred to in Article 23(1), the controller shall, in order to
ascertain whether processing for another purpose is compatible with the purpose for which the personal data are
initially collected, take into account, inter alia:
(a) any link between the purposes for which the personal data have been collected and the purposes of the intended
further processing;</data>
      <data key="d3">Article 9</data>
      <data key="d4">take into account any link between the purposes for which the personal data have been collected and the purposes of the intended further processing</data>
    </node>
    <node id="COND:OBL-0049">
      <data key="d1">condition</data>
      <data key="d5">processing for a purpose other than that for which the personal data have been collected is not based on the data subject's consent or on a Union or Member State law</data>
    </node>
    <node id="OBL-0050">
      <data key="d1">obligation</data>
      <data key="d2">Where processing is based on consent, the controller shall be able to demonstrate that the data subject has
consented to processing of his or her personal data.</data>
      <data key="d3">Article 9</data>
      <data key="d4">demonstrate that the data subject has consented to processing of his or her personal data</data>
    </node>
    <node id="COND:OBL-0050">
      <data key="d1">condition</data>
      <data key="d5">processing is based on consent</data>
    </node>
    <node id="OBL-0051">
      <data key="d1">obligation</data>
      <data key="d2">If the data subject's consent is given in the context of a written declaration which also concerns other matters, the
request for consent shall be presented in a manner which is clearly distinguishable from the other matters, in an
intelligible and easily accessible form, using clear and plain language.</data>
      <data key="d3">Article 9</data>
      <data key="d4">Present the request for consent in a manner which is clearly distinguishable from the other matters, in an intelligible and easily accessible form, using clear and plain language</data>
    </node>
    <node id="COND:OBL-0051">
      <data key="d1">condition</data>
      <data key="d5">If the data subject's consent is given in the context of a written declaration which also concerns other matters</data>
    </node>
    <node id="OBL-0052">
      <data key="d1">obligation</data>
      <data key="d2">Any part of such a declaration which constitutes
an infringement of this Regulation shall not be binding.</data>
      <data key="d3">Article 9</data>
    </node>
    <node id="OBL-0053">
      <data key="d1">obligation</data>
      <data key="d2">The data subject shall have the right to withdraw his or her consent at any time.</data>
      <data key="d3">Article 9</data>
      <data key="d4">have the right to withdraw his or her consent</data>
    </node>
    <node id="COND:OBL-0053">
      <data key="d1">condition</data>
      <data key="d5">at any time</data>
    </node>
    <node id="OBL-0054">
      <data key="d1">obligation</data>
      <data key="d2">The withdrawal of consent shall
not affect the lawfulness of processing based on consent before its withdrawal.</data>
      <data key="d3">Article 9</data>
      <data key="d4">The withdrawal of consent shall not affect the lawfulness of processing based on consent before its withdrawal</data>
    </node>
    <node id="OBL-0055">
      <data key="d1">obligation</data>
      <data key="d2">Prior to giving consent, the data subject
shall be informed thereof.</data>
      <data key="d3">Article 9</data>
      <data key="d4">be informed thereof</data>
    </node>
    <node id="COND:OBL-0055">
      <data key="d1">condition</data>
      <data key="d5">Prior to giving consent</data>
    </node>
    <node id="OBL-0056">
      <data key="d1">obligation</data>
      <data key="d2">It shall be as easy to withdraw as to give consent.</data>
      <data key="d3">Article 9</data>
      <data key="d4">Ensure it is as easy to withdraw as to give consent</data>
    </node>
    <node id="OBL-0057">
      <data key="d1">obligation</data>
      <data key="d2">When assessing whether consent is freely given, utmost account shall be taken of whether, inter alia, the
performance of a contract, including the provision of a service, is conditional on consent to the processing of personal
data that is not necessary for the performance of that contract.</data>
      <data key="d3">Article 9</data>
      <data key="d4">Take utmost account of whether consent is freely given</data>
    </node>
    <node id="COND:OBL-0057">
      <data key="d1">condition</data>
      <data key="d5">When assessing whether consent is freely given</data>
    </node>
    <node id="OBL-0058">
      <data key="d1">obligation</data>
      <data key="d2">Where point (a) of Article 6(1) applies, in relation to the offer of information society services directly to a child,
the processing of the personal data of a child shall be lawful where the child is at least 16 years old.</data>
      <data key="d3">Article 9</data>
      <data key="d4">Ensure the processing of personal data of a child is lawful</data>
    </node>
    <node id="SUBJ:The entity offering information society services">
      <data key="d1">subject</data>
      <data key="d5">The entity offering information society services</data>
    </node>
    <node id="COND:OBL-0058">
      <data key="d1">condition</data>
      <data key="d5">Where point (a) of Article 6(1) applies, in relation to the offer of information society services directly to a child</data>
    </node>
    <node id="THRESH:OBL-0058">
      <data key="d1">threshold</data>
      <data key="d5">The child is at least 16 years old</data>
    </node>
    <node id="OBL-0059">
      <data key="d1">obligation</data>
      <data key="d2">Where the child is
below the age of 16 years, such processing shall be lawful only if and to the extent that consent is given or authorised
by the holder of parental responsibility over the child.</data>
      <data key="d3">Article 9</data>
      <data key="d4">Ensure consent is given or authorised by the holder of parental responsibility</data>
    </node>
    <node id="SUBJ:The entity processing the child's data">
      <data key="d1">subject</data>
      <data key="d5">The entity processing the child's data</data>
    </node>
    <node id="COND:OBL-0059">
      <data key="d1">condition</data>
      <data key="d5">Where the child is below the age of 16 years</data>
    </node>
    <node id="OBL-0060">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall make reasonable efforts to verify in such cases that consent is given or authorised by the
holder of parental responsibility over the child, taking into consideration available technology.</data>
      <data key="d3">Article 9</data>
      <data key="d4">make reasonable efforts to verify that consent is given or authorised by the holder of parental responsibility over the child</data>
    </node>
    <node id="COND:OBL-0060">
      <data key="d1">condition</data>
      <data key="d5">in such cases</data>
    </node>
    <node id="OBL-0061">
      <data key="d1">obligation</data>
      <data key="d2">Paragraph 1 shall not affect the general contract law of Member States such as the rules on the validity, formation
or effect of a contract in relation to a child.</data>
      <data key="d3">Article 9</data>
    </node>
    <node id="OBL-0062">
      <data key="d1">obligation</data>
      <data key="d2">Processing of personal data revealing racial or ethnic origin, political opinions, religious or philosophical beliefs, or
trade union membership, and the processing of genetic data, biometric data for the purpose of uniquely identifying a
natural person, data concerning health or data concerning a natural person's sex life or sexual orientation shall be
prohibited.</data>
      <data key="d3">Article 9</data>
      <data key="d4">Prohibition of processing personal data revealing racial or ethnic origin, political opinions, religious or philosophical beliefs, trade union membership, genetic data, biometric data for uniquely identifying a natural person, data concerning health, or data concerning a natural person's sex life or sexual orientation</data>
    </node>
    <node id="OBL-0063">
      <data key="d1">obligation</data>
      <data key="d2">Paragraph 1 shall not apply if one of the following applies:
(a) the data subject has given explicit consent to the processing of those personal data for one or more specified
purposes, except where Union or Member State law provide that the prohibition referred to in paragraph 1 may not
be lifted by the data subject;</data>
      <data key="d3">Article 9</data>
      <data key="d4">shall not apply</data>
    </node>
    <node id="SUBJ:Paragraph 1">
      <data key="d1">subject</data>
      <data key="d5">Paragraph 1</data>
    </node>
    <node id="COND:OBL-0063">
      <data key="d1">condition</data>
      <data key="d5">if the data subject has given explicit consent to the processing of those personal data for one or more specified purposes</data>
    </node>
    <node id="EXC:OBL-0063">
      <data key="d1">exception</data>
      <data key="d5">except where Union or Member State law provide that the prohibition referred to in paragraph 1 may not be lifted by the data subject</data>
    </node>
    <node id="OBL-0064">
      <data key="d1">obligation</data>
      <data key="d2">(g) processing is necessary for reasons of substantial public interest, on the basis of Union or Member State law which
shall be proportionate to the aim pursued, respect the essence of the right to data protection and provide for
suitable and specific measures to safeguard the fundamental rights and the interests of the data subject;</data>
      <data key="d3">Article 9</data>
      <data key="d4">Processing is necessary for reasons of substantial public interest</data>
    </node>
    <node id="COND:OBL-0064">
      <data key="d1">condition</data>
      <data key="d5">On the basis of Union or Member State law which shall be proportionate to the aim pursued, respect the essence of the right to data protection and provide for suitable and specific measures to safeguard the fundamental rights and the interests of the data subject</data>
    </node>
    <node id="OBL-0065">
      <data key="d1">obligation</data>
      <data key="d2">4.5.2016 EN Official Journal of the European Union L 119/39
(j) processing is necessary for archiving purposes in the public interest, scientific or historical research purposes or
statistical purposes in accordance with Article 89(1) based on Union or Member State law which shall be propor­
tionate to the aim pursued, respect the essence of the right to data protection and provide for suitable and specific
measures to safeguard the fundamental rights and the interests of the data subject.</data>
      <data key="d3">Article 10</data>
      <data key="d4">Processing is necessary for archiving purposes in the public interest, scientific or historical research purposes or statistical purposes</data>
    </node>
    <node id="COND:OBL-0065">
      <data key="d1">condition</data>
      <data key="d5">In accordance with Article 89(1) based on Union or Member State law which shall be proportionate to the aim pursued, respect the essence of the right to data protection and provide for suitable and specific measures to safeguard the fundamental rights and the interests of the data subject</data>
    </node>
    <node id="OBL-0066">
      <data key="d1">obligation</data>
      <data key="d2">Personal data referred to in paragraph 1 may be processed for the purposes referred to in point (h) of paragraph 2
when those data are processed by or under the responsibility of a professional subject to the obligation of professional
secrecy under Union or Member State law or rules established by national competent bodies or by another person also
subject to an obligation of secrecy under Union or Member State law or rules established by national competent bodies.</data>
      <data key="d3">Article 10</data>
      <data key="d4">Process personal data for the purposes referred to in point (h) of paragraph 2</data>
    </node>
    <node id="SUBJ:A professional subject to the obligation of professional secrecy or another person also subject to an obligation of secrecy">
      <data key="d1">subject</data>
      <data key="d5">A professional subject to the obligation of professional secrecy or another person also subject to an obligation of secrecy</data>
    </node>
    <node id="COND:OBL-0066">
      <data key="d1">condition</data>
      <data key="d5">When those data are processed by or under the responsibility of a professional subject to the obligation of professional secrecy under Union or Member State law or rules established by national competent bodies</data>
    </node>
    <node id="OBL-0067">
      <data key="d1">obligation</data>
      <data key="d2">Article 10
Processing of personal data relating to criminal convictions and offences
Processing of personal data relating to criminal convictions and offences or related security measures based on
Article 6(1) shall be carried out only under the control of official authority or when the processing is authorised by
Union or Member State law providing for appropriate safeguards for the rights and freedoms of data subjects.</data>
      <data key="d3">Article 10</data>
      <data key="d4">Carry out processing of personal data relating to criminal convictions and offences</data>
    </node>
    <node id="SUBJ:Official authority or entity authorized by Union or Member State law">
      <data key="d1">subject</data>
      <data key="d5">Official authority or entity authorized by Union or Member State law</data>
    </node>
    <node id="COND:OBL-0067">
      <data key="d1">condition</data>
      <data key="d5">Based on Article 6(1) and providing for appropriate safeguards for the rights and freedoms of data subjects</data>
    </node>
    <node id="OBL-0068">
      <data key="d1">obligation</data>
      <data key="d2">Any
comprehensive register of criminal convictions shall be kept only under the control of official authority.</data>
      <data key="d3">Article 10</data>
      <data key="d4">keep comprehensive register of criminal convictions</data>
    </node>
    <node id="SUBJ:official authority">
      <data key="d1">subject</data>
      <data key="d5">official authority</data>
    </node>
    <node id="OBL-0069">
      <data key="d1">obligation</data>
      <data key="d2">If the purposes for which a controller processes personal data do not or do no longer require the identification of
a data subject by the controller, the controller shall not be obliged to maintain, acquire or process additional
information in order to identify the data subject for the sole purpose of complying with this Regulation.</data>
      <data key="d3">Article 10</data>
      <data key="d4">shall not be obliged to maintain, acquire or process additional information in order to identify the data subject</data>
    </node>
    <node id="COND:OBL-0069">
      <data key="d1">condition</data>
      <data key="d5">if the purposes for which a controller processes personal data do not or do no longer require the identification of a data subject by the controller</data>
    </node>
    <node id="EXC:OBL-0069">
      <data key="d1">exception</data>
      <data key="d5">for the sole purpose of complying with this Regulation</data>
    </node>
    <node id="OBL-0070">
      <data key="d1">obligation</data>
      <data key="d2">Where, in cases referred to in paragraph 1 of this Article, the controller is able to demonstrate that it is not in a
position to identify the data subject, the controller shall inform the data subject accordingly, if possible.</data>
      <data key="d3">Article 10</data>
      <data key="d4">inform the data subject accordingly</data>
    </node>
    <node id="COND:OBL-0070">
      <data key="d1">condition</data>
      <data key="d5">in cases referred to in paragraph 1 of this Article and if the controller is able to demonstrate that it is not in a position to identify the data subject</data>
    </node>
    <node id="EXC:OBL-0070">
      <data key="d1">exception</data>
      <data key="d5">if possible</data>
    </node>
    <node id="OBL-0071">
      <data key="d1">obligation</data>
      <data key="d2">In such cases,
Articles 15 to 20 shall not apply except where the data subject, for the purpose of exercising his or her rights under
those articles, provides additional information enabling his or her identification.</data>
      <data key="d3">Article 10</data>
      <data key="d4">shall not apply</data>
    </node>
    <node id="SUBJ:Articles 15 to 20">
      <data key="d1">subject</data>
      <data key="d5">Articles 15 to 20</data>
    </node>
    <node id="COND:OBL-0071">
      <data key="d1">condition</data>
      <data key="d5">In such cases</data>
    </node>
    <node id="EXC:OBL-0071">
      <data key="d1">exception</data>
      <data key="d5">except where the data subject provides additional information enabling his or her identification</data>
    </node>
    <node id="OBL-0072">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall take appropriate measures to provide any information referred to in Articles 13 and 14 and
any communication under Articles 15 to 22 and 34 relating to processing to the data subject in a concise, transparent,
intelligible and easily accessible form, using clear and plain language, in particular for any information addressed
specifically to a child.</data>
      <data key="d3">Article 10</data>
      <data key="d4">take appropriate measures to provide any information referred to in Articles 13 and 14 and any communication under Articles 15 to 22 and 34 relating to processing to the data subject in a concise, transparent, intelligible and easily accessible form, using clear and plain language</data>
    </node>
    <node id="COND:OBL-0072">
      <data key="d1">condition</data>
      <data key="d5">in particular for any information addressed specifically to a child</data>
    </node>
    <node id="OBL-0073">
      <data key="d1">obligation</data>
      <data key="d2">The information shall be provided in writing, or by other means, including, where appropriate, by
electronic means.</data>
      <data key="d3">Article 10</data>
      <data key="d4">Provide information in writing or by other means</data>
    </node>
    <node id="COND:OBL-0073">
      <data key="d1">condition</data>
      <data key="d5">Where appropriate</data>
    </node>
    <node id="EXC:OBL-0073">
      <data key="d1">exception</data>
      <data key="d5">Including by electronic means</data>
    </node>
    <node id="OBL-0074">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall facilitate the exercise of data subject rights under Articles 15 to 22.</data>
      <data key="d3">Article 11</data>
      <data key="d4">facilitate the exercise of data subject rights</data>
    </node>
    <node id="COND:OBL-0074">
      <data key="d1">condition</data>
      <data key="d5">under Articles 15 to 22</data>
    </node>
    <node id="OBL-0075">
      <data key="d1">obligation</data>
      <data key="d2">In the cases referred to in
Article 11(2), the controller shall not refuse to act on the request of the data subject for exercising his or her rights
under Articles 15 to 22, unless the controller demonstrates that it is not in a position to identify the data subject.</data>
      <data key="d3">Article 11</data>
      <data key="d4">shall not refuse to act on the request of the data subject for exercising his or her rights under Articles 15 to 22</data>
    </node>
    <node id="COND:OBL-0075">
      <data key="d1">condition</data>
      <data key="d5">In the cases referred to in Article 11(2)</data>
    </node>
    <node id="EXC:OBL-0075">
      <data key="d1">exception</data>
      <data key="d5">unless the controller demonstrates that it is not in a position to identify the data subject</data>
    </node>
    <node id="OBL-0076">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall provide information on action taken on a request under Articles 15 to 22 to the data subject
without undue delay and in any event within one month of receipt of the request.</data>
      <data key="d3">Article 11</data>
      <data key="d4">provide information on action taken on a request under Articles 15 to 22 to the data subject</data>
    </node>
    <node id="COND:OBL-0076">
      <data key="d1">condition</data>
      <data key="d5">on a request under Articles 15 to 22</data>
    </node>
    <node id="DL:OBL-0076">
      <data key="d1">deadline</data>
      <data key="d5">without undue delay and in any event within one month of receipt of the request</data>
    </node>
    <node id="OBL-0077">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall
inform the data subject of any such extension within one month of receipt of the request, together with the reasons for
the delay.</data>
      <data key="d3">Article 11</data>
      <data key="d4">inform the data subject of any such extension</data>
    </node>
    <node id="COND:OBL-0077">
      <data key="d1">condition</data>
      <data key="d5">within one month of receipt of the request</data>
    </node>
    <node id="OBL-0078">
      <data key="d1">obligation</data>
      <data key="d2">Where the data subject makes the request by electronic form means, the information shall be provided by
electronic means where possible, unless otherwise requested by the data subject.</data>
      <data key="d3">Article 11</data>
      <data key="d4">Provide the information by electronic means</data>
    </node>
    <node id="COND:OBL-0078">
      <data key="d1">condition</data>
      <data key="d5">Where the data subject makes the request by electronic form means</data>
    </node>
    <node id="EXC:OBL-0078">
      <data key="d1">exception</data>
      <data key="d5">Unless otherwise requested by the data subject</data>
    </node>
    <node id="OBL-0079">
      <data key="d1">obligation</data>
      <data key="d2">If the controller does not take action on the request of the data subject, the controller shall inform the data subject
without delay and at the latest within one month of receipt of the request of the reasons for not taking action and on
the possibility of lodging a complaint with a supervisory authority and seeking a judicial remedy.</data>
      <data key="d3">Article 11</data>
      <data key="d4">inform the data subject of the reasons for not taking action and on the possibility of lodging a complaint with a supervisory authority and seeking a judicial remedy</data>
    </node>
    <node id="COND:OBL-0079">
      <data key="d1">condition</data>
      <data key="d5">If the controller does not take action on the request of the data subject</data>
    </node>
    <node id="DL:OBL-0079">
      <data key="d1">deadline</data>
      <data key="d5">without delay and at the latest within one month of receipt of the request</data>
    </node>
    <node id="OBL-0080">
      <data key="d1">obligation</data>
      <data key="d2">Information provided under Articles 13 and 14 and any communication and any actions taken under Articles 15
to 22 and 34 shall be provided free of charge.</data>
      <data key="d3">Article 11</data>
      <data key="d4">Provide information and communication free of charge</data>
    </node>
    <node id="COND:OBL-0080">
      <data key="d1">condition</data>
      <data key="d5">Under Articles 13, 14, 15 to 22, and 34</data>
    </node>
    <node id="OBL-0081">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall bear the burden of demonstrating the manifestly unfounded or excessive character of the request.</data>
      <data key="d3">Article 11</data>
      <data key="d4">bear the burden of demonstrating the manifestly unfounded or excessive character of the request</data>
    </node>
    <node id="OBL-0082">
      <data key="d1">obligation</data>
      <data key="d2">Where the icons are presented electronically they shall be machine-readable.</data>
      <data key="d3">Article 11</data>
      <data key="d4">Icons shall be machine-readable</data>
    </node>
    <node id="SUBJ:The entity presenting the icons electronically">
      <data key="d1">subject</data>
      <data key="d5">The entity presenting the icons electronically</data>
    </node>
    <node id="COND:OBL-0082">
      <data key="d1">condition</data>
      <data key="d5">Where the icons are presented electronically</data>
    </node>
    <node id="OBL-0083">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall be empowered to adopt delegated acts in accordance with Article 92 for the purpose of
determining the information to be presented by the icons and the procedures for providing standardised icons.</data>
      <data key="d3">Article 11</data>
      <data key="d4">Adopt delegated acts</data>
    </node>
    <node id="SUBJ:The Commission">
      <data key="d1">subject</data>
      <data key="d5">The Commission</data>
    </node>
    <node id="COND:OBL-0083">
      <data key="d1">condition</data>
      <data key="d5">For the purpose of determining the information to be presented by the icons and the procedures for providing standardised icons</data>
    </node>
    <node id="OBL-0084">
      <data key="d1">obligation</data>
      <data key="d2">Where personal data relating to a data subject are collected from the data subject, the controller shall, at the time
when personal data are obtained, provide the data subject with all of the following information:
(a) the identity and the contact details of the controller and, where applicable, of the controller's representative;</data>
      <data key="d3">Article 11</data>
      <data key="d4">provide the data subject with all of the following information: the identity and the contact details of the controller and, where applicable, of the controller's representative</data>
    </node>
    <node id="COND:OBL-0084">
      <data key="d1">condition</data>
      <data key="d5">personal data relating to a data subject are collected from the data subject</data>
    </node>
    <node id="DL:OBL-0084">
      <data key="d1">deadline</data>
      <data key="d5">at the time when personal data are obtained</data>
    </node>
    <node id="OBL-0085">
      <data key="d1">obligation</data>
      <data key="d2">In addition to the information referred to in paragraph 1, the controller shall, at the time when personal data are
obtained, provide the data subject with the following further information necessary to ensure fair and transparent
processing:
(a) the period for which the personal data will be stored, or if that is not possible, the criteria used to determine that
period;</data>
      <data key="d3">Article 14</data>
      <data key="d4">provide the data subject with further information necessary to ensure fair and transparent processing</data>
    </node>
    <node id="COND:OBL-0085">
      <data key="d1">condition</data>
      <data key="d5">at the time when personal data are obtained</data>
    </node>
    <node id="OBL-0086">
      <data key="d1">obligation</data>
      <data key="d2">(e) whether the provision of personal data is a statutory or contractual requirement, or a requirement necessary to enter
into a contract, as well as whether the data subject is obliged to provide the personal data and of the possible
consequences of failure to provide such data;</data>
      <data key="d3">Article 14</data>
      <data key="d4">provide the personal data</data>
    </node>
    <node id="COND:OBL-0086">
      <data key="d1">condition</data>
      <data key="d5">whether the provision of personal data is a statutory or contractual requirement, or a requirement necessary to enter into a contract</data>
    </node>
    <node id="OBL-0087">
      <data key="d1">obligation</data>
      <data key="d2">Where the controller intends to further process the personal data for a purpose other than that for which the
personal data were collected, the controller shall provide the data subject prior to that further processing with
information on that other purpose and with any relevant further information as referred to in paragraph 2.</data>
      <data key="d3">Article 14</data>
      <data key="d4">provide the data subject with information on that other purpose and with any relevant further information</data>
    </node>
    <node id="COND:OBL-0087">
      <data key="d1">condition</data>
      <data key="d5">intends to further process the personal data for a purpose other than that for which the personal data were collected</data>
    </node>
    <node id="DL:OBL-0087">
      <data key="d1">deadline</data>
      <data key="d5">prior to that further processing</data>
    </node>
    <node id="OBL-0088">
      <data key="d1">obligation</data>
      <data key="d2">Paragraphs 1, 2 and 3 shall not apply where and insofar as the data subject already has the information.</data>
      <data key="d3">Article 14</data>
      <data key="d4">Paragraphs 1, 2 and 3 shall not apply</data>
    </node>
    <node id="COND:OBL-0088">
      <data key="d1">condition</data>
      <data key="d5">where and insofar as the data subject already has the information</data>
    </node>
    <node id="OBL-0089">
      <data key="d1">obligation</data>
      <data key="d2">Where personal data have not been obtained from the data subject, the controller shall provide the data subject
with the following information:
(a) the identity and the contact details of the controller and, where applicable, of the controller's representative;</data>
      <data key="d3">Article 14</data>
      <data key="d4">provide the data subject with the identity and the contact details of the controller and, where applicable, of the controller's representative</data>
    </node>
    <node id="COND:OBL-0089">
      <data key="d1">condition</data>
      <data key="d5">personal data have not been obtained from the data subject</data>
    </node>
    <node id="OBL-0090">
      <data key="d1">obligation</data>
      <data key="d2">In addition to the information referred to in paragraph 1, the controller shall provide the data subject with the
following information necessary to ensure fair and transparent processing in respect of the data subject:
(a) the period for which the personal data will be stored, or if that is not possible, the criteria used to determine that
period;</data>
      <data key="d3">Article 14</data>
      <data key="d4">provide the data subject with the period for which the personal data will be stored, or if that is not possible, the criteria used to determine that period</data>
    </node>
    <node id="COND:OBL-0090">
      <data key="d1">condition</data>
      <data key="d5">necessary to ensure fair and transparent processing in respect of the data subject</data>
    </node>
    <node id="OBL-0091">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall provide the information referred to in paragraphs 1 and 2:
(a) within a reasonable period after obtaining the personal data, but at the latest within one month, having regard to
the specific circumstances in which the personal data are processed;</data>
      <data key="d3">Article 14</data>
      <data key="d4">provide the information referred to in paragraphs 1 and 2</data>
    </node>
    <node id="COND:OBL-0091">
      <data key="d1">condition</data>
      <data key="d5">after obtaining the personal data</data>
    </node>
    <node id="DL:OBL-0091">
      <data key="d1">deadline</data>
      <data key="d5">within a reasonable period, but at the latest within one month</data>
    </node>
    <node id="OBL-0092">
      <data key="d1">obligation</data>
      <data key="d2">Where the controller intends to further process the personal data for a purpose other than that for which the
personal data were obtained, the controller shall provide the data subject prior to that further processing with
information on that other purpose and with any relevant further information as referred to in paragraph 2.</data>
      <data key="d3">Article 14</data>
      <data key="d4">provide the data subject with information on that other purpose and with any relevant further information</data>
    </node>
    <node id="COND:OBL-0092">
      <data key="d1">condition</data>
      <data key="d5">intends to further process the personal data for a purpose other than that for which the personal data were obtained</data>
    </node>
    <node id="DL:OBL-0092">
      <data key="d1">deadline</data>
      <data key="d5">prior to that further processing</data>
    </node>
    <node id="OBL-0093">
      <data key="d1">obligation</data>
      <data key="d2">Paragraphs 1 to 4 shall not apply where and insofar as:
(a) the data subject already has the information;</data>
      <data key="d3">Article 14</data>
      <data key="d4">Paragraphs 1 to 4 shall not apply</data>
    </node>
    <node id="COND:OBL-0093">
      <data key="d1">condition</data>
      <data key="d5">where and insofar as the data subject already has the information</data>
    </node>
    <node id="OBL-0094">
      <data key="d1">obligation</data>
      <data key="d2">(b) the provision of such information proves impossible or would involve a disproportionate effort, in particular for
processing for archiving purposes in the public interest, scientific or historical research purposes or statistical
purposes, subject to the conditions and safeguards referred to in Article 89(1) or in so far as the obligation referred
to in paragraph 1 of this Article is likely to render impossible or seriously impair the achievement of the objectives
of that processing.</data>
      <data key="d3">Article 14</data>
      <data key="d4">Provision of information</data>
    </node>
    <node id="COND:OBL-0094">
      <data key="d1">condition</data>
      <data key="d5">Provision of such information proves impossible or would involve a disproportionate effort</data>
    </node>
    <node id="EXC:OBL-0094">
      <data key="d1">exception</data>
      <data key="d5">Processing for archiving purposes in the public interest, scientific or historical research purposes or statistical purposes, subject to the conditions and safeguards referred to in Article 89(1)</data>
    </node>
    <node id="OBL-0095">
      <data key="d1">obligation</data>
      <data key="d2">In such cases the controller shall take appropriate measures to protect the data subject's rights
and freedoms and legitimate interests, including making the information publicly available;</data>
      <data key="d3">Article 14</data>
      <data key="d4">take appropriate measures to protect the data subject's rights and freedoms and legitimate interests, including making the information publicly available</data>
    </node>
    <node id="COND:OBL-0095">
      <data key="d1">condition</data>
      <data key="d5">In such cases</data>
    </node>
    <node id="OBL-0096">
      <data key="d1">obligation</data>
      <data key="d2">or
(d) where the personal data must remain confidential subject to an obligation of professional secrecy regulated by Union
or Member State law, including a statutory obligation of secrecy.</data>
      <data key="d3">Article 14</data>
      <data key="d4">Personal data must remain confidential</data>
    </node>
    <node id="COND:OBL-0096">
      <data key="d1">condition</data>
      <data key="d5">Subject to an obligation of professional secrecy regulated by Union or Member State law</data>
    </node>
    <node id="OBL-0097">
      <data key="d1">obligation</data>
      <data key="d2">The data subject shall have the right to obtain from the controller confirmation as to whether or not personal data
concerning him or her are being processed, and, where that is the case, access to the personal data and the following
information:
(a) the purposes of the processing;</data>
      <data key="d3">Article 15</data>
      <data key="d4">obtain from the controller confirmation as to whether or not personal data concerning him or her are being processed, and, where that is the case, access to the personal data and the following information</data>
    </node>
    <node id="OBL-0098">
      <data key="d1">obligation</data>
      <data key="d2">Where personal data are transferred to a third country or to an international organisation, the data subject shall
have the right to be informed of the appropriate safeguards pursuant to Article 46 relating to the transfer.</data>
      <data key="d3">Article 15</data>
      <data key="d4">Have the right to be informed of the appropriate safeguards</data>
    </node>
    <node id="SUBJ:The data subject">
      <data key="d1">subject</data>
      <data key="d5">The data subject</data>
    </node>
    <node id="COND:OBL-0098">
      <data key="d1">condition</data>
      <data key="d5">Where personal data are transferred to a third country or to an international organisation</data>
    </node>
    <node id="OBL-0099">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall provide a copy of the personal data undergoing processing.</data>
      <data key="d3">Article 15</data>
      <data key="d4">provide a copy of the personal data undergoing processing</data>
    </node>
    <node id="OBL-0100">
      <data key="d1">obligation</data>
      <data key="d2">Where the data subject
makes the request by electronic means, and unless otherwise requested by the data subject, the information shall be
provided in a commonly used electronic form.</data>
      <data key="d3">Article 15</data>
      <data key="d4">Provide the information in a commonly used electronic form</data>
    </node>
    <node id="SUBJ:The data controller">
      <data key="d1">subject</data>
      <data key="d5">The data controller</data>
    </node>
    <node id="COND:OBL-0100">
      <data key="d1">condition</data>
      <data key="d5">Where the data subject makes the request by electronic means, and unless otherwise requested by the data subject</data>
    </node>
    <node id="OBL-0101">
      <data key="d1">obligation</data>
      <data key="d2">The right to obtain a copy referred to in paragraph 3 shall not adversely affect the rights and freedoms of others.</data>
      <data key="d3">Article 15</data>
      <data key="d4">Not adversely affect the rights and freedoms of others</data>
    </node>
    <node id="COND:OBL-0101">
      <data key="d1">condition</data>
      <data key="d5">The right to obtain a copy referred to in paragraph 3</data>
    </node>
    <node id="OBL-0102">
      <data key="d1">obligation</data>
      <data key="d2">Section 3
Rectification and erasure
Article 16
Right to rectification
The data subject shall have the right to obtain from the controller without undue delay the rectification of inaccurate
personal data concerning him or her.</data>
      <data key="d3">Article 15</data>
      <data key="d4">rectify inaccurate personal data</data>
    </node>
    <node id="COND:OBL-0102">
      <data key="d1">condition</data>
      <data key="d5">upon request from the data subject</data>
    </node>
    <node id="DL:OBL-0102">
      <data key="d1">deadline</data>
      <data key="d5">without undue delay</data>
    </node>
    <node id="OBL-0103">
      <data key="d1">obligation</data>
      <data key="d2">Taking into account the purposes of the processing, the data subject shall have the
right to have incomplete personal data completed, including by means of providing a supplementary statement.</data>
      <data key="d3">Article 15</data>
      <data key="d4">have incomplete personal data completed</data>
    </node>
    <node id="COND:OBL-0103">
      <data key="d1">condition</data>
      <data key="d5">Taking into account the purposes of the processing</data>
    </node>
    <node id="OBL-0104">
      <data key="d1">obligation</data>
      <data key="d2">The data subject shall have the right to obtain from the controller the erasure of personal data concerning him or
her without undue delay and the controller shall have the obligation to erase personal data without undue delay where
one of the following grounds applies:
(a) the personal data are no longer necessary in relation to the purposes for which they were collected or otherwise
processed;</data>
      <data key="d3">Article 15</data>
      <data key="d4">erase personal data without undue delay</data>
    </node>
    <node id="COND:OBL-0104">
      <data key="d1">condition</data>
      <data key="d5">where one of the following grounds applies: the personal data are no longer necessary in relation to the purposes for which they were collected or otherwise processed</data>
    </node>
    <node id="DL:OBL-0104">
      <data key="d1">deadline</data>
      <data key="d5">without undue delay</data>
    </node>
    <node id="OBL-0105">
      <data key="d1">obligation</data>
      <data key="d2">(e) the personal data have to be erased for compliance with a legal obligation in Union or Member State law to which
the controller is subject;</data>
      <data key="d3">Article 8</data>
      <data key="d4">erase the personal data</data>
    </node>
    <node id="COND:OBL-0105">
      <data key="d1">condition</data>
      <data key="d5">for compliance with a legal obligation in Union or Member State law</data>
    </node>
    <node id="OBL-0106">
      <data key="d1">obligation</data>
      <data key="d2">Where the controller has made the personal data public and is obliged pursuant to paragraph 1 to erase the
personal data, the controller, taking account of available technology and the cost of implementation, shall take
reasonable steps, including technical measures, to inform controllers which are processing the personal data that the
data subject has requested the erasure by such controllers of any links to, or copy or replication of, those personal data.</data>
      <data key="d3">Article 8</data>
      <data key="d4">take reasonable steps, including technical measures, to inform controllers processing the personal data of the data subject's request for erasure</data>
    </node>
    <node id="COND:OBL-0106">
      <data key="d1">condition</data>
      <data key="d5">where the controller has made the personal data public and is obliged pursuant to paragraph 1 to erase the personal data</data>
    </node>
    <node id="OBL-0107">
      <data key="d1">obligation</data>
      <data key="d2">Paragraphs 1 and 2 shall not apply to the extent that processing is necessary:
(a) for exercising the right of freedom of expression and information;</data>
      <data key="d3">Article 8</data>
      <data key="d4">Paragraphs 1 and 2 shall not apply</data>
    </node>
    <node id="COND:OBL-0107">
      <data key="d1">condition</data>
      <data key="d5">processing is necessary for exercising the right of freedom of expression and information</data>
    </node>
    <node id="OBL-0108">
      <data key="d1">obligation</data>
      <data key="d2">(b) for compliance with a legal obligation which requires processing by Union or Member State law to which the
controller is subject or for the performance of a task carried out in the public interest or in the exercise of official
authority vested in the controller;</data>
      <data key="d3">Article 8</data>
      <data key="d4">processing</data>
    </node>
    <node id="COND:OBL-0108">
      <data key="d1">condition</data>
      <data key="d5">compliance with a legal obligation which requires processing by Union or Member State law or for the performance of a task carried out in the public interest or in the exercise of official authority vested in the controller</data>
    </node>
    <node id="OBL-0109">
      <data key="d1">obligation</data>
      <data key="d2">The data subject shall have the right to obtain from the controller restriction of processing where one of the
following applies:
(a) the accuracy of the personal data is contested by the data subject, for a period enabling the controller to verify the
accuracy of the personal data;</data>
      <data key="d3">Article 8</data>
      <data key="d4">obtain from the controller restriction of processing</data>
    </node>
    <node id="COND:OBL-0109">
      <data key="d1">condition</data>
      <data key="d5">the accuracy of the personal data is contested by the data subject</data>
    </node>
    <node id="DL:OBL-0109">
      <data key="d1">deadline</data>
      <data key="d5">for a period enabling the controller to verify the accuracy of the personal data</data>
    </node>
    <node id="OBL-0110">
      <data key="d1">obligation</data>
      <data key="d2">Where processing has been restricted under paragraph 1, such personal data shall, with the exception of storage,
only be processed with the data subject's consent or for the establishment, exercise or defence of legal claims or for the
protection of the rights of another natural or legal person or for reasons of important public interest of the Union or of
a Member State.</data>
      <data key="d3">Article 8</data>
      <data key="d4">Process personal data only with the data subject's consent or for specific purposes</data>
    </node>
    <node id="COND:OBL-0110">
      <data key="d1">condition</data>
      <data key="d5">Where processing has been restricted under paragraph 1</data>
    </node>
    <node id="EXC:OBL-0110">
      <data key="d1">exception</data>
      <data key="d5">Storage</data>
    </node>
    <node id="OBL-0111">
      <data key="d1">obligation</data>
      <data key="d2">A data subject who has obtained restriction of processing pursuant to paragraph 1 shall be informed by the
controller before the restriction of processing is lifted.</data>
      <data key="d3">Article 19</data>
      <data key="d4">inform the data subject before the restriction of processing is lifted</data>
    </node>
    <node id="COND:OBL-0111">
      <data key="d1">condition</data>
      <data key="d5">data subject has obtained restriction of processing pursuant to paragraph 1</data>
    </node>
    <node id="OBL-0112">
      <data key="d1">obligation</data>
      <data key="d2">Article 19
Notification obligation regarding rectification or erasure of personal data or restriction of
processing
The controller shall communicate any rectification or erasure of personal data or restriction of processing carried out in
accordance with Article 16, Article 17(1) and Article 18 to each recipient to whom the personal data have been
disclosed, unless this proves impossible or involves disproportionate effort.</data>
      <data key="d3">Article 19</data>
      <data key="d4">Communicate any rectification or erasure of personal data or restriction of processing to each recipient to whom the personal data have been disclosed</data>
    </node>
    <node id="SUBJ:The controller">
      <data key="d1">subject</data>
      <data key="d5">The controller</data>
    </node>
    <node id="COND:OBL-0112">
      <data key="d1">condition</data>
      <data key="d5">Carried out in accordance with Article 16, Article 17(1) and Article 18</data>
    </node>
    <node id="EXC:OBL-0112">
      <data key="d1">exception</data>
      <data key="d5">Unless this proves impossible or involves disproportionate effort</data>
    </node>
    <node id="OBL-0113">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall inform the data subject
about those recipients if the data subject requests it.</data>
      <data key="d3">Article 19</data>
      <data key="d4">inform the data subject about those recipients</data>
    </node>
    <node id="COND:OBL-0113">
      <data key="d1">condition</data>
      <data key="d5">if the data subject requests it</data>
    </node>
    <node id="OBL-0114">
      <data key="d1">obligation</data>
      <data key="d2">The data subject shall have the right to receive the personal data concerning him or her, which he or she has
provided to a controller, in a structured, commonly used and machine-readable format and have the right to transmit
those data to another controller without hindrance from the controller to which the personal data have been provided,
where:
(a) the processing is based on consent pursuant to point (a) of Article 6(1) or point (a) of Article 9(2) or on a contract
pursuant to point (b) of Article 6(1);</data>
      <data key="d3">Article 19</data>
      <data key="d4">have the right to receive the personal data concerning him or her, which he or she has provided to a controller, in a structured, commonly used and machine-readable format and have the right to transmit those data to another controller without hindrance</data>
    </node>
    <node id="COND:OBL-0114">
      <data key="d1">condition</data>
      <data key="d5">where the processing is based on consent pursuant to point (a) of Article 6(1) or point (a) of Article 9(2) or on a contract pursuant to point (b) of Article 6(1)</data>
    </node>
    <node id="OBL-0115">
      <data key="d1">obligation</data>
      <data key="d2">In exercising his or her right to data portability pursuant to paragraph 1, the data subject shall have the right to
have the personal data transmitted directly from one controller to another, where technically feasible.</data>
      <data key="d3">Article 19</data>
      <data key="d4">have the personal data transmitted directly from one controller to another</data>
    </node>
    <node id="COND:OBL-0115">
      <data key="d1">condition</data>
      <data key="d5">where technically feasible</data>
    </node>
    <node id="OBL-0116">
      <data key="d1">obligation</data>
      <data key="d2">The exercise of the right referred to in paragraph 1 of this Article shall be without prejudice to Article 17.</data>
      <data key="d3">Article 19</data>
    </node>
    <node id="OBL-0117">
      <data key="d1">obligation</data>
      <data key="d2">That
right shall not apply to processing necessary for the performance of a task carried out in the public interest or in the
exercise of official authority vested in the controller.</data>
      <data key="d3">Article 19</data>
      <data key="d4">processing necessary for the performance of a task</data>
    </node>
    <node id="COND:OBL-0117">
      <data key="d1">condition</data>
      <data key="d5">carried out in the public interest or in the exercise of official authority vested</data>
    </node>
    <node id="EXC:OBL-0117">
      <data key="d1">exception</data>
      <data key="d5">right shall not apply</data>
    </node>
    <node id="OBL-0118">
      <data key="d1">obligation</data>
      <data key="d2">The right referred to in paragraph 1 shall not adversely affect the rights and freedoms of others.</data>
      <data key="d3">Article 19</data>
      <data key="d4">Shall not adversely affect the rights and freedoms of others</data>
    </node>
    <node id="COND:OBL-0118">
      <data key="d1">condition</data>
      <data key="d5">The right referred to in paragraph 1</data>
    </node>
    <node id="OBL-0119">
      <data key="d1">obligation</data>
      <data key="d2">The data subject shall have the right to object, on grounds relating to his or her particular situation, at any time to
processing of personal data concerning him or her which is based on point (e) or (f) of Article 6(1), including profiling
based on those provisions.</data>
      <data key="d3">Article 19</data>
      <data key="d4">have the right to object to processing of personal data</data>
    </node>
    <node id="COND:OBL-0119">
      <data key="d1">condition</data>
      <data key="d5">on grounds relating to his or her particular situation, at any time</data>
    </node>
    <node id="EXC:OBL-0119">
      <data key="d1">exception</data>
      <data key="d5">processing based on point (e) or (f) of Article 6(1), including profiling based on those provisions</data>
    </node>
    <node id="OBL-0120">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall no longer process the personal data unless the controller demonstrates
compelling legitimate grounds for the processing which override the interests, rights and freedoms of the data subject or
for the establishment, exercise or defence of legal claims.</data>
      <data key="d3">Article 19</data>
      <data key="d4">shall no longer process the personal data</data>
    </node>
    <node id="COND:OBL-0120">
      <data key="d1">condition</data>
      <data key="d5">unless the controller demonstrates compelling legitimate grounds for the processing which override the interests, rights and freedoms of the data subject or for the establishment, exercise or defence of legal claims</data>
    </node>
    <node id="OBL-0121">
      <data key="d1">obligation</data>
      <data key="d2">Where personal data are processed for direct marketing purposes, the data subject shall have the right to object at
any time to processing of personal data concerning him or her for such marketing, which includes profiling to the
extent that it is related to such direct marketing.</data>
      <data key="d3">Article 19</data>
      <data key="d4">have the right to object to processing of personal data for direct marketing</data>
    </node>
    <node id="COND:OBL-0121">
      <data key="d1">condition</data>
      <data key="d5">personal data are processed for direct marketing purposes</data>
    </node>
    <node id="DL:OBL-0121">
      <data key="d1">deadline</data>
      <data key="d5">at any time</data>
    </node>
    <node id="OBL-0122">
      <data key="d1">obligation</data>
      <data key="d2">Where the data subject objects to processing for direct marketing purposes, the personal data shall no longer be
processed for such purposes.</data>
      <data key="d3">Article 19</data>
      <data key="d4">Personal data shall no longer be processed for direct marketing purposes</data>
    </node>
    <node id="SUBJ:Data controller">
      <data key="d1">subject</data>
      <data key="d5">Data controller</data>
    </node>
    <node id="COND:OBL-0122">
      <data key="d1">condition</data>
      <data key="d5">Where the data subject objects to processing for direct marketing purposes</data>
    </node>
    <node id="OBL-0123">
      <data key="d1">obligation</data>
      <data key="d2">At the latest at the time of the first communication with the data subject, the right referred to in paragraphs 1 and
2 shall be explicitly brought to the attention of the data subject and shall be presented clearly and separately from any
other information.</data>
      <data key="d3">Article 89</data>
      <data key="d4">Explicitly bring the right referred to in paragraphs 1 and 2 to the attention of the data subject and present it clearly and separately from any other information</data>
    </node>
    <node id="SUBJ:The entity communicating with the data subject">
      <data key="d1">subject</data>
      <data key="d5">The entity communicating with the data subject</data>
    </node>
    <node id="COND:OBL-0123">
      <data key="d1">condition</data>
      <data key="d5">At the time of the first communication with the data subject</data>
    </node>
    <node id="OBL-0124">
      <data key="d1">obligation</data>
      <data key="d2">Where personal data are processed for scientific or historical research purposes or statistical purposes pursuant to
Article 89(1), the data subject, on grounds relating to his or her particular situation, shall have the right to object to
processing of personal data concerning him or her, unless the processing is necessary for the performance of a task
carried out for reasons of public interest.</data>
      <data key="d3">Article 89</data>
      <data key="d4">have the right to object to processing of personal data concerning him or her</data>
    </node>
    <node id="COND:OBL-0124">
      <data key="d1">condition</data>
      <data key="d5">personal data are processed for scientific or historical research purposes or statistical purposes pursuant to Article 89(1)</data>
    </node>
    <node id="EXC:OBL-0124">
      <data key="d1">exception</data>
      <data key="d5">processing is necessary for the performance of a task carried out for reasons of public interest</data>
    </node>
    <node id="OBL-0125">
      <data key="d1">obligation</data>
      <data key="d2">The data subject shall have the right not to be subject to a decision based solely on automated processing,
including profiling, which produces legal effects concerning him or her or similarly significantly affects him or her.</data>
      <data key="d3">Article 89</data>
      <data key="d4">have the right not to be subject to a decision based solely on automated processing</data>
    </node>
    <node id="COND:OBL-0125">
      <data key="d1">condition</data>
      <data key="d5">produces legal effects concerning him or her or similarly significantly affects him or her</data>
    </node>
    <node id="OBL-0126">
      <data key="d1">obligation</data>
      <data key="d2">Paragraph 1 shall not apply if the decision:
(a) is necessary for entering into, or performance of, a contract between the data subject and a data controller;</data>
      <data key="d3">Article 89</data>
      <data key="d4">Paragraph 1 shall not apply</data>
    </node>
    <node id="SUBJ:data controller">
      <data key="d1">subject</data>
      <data key="d5">data controller</data>
    </node>
    <node id="COND:OBL-0126">
      <data key="d1">condition</data>
      <data key="d5">if the decision is necessary for entering into, or performance of, a contract between the data subject and a data controller</data>
    </node>
    <node id="OBL-0127">
      <data key="d1">obligation</data>
      <data key="d2">In the cases referred to in points (a) and (c) of paragraph 2, the data controller shall implement suitable measures
to safeguard the data subject's rights and freedoms and legitimate interests, at least the right to obtain human
intervention on the part of the controller, to express his or her point of view and to contest the decision.</data>
      <data key="d3">Article 89</data>
      <data key="d4">implement suitable measures to safeguard the data subject's rights and freedoms and legitimate interests</data>
    </node>
    <node id="COND:OBL-0127">
      <data key="d1">condition</data>
      <data key="d5">In the cases referred to in points (a) and (c) of paragraph 2</data>
    </node>
    <node id="OBL-0128">
      <data key="d1">obligation</data>
      <data key="d2">Decisions referred to in paragraph 2 shall not be based on special categories of personal data referred to in
Article 9(1), unless point (a) or (g) of Article 9(2) applies and suitable measures to safeguard the data subject's rights and
freedoms and legitimate interests are in place.</data>
      <data key="d3">Article 89</data>
      <data key="d4">shall not be based on special categories of personal data referred to in Article 9(1)</data>
    </node>
    <node id="SUBJ:Decisions referred to in paragraph 2">
      <data key="d1">subject</data>
      <data key="d5">Decisions referred to in paragraph 2</data>
    </node>
    <node id="COND:OBL-0128">
      <data key="d1">condition</data>
      <data key="d5">unless point (a) or (g) of Article 9(2) applies and suitable measures to safeguard the data subject's rights and freedoms and legitimate interests are in place</data>
    </node>
    <node id="OBL-0129">
      <data key="d1">obligation</data>
      <data key="d2">In particular, any legislative measure referred to in paragraph 1 shall contain specific provisions at least, where
relevant, as to:
(a) the purposes of the processing or categories of processing;</data>
      <data key="d3">CHAPTER IV</data>
      <data key="d4">contain specific provisions</data>
    </node>
    <node id="SUBJ:legislative measure">
      <data key="d1">subject</data>
      <data key="d5">legislative measure</data>
    </node>
    <node id="COND:OBL-0129">
      <data key="d1">condition</data>
      <data key="d5">referred to in paragraph 1</data>
    </node>
    <node id="EXC:OBL-0129">
      <data key="d1">exception</data>
      <data key="d5">where relevant</data>
    </node>
    <node id="OBL-0130">
      <data key="d1">obligation</data>
      <data key="d2">Taking into account the nature, scope, context and purposes of processing as well as the risks of varying likelihood
and severity for the rights and freedoms of natural persons, the controller shall implement appropriate technical and
organisational measures to ensure and to be able to demonstrate that processing is performed in accordance with this
Regulation.</data>
      <data key="d3">CHAPTER IV</data>
      <data key="d4">implement appropriate technical and organisational measures to ensure and to be able to demonstrate that processing is performed in accordance with this Regulation</data>
    </node>
    <node id="COND:OBL-0130">
      <data key="d1">condition</data>
      <data key="d5">Taking into account the nature, scope, context and purposes of processing as well as the risks of varying likelihood and severity for the rights and freedoms of natural persons</data>
    </node>
    <node id="OBL-0131">
      <data key="d1">obligation</data>
      <data key="d2">Those measures shall be reviewed and updated where necessary.</data>
      <data key="d3">CHAPTER IV</data>
      <data key="d4">review and update measures</data>
    </node>
    <node id="COND:OBL-0131">
      <data key="d1">condition</data>
      <data key="d5">where necessary</data>
    </node>
    <node id="OBL-0132">
      <data key="d1">obligation</data>
      <data key="d2">Where proportionate in relation to processing activities, the measures referred to in paragraph 1 shall include the
implementation of appropriate data protection policies by the controller.</data>
      <data key="d3">CHAPTER IV</data>
      <data key="d4">implementation of appropriate data protection policies</data>
    </node>
    <node id="COND:OBL-0132">
      <data key="d1">condition</data>
      <data key="d5">Where proportionate in relation to processing activities</data>
    </node>
    <node id="OBL-0133">
      <data key="d1">obligation</data>
      <data key="d2">Taking into account the state of the art, the cost of implementation and the nature, scope, context and purposes of
processing as well as the risks of varying likelihood and severity for rights and freedoms of natural persons posed by the
processing, the controller shall, both at the time of the determination of the means for processing and at the time of the
processing itself, implement appropriate technical and organisational measures, such as pseudonymisation, which are
designed to implement data-protection principles, such as data minimisation, in an effective manner and to integrate the
necessary safeguards into the processing in order to meet the requirements of this Regulation and protect the rights of
data subjects.</data>
      <data key="d3">Article 25</data>
      <data key="d4">implement appropriate technical and organisational measures, such as pseudonymisation, designed to implement data-protection principles and integrate necessary safeguards into the processing</data>
    </node>
    <node id="COND:OBL-0133">
      <data key="d1">condition</data>
      <data key="d5">taking into account the state of the art, the cost of implementation, the nature, scope, context and purposes of processing, and the risks of varying likelihood and severity for rights and freedoms of natural persons posed by the processing</data>
    </node>
    <node id="DL:OBL-0133">
      <data key="d1">deadline</data>
      <data key="d5">at the time of the determination of the means for processing and at the time of the processing itself</data>
    </node>
    <node id="OBL-0134">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall implement appropriate technical and organisational measures for ensuring that, by default,
only personal data which are necessary for each specific purpose of the processing are processed.</data>
      <data key="d3">Article 25</data>
      <data key="d4">implement appropriate technical and organisational measures</data>
    </node>
    <node id="COND:OBL-0134">
      <data key="d1">condition</data>
      <data key="d5">for ensuring that, by default, only personal data which are necessary for each specific purpose of the processing are processed</data>
    </node>
    <node id="OBL-0135">
      <data key="d1">obligation</data>
      <data key="d2">That obligation applies
to the amount of personal data collected, the extent of their processing, the period of their storage and their accessibility.</data>
      <data key="d3">Article 25</data>
      <data key="d4">Applies to the amount of personal data collected, the extent of their processing, the period of their storage and their accessibility</data>
    </node>
    <node id="OBL-0136">
      <data key="d1">obligation</data>
      <data key="d2">In particular, such measures shall ensure that by default personal data are not made accessible without the individual's
intervention to an indefinite number of natural persons.</data>
      <data key="d3">Article 25</data>
      <data key="d4">Ensure that personal data are not made accessible without the individual's intervention</data>
    </node>
    <node id="COND:OBL-0136">
      <data key="d1">condition</data>
      <data key="d5">By default</data>
    </node>
    <node id="EXC:OBL-0136">
      <data key="d1">exception</data>
      <data key="d5">To an indefinite number of natural persons</data>
    </node>
    <node id="OBL-0137">
      <data key="d1">obligation</data>
      <data key="d2">Where two or more controllers jointly determine the purposes and means of processing, they shall be joint
controllers.</data>
      <data key="d3">Article 25</data>
      <data key="d4">shall be joint controllers</data>
    </node>
    <node id="SUBJ:controllers">
      <data key="d1">subject</data>
      <data key="d5">controllers</data>
    </node>
    <node id="COND:OBL-0137">
      <data key="d1">condition</data>
      <data key="d5">Where two or more controllers jointly determine the purposes and means of processing</data>
    </node>
    <node id="OBL-0138">
      <data key="d1">obligation</data>
      <data key="d2">They shall in a transparent manner determine their respective responsibilities for compliance with the
obligations under this Regulation, in particular as regards the exercising of the rights of the data subject and their
respective duties to provide the information referred to in Articles 13 and 14, by means of an arrangement between
them unless, and in so far as, the respective responsibilities of the controllers are determined by Union or Member State
law to which the controllers are subject.</data>
      <data key="d3">Article 25</data>
      <data key="d4">Determine their respective responsibilities for compliance with the obligations under this Regulation</data>
    </node>
    <node id="SUBJ:They">
      <data key="d1">subject</data>
      <data key="d5">They</data>
    </node>
    <node id="COND:OBL-0138">
      <data key="d1">condition</data>
      <data key="d5">In a transparent manner, particularly regarding the exercising of the rights of the data subject and their respective duties to provide the information referred to in Articles 13 and 14</data>
    </node>
    <node id="EXC:OBL-0138">
      <data key="d1">exception</data>
      <data key="d5">Unless, and in so far as, the respective responsibilities of the controllers are determined by Union or Member State law to which the controllers are subject</data>
    </node>
    <node id="OBL-0139">
      <data key="d1">obligation</data>
      <data key="d2">The arrangement referred to in paragraph 1 shall duly reflect the respective roles and relationships of the joint
controllers vis-à-vis the data subjects.</data>
      <data key="d3">Article 25</data>
      <data key="d4">Shall duly reflect the respective roles and relationships of the joint controllers vis-à-vis the data subjects</data>
    </node>
    <node id="SUBJ:The arrangement referred to in paragraph 1">
      <data key="d1">subject</data>
      <data key="d5">The arrangement referred to in paragraph 1</data>
    </node>
    <node id="OBL-0140">
      <data key="d1">obligation</data>
      <data key="d2">The essence of the arrangement shall be made available to the data subject.</data>
      <data key="d3">Article 25</data>
      <data key="d4">Make the essence of the arrangement available to the data subject</data>
    </node>
    <node id="SUBJ:The entity responsible for the arrangement">
      <data key="d1">subject</data>
      <data key="d5">The entity responsible for the arrangement</data>
    </node>
    <node id="OBL-0141">
      <data key="d1">obligation</data>
      <data key="d2">Where Article 3(2) applies, the controller or the processor shall designate in writing a representative in the Union.</data>
      <data key="d3">Article 25</data>
      <data key="d4">designate in writing a representative in the Union</data>
    </node>
    <node id="SUBJ:controller or the processor">
      <data key="d1">subject</data>
      <data key="d5">controller or the processor</data>
    </node>
    <node id="COND:OBL-0141">
      <data key="d1">condition</data>
      <data key="d5">Where Article 3(2) applies</data>
    </node>
    <node id="OBL-0142">
      <data key="d1">obligation</data>
      <data key="d2">The obligation laid down in paragraph 1 of this Article shall not apply to:
(a) processing which is occasional, does not include, on a large scale, processing of special categories of data as referred
to in Article 9(1) or processing of personal data relating to criminal convictions and offences referred to in Article
10, and is unlikely to result in a risk to the rights and freedoms of natural persons, taking into account the nature,
context, scope and purposes of the processing;</data>
      <data key="d3">Article 25</data>
      <data key="d4">The obligation laid down in paragraph 1 of this Article shall not apply</data>
    </node>
    <node id="COND:OBL-0142">
      <data key="d1">condition</data>
      <data key="d5">processing which is occasional, does not include, on a large scale, processing of special categories of data as referred to in Article 9(1) or processing of personal data relating to criminal convictions and offences referred to in Article 10, and is unlikely to result in a risk to the rights and freedoms of natural persons</data>
    </node>
    <node id="OBL-0143">
      <data key="d1">obligation</data>
      <data key="d2">The representative shall be established in one of the Member States where the data subjects, whose personal data
are processed in relation to the offering of goods or services to them, or whose behaviour is monitored, are.</data>
      <data key="d3">Article 28</data>
      <data key="d4">shall be established in one of the Member States</data>
    </node>
    <node id="SUBJ:The representative">
      <data key="d1">subject</data>
      <data key="d5">The representative</data>
    </node>
    <node id="COND:OBL-0143">
      <data key="d1">condition</data>
      <data key="d5">where the data subjects, whose personal data are processed in relation to the offering of goods or services to them, or whose behaviour is monitored, are</data>
    </node>
    <node id="OBL-0144">
      <data key="d1">obligation</data>
      <data key="d2">The representative shall be mandated by the controller or processor to be addressed in addition to or instead of
the controller or the processor by, in particular, supervisory authorities and data subjects, on all issues related to
processing, for the purposes of ensuring compliance with this Regulation.</data>
      <data key="d3">Article 28</data>
      <data key="d4">Be addressed by supervisory authorities and data subjects on all issues related to processing</data>
    </node>
    <node id="COND:OBL-0144">
      <data key="d1">condition</data>
      <data key="d5">Mandated by the controller or processor</data>
    </node>
    <node id="OBL-0145">
      <data key="d1">obligation</data>
      <data key="d2">The designation of a representative by the controller or processor shall be without prejudice to legal actions which
could be initiated against the controller or the processor themselves.</data>
      <data key="d3">Article 28</data>
    </node>
    <node id="OBL-0146">
      <data key="d1">obligation</data>
      <data key="d2">Where processing is to be carried out on behalf of a controller, the controller shall use only processors providing
sufficient guarantees to implement appropriate technical and organisational measures in such a manner that processing
will meet the requirements of this Regulation and ensure the protection of the rights of the data subject.</data>
      <data key="d3">Article 28</data>
      <data key="d4">use only processors providing sufficient guarantees to implement appropriate technical and organisational measures</data>
    </node>
    <node id="COND:OBL-0146">
      <data key="d1">condition</data>
      <data key="d5">processing is to be carried out on behalf of a controller</data>
    </node>
    <node id="OBL-0147">
      <data key="d1">obligation</data>
      <data key="d2">The processor shall not engage another processor without prior specific or general written authorisation of the
controller.</data>
      <data key="d3">Article 28</data>
      <data key="d4">shall not engage another processor without prior specific or general written authorisation</data>
    </node>
    <node id="SUBJ:processor">
      <data key="d1">subject</data>
      <data key="d5">processor</data>
    </node>
    <node id="OBL-0148">
      <data key="d1">obligation</data>
      <data key="d2">In the case of general written authorisation, the processor shall inform the controller of any intended changes
concerning the addition or replacement of other processors, thereby giving the controller the opportunity to object to
such changes.</data>
      <data key="d3">Article 28</data>
      <data key="d4">inform the controller of any intended changes concerning the addition or replacement of other processors</data>
    </node>
    <node id="COND:OBL-0148">
      <data key="d1">condition</data>
      <data key="d5">In the case of general written authorisation</data>
    </node>
    <node id="OBL-0149">
      <data key="d1">obligation</data>
      <data key="d2">Processing by a processor shall be governed by a contract or other legal act under Union or Member State law,
that is binding on the processor with regard to the controller and that sets out the subject-matter and duration of the
processing, the nature and purpose of the processing, the type of personal data and categories of data subjects and the
obligations and rights of the controller.</data>
      <data key="d3">Article 28</data>
      <data key="d4">Processing shall be governed by a contract or other legal act</data>
    </node>
    <node id="COND:OBL-0149">
      <data key="d1">condition</data>
      <data key="d5">under Union or Member State law, that is binding on the processor with regard to the controller</data>
    </node>
    <node id="OBL-0150">
      <data key="d1">obligation</data>
      <data key="d2">That contract or other legal act shall stipulate, in particular, that the processor:
(a) processes the personal data only on documented instructions from the controller, including with regard to transfers
of personal data to a third country or an international organisation, unless required to do so by Union or
Member State law to which the processor is subject;</data>
      <data key="d3">Article 28</data>
      <data key="d4">processes the personal data only on documented instructions from the controller</data>
    </node>
    <node id="COND:OBL-0150">
      <data key="d1">condition</data>
      <data key="d5">including with regard to transfers of personal data to a third country or an international organisation</data>
    </node>
    <node id="EXC:OBL-0150">
      <data key="d1">exception</data>
      <data key="d5">unless required to do so by Union or Member State law to which the processor is subject</data>
    </node>
    <node id="OBL-0151">
      <data key="d1">obligation</data>
      <data key="d2">in such a case, the processor shall inform the controller of that
legal requirement before processing, unless that law prohibits such information on important grounds of public
interest;</data>
      <data key="d3">Article 28</data>
      <data key="d4">inform the controller of that legal requirement before processing</data>
    </node>
    <node id="COND:OBL-0151">
      <data key="d1">condition</data>
      <data key="d5">in such a case</data>
    </node>
    <node id="EXC:OBL-0151">
      <data key="d1">exception</data>
      <data key="d5">unless that law prohibits such information on important grounds of public interest</data>
    </node>
    <node id="OBL-0152">
      <data key="d1">obligation</data>
      <data key="d2">(b) ensures that persons authorised to process the personal data have committed themselves to confidentiality or are
under an appropriate statutory obligation of confidentiality;</data>
      <data key="d3">Article 28</data>
      <data key="d4">commit themselves to confidentiality or are under an appropriate statutory obligation of confidentiality</data>
    </node>
    <node id="SUBJ:persons authorised to process the personal data">
      <data key="d1">subject</data>
      <data key="d5">persons authorised to process the personal data</data>
    </node>
    <node id="OBL-0153">
      <data key="d1">obligation</data>
      <data key="d2">(e) taking into account the nature of the processing, assists the controller by appropriate technical and organisational
measures, insofar as this is possible, for the fulfilment of the controller's obligation to respond to requests for
exercising the data subject's rights laid down in Chapter III;</data>
      <data key="d3">Article 28</data>
      <data key="d4">Assists the controller by appropriate technical and organisational measures</data>
    </node>
    <node id="SUBJ:The processor">
      <data key="d1">subject</data>
      <data key="d5">The processor</data>
    </node>
    <node id="COND:OBL-0153">
      <data key="d1">condition</data>
      <data key="d5">Taking into account the nature of the processing, insofar as this is possible</data>
    </node>
    <node id="OBL-0154">
      <data key="d1">obligation</data>
      <data key="d2">L 119/50 EN Official Journal of the European Union 4.5.2016
With regard to point (h) of the first subparagraph, the processor shall immediately inform the controller if, in its
opinion, an instruction infringes this Regulation or other Union or Member State data protection provisions.</data>
      <data key="d3">Article 29</data>
      <data key="d4">inform the controller</data>
    </node>
    <node id="COND:OBL-0154">
      <data key="d1">condition</data>
      <data key="d5">if, in its opinion, an instruction infringes this Regulation or other Union or Member State data protection provisions</data>
    </node>
    <node id="DL:OBL-0154">
      <data key="d1">deadline</data>
      <data key="d5">immediately</data>
    </node>
    <node id="OBL-0155">
      <data key="d1">obligation</data>
      <data key="d2">Where a processor engages another processor for carrying out specific processing activities on behalf of the
controller, the same data protection obligations as set out in the contract or other legal act between the controller and
the processor as referred to in paragraph 3 shall be imposed on that other processor by way of a contract or other legal
act under Union or Member State law, in particular providing sufficient guarantees to implement appropriate technical
and organisational measures in such a manner that the processing will meet the requirements of this Regulation.</data>
      <data key="d3">Article 29</data>
      <data key="d4">Impose the same data protection obligations on another processor by way of a contract or other legal act</data>
    </node>
    <node id="COND:OBL-0155">
      <data key="d1">condition</data>
      <data key="d5">Where a processor engages another processor for carrying out specific processing activities on behalf of the controller</data>
    </node>
    <node id="OBL-0156">
      <data key="d1">obligation</data>
      <data key="d2">Where
that other processor fails to fulfil its data protection obligations, the initial processor shall remain fully liable to the
controller for the performance of that other processor's obligations.</data>
      <data key="d3">Article 29</data>
      <data key="d4">remain fully liable to the controller for the performance of that other processor's obligations</data>
    </node>
    <node id="SUBJ:initial processor">
      <data key="d1">subject</data>
      <data key="d5">initial processor</data>
    </node>
    <node id="COND:OBL-0156">
      <data key="d1">condition</data>
      <data key="d5">that other processor fails to fulfil its data protection obligations</data>
    </node>
    <node id="OBL-0157">
      <data key="d1">obligation</data>
      <data key="d2">The contract or the other legal act referred to in paragraphs 3 and 4 shall be in writing, including in electronic
form.</data>
      <data key="d3">Article 29</data>
      <data key="d4">Shall be in writing, including in electronic form</data>
    </node>
    <node id="SUBJ:The contract or the other legal act">
      <data key="d1">subject</data>
      <data key="d5">The contract or the other legal act</data>
    </node>
    <node id="COND:OBL-0157">
      <data key="d1">condition</data>
      <data key="d5">Referred to in paragraphs 3 and 4</data>
    </node>
    <node id="OBL-0158">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to Articles 82, 83 and 84, if a processor infringes this Regulation by determining the purposes
and means of processing, the processor shall be considered to be a controller in respect of that processing.</data>
      <data key="d3">Article 29</data>
      <data key="d4">shall be considered to be a controller in respect of that processing</data>
    </node>
    <node id="COND:OBL-0158">
      <data key="d1">condition</data>
      <data key="d5">if a processor infringes this Regulation by determining the purposes and means of processing</data>
    </node>
    <node id="EXC:OBL-0158">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to Articles 82, 83 and 84</data>
    </node>
    <node id="OBL-0159">
      <data key="d1">obligation</data>
      <data key="d2">Article 29
Processing under the authority of the controller or processor
The processor and any person acting under the authority of the controller or of the processor, who has access to
personal data, shall not process those data except on instructions from the controller, unless required to do so by Union
or Member State law.</data>
      <data key="d3">Article 29</data>
      <data key="d4">Shall not process personal data except on instructions from the controller</data>
    </node>
    <node id="SUBJ:The processor and any person acting under the authority of the controller or of the processor">
      <data key="d1">subject</data>
      <data key="d5">The processor and any person acting under the authority of the controller or of the processor</data>
    </node>
    <node id="COND:OBL-0159">
      <data key="d1">condition</data>
      <data key="d5">Who has access to personal data</data>
    </node>
    <node id="EXC:OBL-0159">
      <data key="d1">exception</data>
      <data key="d5">Unless required to do so by Union or Member State law</data>
    </node>
    <node id="OBL-0160">
      <data key="d1">obligation</data>
      <data key="d2">Each controller and, where applicable, the controller's representative, shall maintain a record of processing
activities under its responsibility.</data>
      <data key="d3">Article 29</data>
      <data key="d4">maintain a record of processing activities</data>
    </node>
    <node id="SUBJ:Each controller and, where applicable, the controller's representative">
      <data key="d1">subject</data>
      <data key="d5">Each controller and, where applicable, the controller's representative</data>
    </node>
    <node id="COND:OBL-0160">
      <data key="d1">condition</data>
      <data key="d5">under its responsibility</data>
    </node>
    <node id="OBL-0161">
      <data key="d1">obligation</data>
      <data key="d2">That record shall contain all of the following information:
(a) the name and contact details of the controller and, where applicable, the joint controller, the controller's representa­
tive and the data protection officer;</data>
      <data key="d3">Article 29</data>
      <data key="d4">Shall contain the name and contact details of the controller and, where applicable, the joint controller, the controller's representative and the data protection officer</data>
    </node>
    <node id="SUBJ:The record">
      <data key="d1">subject</data>
      <data key="d5">The record</data>
    </node>
    <node id="OBL-0162">
      <data key="d1">obligation</data>
      <data key="d2">Each processor and, where applicable, the processor's representative shall maintain a record of all categories of
processing activities carried out on behalf of a controller, containing:
(a) the name and contact details of the processor or processors and of each controller on behalf of which the processor
is acting, and, where applicable, of the controller's or the processor's representative, and the data protection officer;</data>
      <data key="d3">Article 32</data>
      <data key="d4">maintain a record of all categories of processing activities carried out on behalf of a controller</data>
    </node>
    <node id="SUBJ:processor and, where applicable, the processor's representative">
      <data key="d1">subject</data>
      <data key="d5">processor and, where applicable, the processor's representative</data>
    </node>
    <node id="OBL-0163">
      <data key="d1">obligation</data>
      <data key="d2">The records referred to in paragraphs 1 and 2 shall be in writing, including in electronic form.</data>
      <data key="d3">Article 32</data>
      <data key="d4">Shall be in writing, including in electronic form</data>
    </node>
    <node id="SUBJ:The records">
      <data key="d1">subject</data>
      <data key="d5">The records</data>
    </node>
    <node id="COND:OBL-0163">
      <data key="d1">condition</data>
      <data key="d5">Referred to in paragraphs 1 and 2</data>
    </node>
    <node id="OBL-0164">
      <data key="d1">obligation</data>
      <data key="d2">The controller or the processor and, where applicable, the controller's or the processor's representative, shall make
the record available to the supervisory authority on request.</data>
      <data key="d3">Article 32</data>
      <data key="d4">Make the record available to the supervisory authority</data>
    </node>
    <node id="SUBJ:The controller or the processor and, where applicable, the controller's or the processor's representative">
      <data key="d1">subject</data>
      <data key="d5">The controller or the processor and, where applicable, the controller's or the processor's representative</data>
    </node>
    <node id="COND:OBL-0164">
      <data key="d1">condition</data>
      <data key="d5">On request</data>
    </node>
    <node id="OBL-0165">
      <data key="d1">obligation</data>
      <data key="d2">The obligations referred to in paragraphs 1 and 2 shall not apply to an enterprise or an organisation employing
fewer than 250 persons unless the processing it carries out is likely to result in a risk to the rights and freedoms of
data subjects, the processing is not occasional, or the processing includes special categories of data as referred to in
Article 9(1) or personal data relating to criminal convictions and offences referred to in Article 10.</data>
      <data key="d3">Article 32</data>
      <data key="d4">The obligations referred to in paragraphs 1 and 2 shall not apply</data>
    </node>
    <node id="SUBJ:enterprise or an organisation">
      <data key="d1">subject</data>
      <data key="d5">enterprise or an organisation</data>
    </node>
    <node id="COND:OBL-0165">
      <data key="d1">condition</data>
      <data key="d5">employing fewer than 250 persons</data>
    </node>
    <node id="EXC:OBL-0165">
      <data key="d1">exception</data>
      <data key="d5">unless the processing it carries out is likely to result in a risk to the rights and freedoms of data subjects, the processing is not occasional, or the processing includes special categories of data as referred to in Article 9(1) or personal data relating to criminal convictions and offences referred to in Article 10</data>
    </node>
    <node id="OBL-0166">
      <data key="d1">obligation</data>
      <data key="d2">Article 31
Cooperation with the supervisory authority
The controller and the processor and, where applicable, their representatives, shall cooperate, on request, with the
supervisory authority in the performance of its tasks.</data>
      <data key="d3">Article 32</data>
      <data key="d4">Cooperate with the supervisory authority</data>
    </node>
    <node id="SUBJ:The controller and the processor and, where applicable, their representatives">
      <data key="d1">subject</data>
      <data key="d5">The controller and the processor and, where applicable, their representatives</data>
    </node>
    <node id="COND:OBL-0166">
      <data key="d1">condition</data>
      <data key="d5">On request</data>
    </node>
    <node id="OBL-0167">
      <data key="d1">obligation</data>
      <data key="d2">Taking into account the state of the art, the costs of implementation and the nature, scope, context and purposes
of processing as well as the risk of varying likelihood and severity for the rights and freedoms of natural persons, the
controller and the processor shall implement appropriate technical and organisational measures to ensure a level of
security appropriate to the risk, including inter alia as appropriate:
(a) the pseudonymisation and encryption of personal data;</data>
      <data key="d3">Article 32</data>
      <data key="d4">implement appropriate technical and organisational measures to ensure a level of security appropriate to the risk</data>
    </node>
    <node id="SUBJ:controller and the processor">
      <data key="d1">subject</data>
      <data key="d5">controller and the processor</data>
    </node>
    <node id="COND:OBL-0167">
      <data key="d1">condition</data>
      <data key="d5">Taking into account the state of the art, the costs of implementation and the nature, scope, context and purposes of processing as well as the risk of varying likelihood and severity for the rights and freedoms of natural persons</data>
    </node>
    <node id="OBL-0168">
      <data key="d1">obligation</data>
      <data key="d2">In assessing the appropriate level of security account shall be taken in particular of the risks that are presented by
processing, in particular from accidental or unlawful destruction, loss, alteration, unauthorised disclosure of, or access to
personal data transmitted, stored or otherwise processed.</data>
      <data key="d3">Article 33</data>
      <data key="d4">Assess the appropriate level of security</data>
    </node>
    <node id="COND:OBL-0168">
      <data key="d1">condition</data>
      <data key="d5">Risks presented by processing, in particular from accidental or unlawful destruction, loss, alteration, unauthorised disclosure of, or access to personal data transmitted, stored or otherwise processed</data>
    </node>
    <node id="OBL-0169">
      <data key="d1">obligation</data>
      <data key="d2">The controller and processor shall take steps to ensure that any natural person acting under the authority of the
controller or the processor who has access to personal data does not process them except on instructions from the
controller, unless he or she is required to do so by Union or Member State law.</data>
      <data key="d3">Article 33</data>
      <data key="d4">Take steps to ensure that any natural person acting under their authority does not process personal data except on instructions from the controller</data>
    </node>
    <node id="SUBJ:The controller and processor">
      <data key="d1">subject</data>
      <data key="d5">The controller and processor</data>
    </node>
    <node id="COND:OBL-0169">
      <data key="d1">condition</data>
      <data key="d5">Any natural person acting under the authority of the controller or the processor who has access to personal data</data>
    </node>
    <node id="EXC:OBL-0169">
      <data key="d1">exception</data>
      <data key="d5">Unless he or she is required to do so by Union or Member State law</data>
    </node>
    <node id="OBL-0170">
      <data key="d1">obligation</data>
      <data key="d2">In the case of a personal data breach, the controller shall without undue delay and, where feasible, not later than
72 hours after having become aware of it, notify the personal data breach to the supervisory authority competent in
accordance with Article 55, unless the personal data breach is unlikely to result in a risk to the rights and freedoms of
natural persons.</data>
      <data key="d3">Article 33</data>
      <data key="d4">notify the personal data breach to the supervisory authority</data>
    </node>
    <node id="COND:OBL-0170">
      <data key="d1">condition</data>
      <data key="d5">in the case of a personal data breach</data>
    </node>
    <node id="DL:OBL-0170">
      <data key="d1">deadline</data>
      <data key="d5">without undue delay and, where feasible, not later than 72 hours after having become aware of it</data>
    </node>
    <node id="EXC:OBL-0170">
      <data key="d1">exception</data>
      <data key="d5">unless the personal data breach is unlikely to result in a risk to the rights and freedoms of natural persons</data>
    </node>
    <node id="OBL-0171">
      <data key="d1">obligation</data>
      <data key="d2">Where the notification to the supervisory authority is not made within 72 hours, it shall be
accompanied by reasons for the delay.</data>
      <data key="d3">Article 33</data>
      <data key="d4">Accompany the notification with reasons for the delay</data>
    </node>
    <node id="COND:OBL-0171">
      <data key="d1">condition</data>
      <data key="d5">Notification to the supervisory authority is not made within 72 hours</data>
    </node>
    <node id="OBL-0172">
      <data key="d1">obligation</data>
      <data key="d2">The processor shall notify the controller without undue delay after becoming aware of a personal data breach.</data>
      <data key="d3">Article 33</data>
      <data key="d4">notify the controller</data>
    </node>
    <node id="COND:OBL-0172">
      <data key="d1">condition</data>
      <data key="d5">after becoming aware of a personal data breach</data>
    </node>
    <node id="DL:OBL-0172">
      <data key="d1">deadline</data>
      <data key="d5">without undue delay</data>
    </node>
    <node id="OBL-0173">
      <data key="d1">obligation</data>
      <data key="d2">The notification referred to in paragraph 1 shall at least:
(a) describe the nature of the personal data breach including where possible, the categories and approximate number of
data subjects concerned and the categories and approximate number of personal data records concerned;</data>
      <data key="d3">Article 33</data>
      <data key="d4">Describe the nature of the personal data breach including where possible, the categories and approximate number of data subjects concerned and the categories and approximate number of personal data records concerned</data>
    </node>
    <node id="COND:OBL-0173">
      <data key="d1">condition</data>
      <data key="d5">The notification referred to in paragraph 1</data>
    </node>
    <node id="OBL-0174">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall document any personal data breaches, comprising the facts relating to the personal data
breach, its effects and the remedial action taken.</data>
      <data key="d3">Article 33</data>
      <data key="d4">Document any personal data breaches, comprising the facts relating to the personal data breach, its effects and the remedial action taken</data>
    </node>
    <node id="OBL-0175">
      <data key="d1">obligation</data>
      <data key="d2">That documentation shall enable the supervisory authority to verify
compliance with this Article.</data>
      <data key="d3">Article 33</data>
      <data key="d4">Enable the supervisory authority to verify compliance with this Article</data>
    </node>
    <node id="COND:OBL-0175">
      <data key="d1">condition</data>
      <data key="d5">That documentation</data>
    </node>
    <node id="OBL-0176">
      <data key="d1">obligation</data>
      <data key="d2">When the personal data breach is likely to result in a high risk to the rights and freedoms of natural persons, the
controller shall communicate the personal data breach to the data subject without undue delay.</data>
      <data key="d3">Article 33</data>
      <data key="d4">communicate the personal data breach to the data subject</data>
    </node>
    <node id="COND:OBL-0176">
      <data key="d1">condition</data>
      <data key="d5">when the personal data breach is likely to result in a high risk to the rights and freedoms of natural persons</data>
    </node>
    <node id="DL:OBL-0176">
      <data key="d1">deadline</data>
      <data key="d5">without undue delay</data>
    </node>
    <node id="OBL-0177">
      <data key="d1">obligation</data>
      <data key="d2">The communication to the data subject referred to in paragraph 1 of this Article shall describe in clear and plain
language the nature of the personal data breach and contain at least the information and measures referred to in
points (b), (c) and (d) of Article 33(3).</data>
      <data key="d3">Section 3</data>
      <data key="d4">Describe in clear and plain language the nature of the personal data breach and contain at least the information and measures referred to in points (b), (c) and (d) of Article 33(3)</data>
    </node>
    <node id="SUBJ:The communication to the data subject">
      <data key="d1">subject</data>
      <data key="d5">The communication to the data subject</data>
    </node>
    <node id="COND:OBL-0177">
      <data key="d1">condition</data>
      <data key="d5">Referred to in paragraph 1 of this Article</data>
    </node>
    <node id="OBL-0178">
      <data key="d1">obligation</data>
      <data key="d2">The communication to the data subject referred to in paragraph 1 shall not be required if any of the following
conditions are met:
(a) the controller has implemented appropriate technical and organisational protection measures, and those measures
were applied to the personal data affected by the personal data breach, in particular those that render the personal
data unintelligible to any person who is not authorised to access it, such as encryption;</data>
      <data key="d3">Section 3</data>
      <data key="d4">Communication to the data subject is not required</data>
    </node>
    <node id="COND:OBL-0178">
      <data key="d1">condition</data>
      <data key="d5">If the controller has implemented appropriate technical and organisational protection measures applied to the personal data affected by the breach</data>
    </node>
    <node id="EXC:OBL-0178">
      <data key="d1">exception</data>
      <data key="d5">Measures render the personal data unintelligible to unauthorized persons, such as encryption</data>
    </node>
    <node id="OBL-0179">
      <data key="d1">obligation</data>
      <data key="d2">(b) the controller has taken subsequent measures which ensure that the high risk to the rights and freedoms of data
subjects referred to in paragraph 1 is no longer likely to materialise;</data>
      <data key="d3">Section 3</data>
      <data key="d4">has taken subsequent measures</data>
    </node>
    <node id="SUBJ:the controller">
      <data key="d1">subject</data>
      <data key="d5">the controller</data>
    </node>
    <node id="COND:OBL-0179">
      <data key="d1">condition</data>
      <data key="d5">to ensure that the high risk to the rights and freedoms of data subjects is no longer likely to materialise</data>
    </node>
    <node id="OBL-0180">
      <data key="d1">obligation</data>
      <data key="d2">In such a case, there shall instead be a public communication or similar
measure whereby the data subjects are informed in an equally effective manner.</data>
      <data key="d3">Section 3</data>
      <data key="d4">Inform data subjects in an equally effective manner</data>
    </node>
    <node id="COND:OBL-0180">
      <data key="d1">condition</data>
      <data key="d5">In such a case</data>
    </node>
    <node id="OBL-0181">
      <data key="d1">obligation</data>
      <data key="d2">Where a type of processing in particular using new technologies, and taking into account the nature, scope,
context and purposes of the processing, is likely to result in a high risk to the rights and freedoms of natural persons,
the controller shall, prior to the processing, carry out an assessment of the impact of the envisaged processing
operations on the protection of personal data.</data>
      <data key="d3">Section 3</data>
      <data key="d4">carry out an assessment of the impact of the envisaged processing operations on the protection of personal data</data>
    </node>
    <node id="COND:OBL-0181">
      <data key="d1">condition</data>
      <data key="d5">Where a type of processing in particular using new technologies, and taking into account the nature, scope, context and purposes of the processing, is likely to result in a high risk to the rights and freedoms of natural persons</data>
    </node>
    <node id="DL:OBL-0181">
      <data key="d1">deadline</data>
      <data key="d5">prior to the processing</data>
    </node>
    <node id="OBL-0182">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall seek the advice of the data protection officer, where designated, when carrying out a data
protection impact assessment.</data>
      <data key="d3">Section 3</data>
      <data key="d4">seek the advice of the data protection officer</data>
    </node>
    <node id="COND:OBL-0182">
      <data key="d1">condition</data>
      <data key="d5">when carrying out a data protection impact assessment</data>
    </node>
    <node id="EXC:OBL-0182">
      <data key="d1">exception</data>
      <data key="d5">where designated</data>
    </node>
    <node id="OBL-0183">
      <data key="d1">obligation</data>
      <data key="d2">A data protection impact assessment referred to in paragraph 1 shall in particular be required in the case of:
(a) a systematic and extensive evaluation of personal aspects relating to natural persons which is based on automated
processing, including profiling, and on which decisions are based that produce legal effects concerning the natural
person or similarly significantly affect the natural person;</data>
      <data key="d3">Section 3</data>
      <data key="d4">Conduct a data protection impact assessment</data>
    </node>
    <node id="COND:OBL-0183">
      <data key="d1">condition</data>
      <data key="d5">In the case of a systematic and extensive evaluation of personal aspects relating to natural persons based on automated processing, including profiling</data>
    </node>
    <node id="OBL-0184">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authority shall establish and make public a list of the kind of processing operations which are
subject to the requirement for a data protection impact assessment pursuant to paragraph 1.</data>
      <data key="d3">Section 3</data>
      <data key="d4">establish and make public a list of the kind of processing operations</data>
    </node>
    <node id="SUBJ:The supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">The supervisory authority</data>
    </node>
    <node id="COND:OBL-0184">
      <data key="d1">condition</data>
      <data key="d5">which are subject to the requirement for a data protection impact assessment pursuant to paragraph 1</data>
    </node>
    <node id="OBL-0185">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authority
shall communicate those lists to the Board referred to in Article 68.</data>
      <data key="d3">Section 3</data>
      <data key="d4">communicate those lists to the Board referred to in Article 68</data>
    </node>
    <node id="OBL-0186">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authority shall communicate those lists to the Board.</data>
      <data key="d3">Section 3</data>
      <data key="d4">communicate those lists to the Board</data>
    </node>
    <node id="OBL-0187">
      <data key="d1">obligation</data>
      <data key="d2">Prior to the adoption of the lists referred to in paragraphs 4 and 5, the competent supervisory authority shall
apply the consistency mechanism referred to in Article 63 where such lists involve processing activities which are
related to the offering of goods or services to data subjects or to the monitoring of their behaviour in several
Member States, or may substantially affect the free movement of personal data within the Union.</data>
      <data key="d3">Section 3</data>
      <data key="d4">apply the consistency mechanism referred to in Article 63</data>
    </node>
    <node id="SUBJ:competent supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">competent supervisory authority</data>
    </node>
    <node id="COND:OBL-0187">
      <data key="d1">condition</data>
      <data key="d5">Prior to the adoption of the lists referred to in paragraphs 4 and 5; where such lists involve processing activities related to the offering of goods or services to data subjects or to the monitoring of their behaviour in several Member States, or may substantially affect the free movement of personal data within the Union</data>
    </node>
    <node id="OBL-0188">
      <data key="d1">obligation</data>
      <data key="d2">The assessment shall contain at least:
(a) a systematic description of the envisaged processing operations and the purposes of the processing, including, where
applicable, the legitimate interest pursued by the controller;</data>
      <data key="d3">Article 36</data>
      <data key="d4">Contain a systematic description of the envisaged processing operations and the purposes of the processing</data>
    </node>
    <node id="SUBJ:The assessment">
      <data key="d1">subject</data>
      <data key="d5">The assessment</data>
    </node>
    <node id="COND:OBL-0188">
      <data key="d1">condition</data>
      <data key="d5">Including, where applicable, the legitimate interest pursued by the controller</data>
    </node>
    <node id="THRESH:OBL-0188">
      <data key="d1">threshold</data>
      <data key="d5">At least</data>
    </node>
    <node id="OBL-0189">
      <data key="d1">obligation</data>
      <data key="d2">Compliance with approved codes of conduct referred to in Article 40 by the relevant controllers or processors
shall be taken into due account in assessing the impact of the processing operations performed by such controllers or
processors, in particular for the purposes of a data protection impact assessment.</data>
      <data key="d3">Article 36</data>
      <data key="d4">Compliance with approved codes of conduct referred to in Article 40</data>
    </node>
    <node id="SUBJ:relevant controllers or processors">
      <data key="d1">subject</data>
      <data key="d5">relevant controllers or processors</data>
    </node>
    <node id="COND:OBL-0189">
      <data key="d1">condition</data>
      <data key="d5">in assessing the impact of the processing operations performed by such controllers or processors, in particular for the purposes of a data protection impact assessment</data>
    </node>
    <node id="OBL-0190">
      <data key="d1">obligation</data>
      <data key="d2">Where appropriate, the controller shall seek the views of data subjects or their representatives on the intended
processing, without prejudice to the protection of commercial or public interests or the security of processing
operations.</data>
      <data key="d3">Article 36</data>
      <data key="d4">seek the views of data subjects or their representatives on the intended processing</data>
    </node>
    <node id="COND:OBL-0190">
      <data key="d1">condition</data>
      <data key="d5">Where appropriate</data>
    </node>
    <node id="EXC:OBL-0190">
      <data key="d1">exception</data>
      <data key="d5">without prejudice to the protection of commercial or public interests or the security of processing operations</data>
    </node>
    <node id="OBL-0191">
      <data key="d1">obligation</data>
      <data key="d2">Where processing pursuant to point (c) or (e) of Article 6(1) has a legal basis in Union law or in the law of the
Member State to which the controller is subject, that law regulates the specific processing operation or set of operations
in question, and a data protection impact assessment has already been carried out as part of a general impact assessment
in the context of the adoption of that legal basis, paragraphs 1 to 7 shall not apply unless Member States deem it to be
necessary to carry out such an assessment prior to processing activities.</data>
      <data key="d3">Article 36</data>
      <data key="d4">Deem it necessary to carry out a data protection impact assessment</data>
    </node>
    <node id="COND:OBL-0191">
      <data key="d1">condition</data>
      <data key="d5">Processing pursuant to point (c) or (e) of Article 6(1) has a legal basis in Union law or in the law of the Member State, and a data protection impact assessment has already been carried out as part of a general impact assessment</data>
    </node>
    <node id="DL:OBL-0191">
      <data key="d1">deadline</data>
      <data key="d5">Prior to processing activities</data>
    </node>
    <node id="EXC:OBL-0191">
      <data key="d1">exception</data>
      <data key="d5">Paragraphs 1 to 7 shall not apply unless deemed necessary</data>
    </node>
    <node id="OBL-0192">
      <data key="d1">obligation</data>
      <data key="d2">Where necessary, the controller shall carry out a review to assess if processing is performed in accordance with
the data protection impact assessment at least when there is a change of the risk represented by processing operations.</data>
      <data key="d3">Article 36</data>
      <data key="d4">carry out a review to assess if processing is performed in accordance with the data protection impact assessment</data>
    </node>
    <node id="COND:OBL-0192">
      <data key="d1">condition</data>
      <data key="d5">where necessary</data>
    </node>
    <node id="OBL-0193">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall consult the supervisory authority prior to processing where a data protection impact
assessment under Article 35 indicates that the processing would result in a high risk in the absence of measures taken
by the controller to mitigate the risk.</data>
      <data key="d3">Article 36</data>
      <data key="d4">consult the supervisory authority prior to processing</data>
    </node>
    <node id="COND:OBL-0193">
      <data key="d1">condition</data>
      <data key="d5">where a data protection impact assessment under Article 35 indicates that the processing would result in a high risk</data>
    </node>
    <node id="EXC:OBL-0193">
      <data key="d1">exception</data>
      <data key="d5">in the absence of measures taken by the controller to mitigate the risk</data>
    </node>
    <node id="OBL-0194">
      <data key="d1">obligation</data>
      <data key="d2">Where the supervisory authority is of the opinion that the intended processing referred to in paragraph 1 would
infringe this Regulation, in particular where the controller has insufficiently identified or mitigated the risk, the
supervisory authority shall, within period of up to eight weeks of receipt of the request for consultation, provide written
advice to the controller and, where applicable to the processor, and may use any of its powers referred to in Article 58.</data>
      <data key="d3">Article 36</data>
      <data key="d4">provide written advice to the controller and, where applicable to the processor</data>
    </node>
    <node id="COND:OBL-0194">
      <data key="d1">condition</data>
      <data key="d5">where the supervisory authority is of the opinion that the intended processing would infringe this Regulation, in particular where the controller has insufficiently identified or mitigated the risk</data>
    </node>
    <node id="DL:OBL-0194">
      <data key="d1">deadline</data>
      <data key="d5">within period of up to eight weeks of receipt of the request for consultation</data>
    </node>
    <node id="OBL-0195">
      <data key="d1">obligation</data>
      <data key="d2">The
supervisory authority shall inform the controller and, where applicable, the processor, of any such extension within one
month of receipt of the request for consultation together with the reasons for the delay.</data>
      <data key="d3">Article 36</data>
      <data key="d4">inform the controller and, where applicable, the processor, of any such extension</data>
    </node>
    <node id="COND:OBL-0195">
      <data key="d1">condition</data>
      <data key="d5">within one month of receipt of the request for consultation</data>
    </node>
    <node id="OBL-0196">
      <data key="d1">obligation</data>
      <data key="d2">When consulting the supervisory authority pursuant to paragraph 1, the controller shall provide the supervisory
authority with:
(a) where applicable, the respective responsibilities of the controller, joint controllers and processors involved in the
processing, in particular for processing within a group of undertakings;</data>
      <data key="d3">Article 36</data>
      <data key="d4">provide the supervisory authority with the respective responsibilities of the controller, joint controllers and processors involved in the processing</data>
    </node>
    <node id="COND:OBL-0196">
      <data key="d1">condition</data>
      <data key="d5">when consulting the supervisory authority pursuant to paragraph 1</data>
    </node>
    <node id="EXC:OBL-0196">
      <data key="d1">exception</data>
      <data key="d5">where applicable</data>
    </node>
    <node id="OBL-0197">
      <data key="d1">obligation</data>
      <data key="d2">Member States shall consult the supervisory authority during the preparation of a proposal for a legislative
measure to be adopted by a national parliament, or of a regulatory measure based on such a legislative measure, which
relates to processing.</data>
      <data key="d3">Section 4</data>
      <data key="d4">consult the supervisory authority</data>
    </node>
    <node id="COND:OBL-0197">
      <data key="d1">condition</data>
      <data key="d5">during the preparation of a proposal for a legislative measure to be adopted by a national parliament, or of a regulatory measure based on such a legislative measure, which relates to processing</data>
    </node>
    <node id="OBL-0198">
      <data key="d1">obligation</data>
      <data key="d2">The controller and the processor shall designate a data protection officer in any case where:
(a) the processing is carried out by a public authority or body, except for courts acting in their judicial capacity;</data>
      <data key="d3">Section 4</data>
      <data key="d4">Designate a data protection officer</data>
    </node>
    <node id="SUBJ:The controller and the processor">
      <data key="d1">subject</data>
      <data key="d5">The controller and the processor</data>
    </node>
    <node id="COND:OBL-0198">
      <data key="d1">condition</data>
      <data key="d5">The processing is carried out by a public authority or body</data>
    </node>
    <node id="EXC:OBL-0198">
      <data key="d1">exception</data>
      <data key="d5">Except for courts acting in their judicial capacity</data>
    </node>
    <node id="OBL-0199">
      <data key="d1">obligation</data>
      <data key="d2">In cases other than those referred to in paragraph 1, the controller or processor or associations and other bodies
representing categories of controllers or processors may or, where required by Union or Member State law shall,
designate a data protection officer.</data>
      <data key="d3">Section 4</data>
      <data key="d4">designate a data protection officer</data>
    </node>
    <node id="SUBJ:controller or processor or associations and other bodies representing categories of controllers or processors">
      <data key="d1">subject</data>
      <data key="d5">controller or processor or associations and other bodies representing categories of controllers or processors</data>
    </node>
    <node id="COND:OBL-0199">
      <data key="d1">condition</data>
      <data key="d5">In cases other than those referred to in paragraph 1</data>
    </node>
    <node id="OBL-0200">
      <data key="d1">obligation</data>
      <data key="d2">The data protection officer shall be designated on the basis of professional qualities and, in particular, expert
knowledge of data protection law and practices and the ability to fulfil the tasks referred to in Article 39.</data>
      <data key="d3">Section 4</data>
      <data key="d4">Shall be designated on the basis of professional qualities and expert knowledge of data protection law and practices</data>
    </node>
    <node id="SUBJ:The data protection officer">
      <data key="d1">subject</data>
      <data key="d5">The data protection officer</data>
    </node>
    <node id="COND:OBL-0200">
      <data key="d1">condition</data>
      <data key="d5">Ability to fulfil the tasks referred to in Article 39</data>
    </node>
    <node id="OBL-0201">
      <data key="d1">obligation</data>
      <data key="d2">The controller or the processor shall publish the contact details of the data protection officer and communicate
them to the supervisory authority.</data>
      <data key="d3">Section 4</data>
      <data key="d4">Publish the contact details of the data protection officer and communicate them to the supervisory authority</data>
    </node>
    <node id="SUBJ:The controller or the processor">
      <data key="d1">subject</data>
      <data key="d5">The controller or the processor</data>
    </node>
    <node id="OBL-0202">
      <data key="d1">obligation</data>
      <data key="d2">The controller and the processor shall ensure that the data protection officer is involved, properly and in a timely
manner, in all issues which relate to the protection of personal data.</data>
      <data key="d3">Section 4</data>
      <data key="d4">Ensure that the data protection officer is involved, properly and in a timely manner, in all issues which relate to the protection of personal data</data>
    </node>
    <node id="OBL-0203">
      <data key="d1">obligation</data>
      <data key="d2">The controller and processor shall support the data protection officer in performing the tasks referred to in
Article 39 by providing resources necessary to carry out those tasks and access to personal data and processing
operations, and to maintain his or her expert knowledge.</data>
      <data key="d3">Article 39</data>
      <data key="d4">Support the data protection officer by providing resources necessary to carry out tasks and access to personal data and processing operations, and to maintain expert knowledge</data>
    </node>
    <node id="COND:OBL-0203">
      <data key="d1">condition</data>
      <data key="d5">In performing the tasks referred to in Article 39</data>
    </node>
    <node id="OBL-0204">
      <data key="d1">obligation</data>
      <data key="d2">The controller and processor shall ensure that the data protection officer does not receive any instructions
regarding the exercise of those tasks.</data>
      <data key="d3">Article 39</data>
      <data key="d4">Ensure that the data protection officer does not receive any instructions regarding the exercise of those tasks</data>
    </node>
    <node id="OBL-0205">
      <data key="d1">obligation</data>
      <data key="d2">He or she shall not be dismissed or penalised by the controller or the processor for
performing his tasks.</data>
      <data key="d3">Article 39</data>
      <data key="d4">shall not dismiss or penalise</data>
    </node>
    <node id="COND:OBL-0205">
      <data key="d1">condition</data>
      <data key="d5">for performing his tasks</data>
    </node>
    <node id="OBL-0206">
      <data key="d1">obligation</data>
      <data key="d2">The data protection officer shall directly report to the highest management level of the controller
or the processor.</data>
      <data key="d3">Article 39</data>
      <data key="d4">shall directly report to the highest management level of the controller or the processor</data>
    </node>
    <node id="SUBJ:data protection officer">
      <data key="d1">subject</data>
      <data key="d5">data protection officer</data>
    </node>
    <node id="OBL-0207">
      <data key="d1">obligation</data>
      <data key="d2">The data protection officer shall be bound by secrecy or confidentiality concerning the performance of his or her
tasks, in accordance with Union or Member State law.</data>
      <data key="d3">Article 39</data>
      <data key="d4">be bound by secrecy or confidentiality</data>
    </node>
    <node id="COND:OBL-0207">
      <data key="d1">condition</data>
      <data key="d5">concerning the performance of his or her tasks</data>
    </node>
    <node id="EXC:OBL-0207">
      <data key="d1">exception</data>
      <data key="d5">in accordance with Union or Member State law</data>
    </node>
    <node id="OBL-0208">
      <data key="d1">obligation</data>
      <data key="d2">The controller or processor shall ensure that any such
tasks and duties do not result in a conflict of interests.</data>
      <data key="d3">Article 39</data>
      <data key="d4">ensure that any such tasks and duties do not result in a conflict of interests</data>
    </node>
    <node id="SUBJ:controller or processor">
      <data key="d1">subject</data>
      <data key="d5">controller or processor</data>
    </node>
    <node id="OBL-0209">
      <data key="d1">obligation</data>
      <data key="d2">The data protection officer shall have at least the following tasks:
(a) to inform and advise the controller or the processor and the employees who carry out processing of their
obligations pursuant to this Regulation and to other Union or Member State data protection provisions;</data>
      <data key="d3">Article 39</data>
      <data key="d4">inform and advise the controller or the processor and the employees who carry out processing of their obligations pursuant to this Regulation and to other Union or Member State data protection provisions</data>
    </node>
    <node id="OBL-0210">
      <data key="d1">obligation</data>
      <data key="d2">The data protection officer shall in the performance of his or her tasks have due regard to the risk associated with
processing operations, taking into account the nature, scope, context and purposes of processing.</data>
      <data key="d3">Article 39</data>
      <data key="d4">Have due regard to the risk associated with processing operations</data>
    </node>
    <node id="COND:OBL-0210">
      <data key="d1">condition</data>
      <data key="d5">In the performance of his or her tasks</data>
    </node>
    <node id="OBL-0211">
      <data key="d1">obligation</data>
      <data key="d2">The Member States, the supervisory authorities, the Board and the Commission shall encourage the drawing up of
codes of conduct intended to contribute to the proper application of this Regulation, taking account of the specific
features of the various processing sectors and the specific needs of micro, small and medium-sized enterprises.</data>
      <data key="d3">Article 39</data>
      <data key="d4">Encourage the drawing up of codes of conduct</data>
    </node>
    <node id="SUBJ:The Member States, the supervisory authorities, the Board and the Commission">
      <data key="d1">subject</data>
      <data key="d5">The Member States, the supervisory authorities, the Board and the Commission</data>
    </node>
    <node id="COND:OBL-0211">
      <data key="d1">condition</data>
      <data key="d5">Intended to contribute to the proper application of this Regulation</data>
    </node>
    <node id="OBL-0212">
      <data key="d1">obligation</data>
      <data key="d2">Such controllers or processors shall make binding and
enforceable commitments, via contractual or other legally binding instruments, to apply those appropriate safeguards
including with regard to the rights of data subjects.</data>
      <data key="d3">Article 39</data>
      <data key="d4">make binding and enforceable commitments to apply appropriate safeguards</data>
    </node>
    <node id="SUBJ:controllers or processors">
      <data key="d1">subject</data>
      <data key="d5">controllers or processors</data>
    </node>
    <node id="COND:OBL-0212">
      <data key="d1">condition</data>
      <data key="d5">via contractual or other legally binding instruments</data>
    </node>
    <node id="OBL-0213">
      <data key="d1">obligation</data>
      <data key="d2">A code of conduct referred to in paragraph 2 of this Article shall contain mechanisms which enable the body
referred to in Article 41(1) to carry out the mandatory monitoring of compliance with its provisions by the controllers
or processors which undertake to apply it, without prejudice to the tasks and powers of supervisory authorities
competent pursuant to Article 55 or 56.</data>
      <data key="d3">Article 39</data>
      <data key="d4">Carry out the mandatory monitoring of compliance with its provisions by the controllers or processors</data>
    </node>
    <node id="SUBJ:The body referred to in Article 41(1)">
      <data key="d1">subject</data>
      <data key="d5">The body referred to in Article 41(1)</data>
    </node>
    <node id="COND:OBL-0213">
      <data key="d1">condition</data>
      <data key="d5">A code of conduct referred to in paragraph 2 of this Article</data>
    </node>
    <node id="EXC:OBL-0213">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to the tasks and powers of supervisory authorities competent pursuant to Article 55 or 56</data>
    </node>
    <node id="OBL-0214">
      <data key="d1">obligation</data>
      <data key="d2">Associations and other bodies referred to in paragraph 2 of this Article which intend to prepare a code of conduct
or to amend or extend an existing code shall submit the draft code, amendment or extension to the supervisory
authority which is competent pursuant to Article 55.</data>
      <data key="d3">Article 39</data>
      <data key="d4">Submit the draft code, amendment or extension to the supervisory authority</data>
    </node>
    <node id="SUBJ:Associations and other bodies referred to in paragraph 2 of this Article">
      <data key="d1">subject</data>
      <data key="d5">Associations and other bodies referred to in paragraph 2 of this Article</data>
    </node>
    <node id="COND:OBL-0214">
      <data key="d1">condition</data>
      <data key="d5">Intend to prepare a code of conduct or to amend or extend an existing code</data>
    </node>
    <node id="OBL-0215">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authority shall provide an opinion on whether the
draft code, amendment or extension complies with this Regulation and shall approve that draft code, amendment or
extension if it finds that it provides sufficient appropriate safeguards.</data>
      <data key="d3">Article 39</data>
      <data key="d4">Provide an opinion on whether the draft code, amendment or extension complies with this Regulation and approve that draft code, amendment or extension if it finds that it provides sufficient appropriate safeguards</data>
    </node>
    <node id="OBL-0216">
      <data key="d1">obligation</data>
      <data key="d2">Where the draft code, or amendment or extension is approved in accordance with paragraph 5, and where the
code of conduct concerned does not relate to processing activities in several Member States, the supervisory authority
shall register and publish the code.</data>
      <data key="d3">Article 39</data>
      <data key="d4">register and publish the code</data>
    </node>
    <node id="COND:OBL-0216">
      <data key="d1">condition</data>
      <data key="d5">Where the draft code, or amendment or extension is approved in accordance with paragraph 5, and where the code of conduct concerned does not relate to processing activities in several Member States</data>
    </node>
    <node id="OBL-0217">
      <data key="d1">obligation</data>
      <data key="d2">Where a draft code of conduct relates to processing activities in several Member States, the supervisory authority
which is competent pursuant to Article 55 shall, before approving the draft code, amendment or extension, submit it in
the procedure referred to in Article 63 to the Board which shall provide an opinion on whether the draft code,
amendment or extension complies with this Regulation or, in the situation referred to in paragraph 3 of this Article,
provides appropriate safeguards.</data>
      <data key="d3">Article 39</data>
      <data key="d4">Submit the draft code, amendment or extension to the Board</data>
    </node>
    <node id="COND:OBL-0217">
      <data key="d1">condition</data>
      <data key="d5">Where a draft code of conduct relates to processing activities in several Member States</data>
    </node>
    <node id="DL:OBL-0217">
      <data key="d1">deadline</data>
      <data key="d5">Before approving the draft code, amendment or extension</data>
    </node>
    <node id="OBL-0218">
      <data key="d1">obligation</data>
      <data key="d2">Where the opinion referred to in paragraph 7 confirms that the draft code, amendment or extension complies
with this Regulation, or, in the situation referred to in paragraph 3, provides appropriate safeguards, the Board shall
submit its opinion to the Commission.</data>
      <data key="d3">Article 39</data>
      <data key="d4">Submit its opinion to the Commission</data>
    </node>
    <node id="SUBJ:The Board">
      <data key="d1">subject</data>
      <data key="d5">The Board</data>
    </node>
    <node id="COND:OBL-0218">
      <data key="d1">condition</data>
      <data key="d5">Where the opinion referred to in paragraph 7 confirms that the draft code, amendment or extension complies with this Regulation, or, in the situation referred to in paragraph 3, provides appropriate safeguards</data>
    </node>
    <node id="OBL-0219">
      <data key="d1">obligation</data>
      <data key="d2">Those
implementing acts shall be adopted in accordance with the examination procedure set out in Article 93(2).</data>
      <data key="d3">Article 39</data>
      <data key="d4">Adopt implementing acts in accordance with the examination procedure</data>
    </node>
    <node id="COND:OBL-0219">
      <data key="d1">condition</data>
      <data key="d5">Set out in Article 93(2)</data>
    </node>
    <node id="OBL-0220">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall ensure appropriate publicity for the approved codes which have been decided as having
general validity in accordance with paragraph 9.</data>
      <data key="d3">Article 41</data>
      <data key="d4">ensure appropriate publicity for the approved codes</data>
    </node>
    <node id="COND:OBL-0220">
      <data key="d1">condition</data>
      <data key="d5">which have been decided as having general validity in accordance with paragraph 9</data>
    </node>
    <node id="OBL-0221">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall collate all approved codes of conduct, amendments and extensions in a register and shall make
them publicly available by way of appropriate means.</data>
      <data key="d3">Article 41</data>
      <data key="d4">collate all approved codes of conduct, amendments and extensions in a register and make them publicly available</data>
    </node>
    <node id="OBL-0222">
      <data key="d1">obligation</data>
      <data key="d2">The competent supervisory authority shall submit the draft criteria for accreditation of a body as referred to in
paragraph 1 of this Article to the Board pursuant to the consistency mechanism referred to in Article 63.</data>
      <data key="d3">Article 41</data>
      <data key="d4">submit the draft criteria for accreditation of a body</data>
    </node>
    <node id="SUBJ:The competent supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">The competent supervisory authority</data>
    </node>
    <node id="COND:OBL-0222">
      <data key="d1">condition</data>
      <data key="d5">as referred to in paragraph 1 of this Article</data>
    </node>
    <node id="OBL-0223">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to the tasks and powers of the competent supervisory authority and the provisions of
Chapter VIII, a body as referred to in paragraph 1 of this Article shall, subject to appropriate safeguards, take
appropriate action in cases of infringement of the code by a controller or processor, including suspension or exclusion
of the controller or processor concerned from the code.</data>
      <data key="d3">Article 41</data>
      <data key="d4">Take appropriate action in cases of infringement of the code by a controller or processor, including suspension or exclusion of the controller or processor concerned from the code</data>
    </node>
    <node id="SUBJ:A body as referred to in paragraph 1 of this Article">
      <data key="d1">subject</data>
      <data key="d5">A body as referred to in paragraph 1 of this Article</data>
    </node>
    <node id="COND:OBL-0223">
      <data key="d1">condition</data>
      <data key="d5">Without prejudice to the tasks and powers of the competent supervisory authority and the provisions of Chapter VIII, subject to appropriate safeguards</data>
    </node>
    <node id="OBL-0224">
      <data key="d1">obligation</data>
      <data key="d2">It shall inform the competent supervisory authority of such
actions and the reasons for taking them.</data>
      <data key="d3">Article 41</data>
      <data key="d4">inform the competent supervisory authority of such actions and the reasons for taking them</data>
    </node>
    <node id="SUBJ:It">
      <data key="d1">subject</data>
      <data key="d5">It</data>
    </node>
    <node id="OBL-0225">
      <data key="d1">obligation</data>
      <data key="d2">The competent supervisory authority shall revoke the accreditation of a body as referred to in paragraph 1 if the
conditions for accreditation are not, or are no longer, met or where actions taken by the body infringe this Regulation.</data>
      <data key="d3">Article 41</data>
      <data key="d4">Revoke the accreditation of a body</data>
    </node>
    <node id="COND:OBL-0225">
      <data key="d1">condition</data>
      <data key="d5">If the conditions for accreditation are not, or are no longer, met or where actions taken by the body infringe this Regulation</data>
    </node>
    <node id="OBL-0226">
      <data key="d1">obligation</data>
      <data key="d2">This Article shall not apply to processing carried out by public authorities and bodies.</data>
      <data key="d3">Article 41</data>
      <data key="d4">The Article shall not apply to processing</data>
    </node>
    <node id="SUBJ:public authorities and bodies">
      <data key="d1">subject</data>
      <data key="d5">public authorities and bodies</data>
    </node>
    <node id="OBL-0227">
      <data key="d1">obligation</data>
      <data key="d2">The Member States, the supervisory authorities, the Board and the Commission shall encourage, in particular at
Union level, the establishment of data protection certification mechanisms and of data protection seals and marks, for
the purpose of demonstrating compliance with this Regulation of processing operations by controllers and processors.</data>
      <data key="d3">Article 41</data>
      <data key="d4">Encourage the establishment of data protection certification mechanisms and of data protection seals and marks</data>
    </node>
    <node id="COND:OBL-0227">
      <data key="d1">condition</data>
      <data key="d5">For the purpose of demonstrating compliance with this Regulation of processing operations by controllers and processors</data>
    </node>
    <node id="OBL-0228">
      <data key="d1">obligation</data>
      <data key="d2">The specific needs of micro, small and medium-sized enterprises shall be taken into account.</data>
      <data key="d3">Article 41</data>
      <data key="d4">Take into account the specific needs of micro, small and medium-sized enterprises</data>
    </node>
    <node id="SUBJ:Regulatory authority or policy maker">
      <data key="d1">subject</data>
      <data key="d5">Regulatory authority or policy maker</data>
    </node>
    <node id="OBL-0229">
      <data key="d1">obligation</data>
      <data key="d2">Such controllers or processors shall make binding
and enforceable commitments, via contractual or other legally binding instruments, to apply those appropriate
safeguards, including with regard to the rights of data subjects.</data>
      <data key="d3">Article 58</data>
      <data key="d4">make binding and enforceable commitments to apply appropriate safeguards</data>
    </node>
    <node id="COND:OBL-0229">
      <data key="d1">condition</data>
      <data key="d5">via contractual or other legally binding instruments</data>
    </node>
    <node id="OBL-0230">
      <data key="d1">obligation</data>
      <data key="d2">The certification shall be voluntary and available via a process that is transparent.</data>
      <data key="d3">Article 58</data>
      <data key="d4">Certification shall be voluntary and available via a transparent process</data>
    </node>
    <node id="OBL-0231">
      <data key="d1">obligation</data>
      <data key="d2">A certification pursuant to this Article shall be issued by the certification bodies referred to in Article 43 or by the
competent supervisory authority, on the basis of criteria approved by that competent supervisory authority pursuant to
Article 58(3) or by the Board pursuant to Article 63.</data>
      <data key="d3">Article 58</data>
      <data key="d4">issue a certification</data>
    </node>
    <node id="SUBJ:certification bodies or competent supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">certification bodies or competent supervisory authority</data>
    </node>
    <node id="COND:OBL-0231">
      <data key="d1">condition</data>
      <data key="d5">pursuant to this Article</data>
    </node>
    <node id="OBL-0232">
      <data key="d1">obligation</data>
      <data key="d2">The controller or processor which submits its processing to the certification mechanism shall provide the certifi­
cation body referred to in Article 43, or where applicable, the competent supervisory authority, with all information
and access to its processing activities which are necessary to conduct the certification procedure.</data>
      <data key="d3">Article 58</data>
      <data key="d4">Provide the certification body or competent supervisory authority with all information and access to its processing activities</data>
    </node>
    <node id="SUBJ:The controller or processor">
      <data key="d1">subject</data>
      <data key="d5">The controller or processor</data>
    </node>
    <node id="COND:OBL-0232">
      <data key="d1">condition</data>
      <data key="d5">Submits its processing to the certification mechanism</data>
    </node>
    <node id="OBL-0233">
      <data key="d1">obligation</data>
      <data key="d2">Certification shall be issued to a controller or processor for a maximum period of three years and may be
renewed, under the same conditions, provided that the relevant requirements continue to be met.</data>
      <data key="d3">Article 58</data>
      <data key="d4">Certification shall be issued</data>
    </node>
    <node id="COND:OBL-0233">
      <data key="d1">condition</data>
      <data key="d5">provided that the relevant requirements continue to be met</data>
    </node>
    <node id="THRESH:OBL-0233">
      <data key="d1">threshold</data>
      <data key="d5">maximum period of three years</data>
    </node>
    <node id="OBL-0234">
      <data key="d1">obligation</data>
      <data key="d2">Certification shall be
withdrawn, as applicable, by the certification bodies referred to in Article 43 or by the competent supervisory authority
where the requirements for the certification are not or are no longer met.</data>
      <data key="d3">Article 58</data>
      <data key="d4">withdraw certification</data>
    </node>
    <node id="SUBJ:certification bodies referred to in Article 43 or the competent supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">certification bodies referred to in Article 43 or the competent supervisory authority</data>
    </node>
    <node id="COND:OBL-0234">
      <data key="d1">condition</data>
      <data key="d5">where the requirements for the certification are not or are no longer met</data>
    </node>
    <node id="OBL-0235">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall collate all certification mechanisms and data protection seals and marks in a register and shall
make them publicly available by any appropriate means.</data>
      <data key="d3">Article 58</data>
      <data key="d4">collate all certification mechanisms and data protection seals and marks in a register and make them publicly available by any appropriate means</data>
    </node>
    <node id="OBL-0236">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to the tasks and powers of the competent supervisory authority under Articles 57 and 58,
certification bodies which have an appropriate level of expertise in relation to data protection shall, after informing the
supervisory authority in order to allow it to exercise its powers pursuant to point (h) of Article 58(2) where necessary,
issue and renew certification.</data>
      <data key="d3">Article 58</data>
      <data key="d4">issue and renew certification</data>
    </node>
    <node id="SUBJ:certification bodies">
      <data key="d1">subject</data>
      <data key="d5">certification bodies</data>
    </node>
    <node id="COND:OBL-0236">
      <data key="d1">condition</data>
      <data key="d5">after informing the supervisory authority in order to allow it to exercise its powers pursuant to point (h) of Article 58(2) where necessary</data>
    </node>
    <node id="EXC:OBL-0236">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to the tasks and powers of the competent supervisory authority under Articles 57 and 58</data>
    </node>
    <node id="OBL-0237">
      <data key="d1">obligation</data>
      <data key="d2">Member States shall ensure that those certification bodies are accredited by one or both of
the following:
(a) the supervisory authority which is competent pursuant to Article 55 or 56;</data>
      <data key="d3">Article 58</data>
      <data key="d4">Ensure that those certification bodies are accredited</data>
    </node>
    <node id="COND:OBL-0237">
      <data key="d1">condition</data>
      <data key="d5">By one or both of the following</data>
    </node>
    <node id="OBL-0238">
      <data key="d1">obligation</data>
      <data key="d2">Certification bodies referred to in paragraph 1 shall be accredited in accordance with that paragraph only where
they have:
(a) demonstrated their independence and expertise in relation to the subject-matter of the certification to the
satisfaction of the competent supervisory authority;</data>
      <data key="d3">Article 58</data>
      <data key="d4">Be accredited</data>
    </node>
    <node id="SUBJ:Certification bodies">
      <data key="d1">subject</data>
      <data key="d5">Certification bodies</data>
    </node>
    <node id="COND:OBL-0238">
      <data key="d1">condition</data>
      <data key="d5">Referred to in paragraph 1 and have demonstrated their independence and expertise in relation to the subject-matter of the certification to the satisfaction of the competent supervisory authority</data>
    </node>
    <node id="OBL-0239">
      <data key="d1">obligation</data>
      <data key="d2">The accreditation of certification bodies as referred to in paragraphs 1 and 2 of this Article shall take place on the
basis of criteria approved by the supervisory authority which is competent pursuant to Article 55 or 56 or by the Board
pursuant to Article 63.</data>
      <data key="d3">Article 42</data>
      <data key="d4">approve criteria for accreditation of certification bodies</data>
    </node>
    <node id="SUBJ:supervisory authority or the Board">
      <data key="d1">subject</data>
      <data key="d5">supervisory authority or the Board</data>
    </node>
    <node id="COND:OBL-0239">
      <data key="d1">condition</data>
      <data key="d5">as referred to in paragraphs 1 and 2 of this Article</data>
    </node>
    <node id="OBL-0240">
      <data key="d1">obligation</data>
      <data key="d2">In the case of accreditation pursuant to point (b) of paragraph 1 of this Article, those
requirements shall complement those envisaged in Regulation (EC) No 765/2008 and the technical rules that describe
the methods and procedures of the certification bodies.</data>
      <data key="d3">Article 42</data>
      <data key="d4">complement those envisaged in Regulation (EC) No 765/2008 and the technical rules</data>
    </node>
    <node id="COND:OBL-0240">
      <data key="d1">condition</data>
      <data key="d5">In the case of accreditation pursuant to point (b) of paragraph 1 of this Article</data>
    </node>
    <node id="OBL-0241">
      <data key="d1">obligation</data>
      <data key="d2">The certification bodies referred to in paragraph 1 shall be responsible for the proper assessment leading to the
certification or the withdrawal of such certification without prejudice to the responsibility of the controller or processor
for compliance with this Regulation.</data>
      <data key="d3">Article 42</data>
      <data key="d4">Responsible for the proper assessment leading to the certification or the withdrawal of such certification</data>
    </node>
    <node id="SUBJ:The certification bodies">
      <data key="d1">subject</data>
      <data key="d5">The certification bodies</data>
    </node>
    <node id="COND:OBL-0241">
      <data key="d1">condition</data>
      <data key="d5">Referred to in paragraph 1</data>
    </node>
    <node id="EXC:OBL-0241">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to the responsibility of the controller or processor for compliance with this Regulation</data>
    </node>
    <node id="OBL-0242">
      <data key="d1">obligation</data>
      <data key="d2">The accreditation shall be issued for a maximum period of five years and may be
renewed on the same conditions provided that the certification body meets the requirements set out in this Article.</data>
      <data key="d3">Article 42</data>
      <data key="d4">accreditation may be renewed</data>
    </node>
    <node id="SUBJ:certification body">
      <data key="d1">subject</data>
      <data key="d5">certification body</data>
    </node>
    <node id="COND:OBL-0242">
      <data key="d1">condition</data>
      <data key="d5">provided that the certification body meets the requirements set out in this Article</data>
    </node>
    <node id="DL:OBL-0242">
      <data key="d1">deadline</data>
      <data key="d5">maximum period of five years</data>
    </node>
    <node id="OBL-0243">
      <data key="d1">obligation</data>
      <data key="d2">The certification bodies referred to in paragraph 1 shall provide the competent supervisory authorities with the
reasons for granting or withdrawing the requested certification.</data>
      <data key="d3">Article 42</data>
      <data key="d4">Provide the competent supervisory authorities with the reasons for granting or withdrawing the requested certification</data>
    </node>
    <node id="SUBJ:The certification bodies referred to in paragraph 1">
      <data key="d1">subject</data>
      <data key="d5">The certification bodies referred to in paragraph 1</data>
    </node>
    <node id="OBL-0244">
      <data key="d1">obligation</data>
      <data key="d2">The requirements referred to in paragraph 3 of this Article and the criteria referred to in Article 42(5) shall be
made public by the supervisory authority in an easily accessible form.</data>
      <data key="d3">Article 42</data>
      <data key="d4">make public the requirements referred to in paragraph 3 of this Article and the criteria referred to in Article 42(5)</data>
    </node>
    <node id="OBL-0245">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authorities shall also transmit
those requirements and criteria to the Board.</data>
      <data key="d3">Article 42</data>
      <data key="d4">transmit those requirements and criteria to the Board</data>
    </node>
    <node id="SUBJ:supervisory authorities">
      <data key="d1">subject</data>
      <data key="d5">supervisory authorities</data>
    </node>
    <node id="OBL-0246">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall collate all certification mechanisms and data protection
seals in a register and shall make them publicly available by any appropriate means.</data>
      <data key="d3">Article 42</data>
      <data key="d4">collate all certification mechanisms and data protection seals in a register and make them publicly available</data>
    </node>
    <node id="OBL-0247">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to Chapter VIII, the competent supervisory authority or the national accreditation body shall
revoke an accreditation of a certification body pursuant to paragraph 1 of this Article where the conditions for the
accreditation are not, or are no longer, met or where actions taken by a certification body infringe this Regulation.</data>
      <data key="d3">Article 42</data>
      <data key="d4">revoke an accreditation of a certification body</data>
    </node>
    <node id="SUBJ:competent supervisory authority or the national accreditation body">
      <data key="d1">subject</data>
      <data key="d5">competent supervisory authority or the national accreditation body</data>
    </node>
    <node id="COND:OBL-0247">
      <data key="d1">condition</data>
      <data key="d5">where the conditions for the accreditation are not, or are no longer, met or where actions taken by a certification body infringe this Regulation</data>
    </node>
    <node id="EXC:OBL-0247">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to Chapter VIII</data>
    </node>
    <node id="OBL-0248">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall be empowered to adopt delegated acts in accordance with Article 92 for the purpose of
specifying the requirements to be taken into account for the data protection certification mechanisms referred to in
Article 42(1).</data>
      <data key="d3">Article 42</data>
      <data key="d4">Adopt delegated acts</data>
    </node>
    <node id="COND:OBL-0248">
      <data key="d1">condition</data>
      <data key="d5">For the purpose of specifying the requirements for data protection certification mechanisms</data>
    </node>
    <node id="OBL-0249">
      <data key="d1">obligation</data>
      <data key="d2">Those implementing acts shall be adopted in accordance with the examination procedure referred to in
Article 93(2).</data>
      <data key="d3">Article 42</data>
      <data key="d4">Shall be adopted in accordance with the examination procedure</data>
    </node>
    <node id="SUBJ:Those implementing acts">
      <data key="d1">subject</data>
      <data key="d5">Those implementing acts</data>
    </node>
    <node id="COND:OBL-0249">
      <data key="d1">condition</data>
      <data key="d5">Referred to in Article 93(2)</data>
    </node>
    <node id="OBL-0250">
      <data key="d1">obligation</data>
      <data key="d2">CHAPTER V
Transfers of personal data to third countries or international organisations
Article 44
General principle for transfers
Any transfer of personal data which are undergoing processing or are intended for processing after transfer to a third
country or to an international organisation shall take place only if, subject to the other provisions of this Regulation, the
conditions laid down in this Chapter are complied with by the controller and processor, including for onward transfers
of personal data from the third country or an international organisation to another third country or to another internat­
ional organisation.</data>
      <data key="d3">Article 42</data>
      <data key="d4">Ensure conditions laid down in this Chapter are complied with for transfers of personal data</data>
    </node>
    <node id="SUBJ:controller and processor">
      <data key="d1">subject</data>
      <data key="d5">controller and processor</data>
    </node>
    <node id="COND:OBL-0250">
      <data key="d1">condition</data>
      <data key="d5">Transfer of personal data to a third country or international organisation</data>
    </node>
    <node id="EXC:OBL-0250">
      <data key="d1">exception</data>
      <data key="d5">Subject to the other provisions of this Regulation</data>
    </node>
    <node id="OBL-0251">
      <data key="d1">obligation</data>
      <data key="d2">All provisions in this Chapter shall be applied in order to ensure that the level of protection of
natural persons guaranteed by this Regulation is not undermined.</data>
      <data key="d3">Article 42</data>
      <data key="d4">Ensure that the level of protection of natural persons guaranteed by this Regulation is not undermined</data>
    </node>
    <node id="SUBJ:All provisions in this Chapter">
      <data key="d1">subject</data>
      <data key="d5">All provisions in this Chapter</data>
    </node>
    <node id="OBL-0252">
      <data key="d1">obligation</data>
      <data key="d2">Such a transfer shall not require any
specific authorisation.</data>
      <data key="d3">Article 45</data>
      <data key="d4">shall not require any specific authorisation</data>
    </node>
    <node id="COND:OBL-0252">
      <data key="d1">condition</data>
      <data key="d5">Such a transfer</data>
    </node>
    <node id="OBL-0253">
      <data key="d1">obligation</data>
      <data key="d2">When assessing the adequacy of the level of protection, the Commission shall, in particular, take account of the
following elements:
(a) the rule of law, respect for human rights and fundamental freedoms, relevant legislation, both general and sectoral,
including concerning public security, defence, national security and criminal law and the access of public authorities
to personal data, as well as the implementation of such legislation, data protection rules, professional rules and
security measures, including rules for the onward transfer of personal data to another third country or international
organisation which are complied with in that country or international organisation, case-law, as well as effective and
enforceable data subject rights and effective administrative and judicial redress for the data subjects whose personal
data are being transferred;</data>
      <data key="d3">Article 45</data>
      <data key="d4">Take account of the rule of law, respect for human rights and fundamental freedoms, relevant legislation, data protection rules, professional rules and security measures, case-law, effective and enforceable data subject rights, and effective administrative and judicial redress</data>
    </node>
    <node id="COND:OBL-0253">
      <data key="d1">condition</data>
      <data key="d5">When assessing the adequacy of the level of protection</data>
    </node>
    <node id="OBL-0254">
      <data key="d1">obligation</data>
      <data key="d2">The
implementing act shall provide for a mechanism for a periodic review, at least every four years, which shall take into
account all relevant developments in the third country or international organisation.</data>
      <data key="d3">Article 45</data>
      <data key="d4">provide for a mechanism for a periodic review</data>
    </node>
    <node id="SUBJ:implementing act">
      <data key="d1">subject</data>
      <data key="d5">implementing act</data>
    </node>
    <node id="COND:OBL-0254">
      <data key="d1">condition</data>
      <data key="d5">take into account all relevant developments in the third country or international organisation</data>
    </node>
    <node id="DL:OBL-0254">
      <data key="d1">deadline</data>
      <data key="d5">at least every four years</data>
    </node>
    <node id="OBL-0255">
      <data key="d1">obligation</data>
      <data key="d2">The implementing act shall specify
its territorial and sectoral application and, where applicable, identify the supervisory authority or authorities referred to
in point (b) of paragraph 2 of this Article.</data>
      <data key="d3">Article 45</data>
      <data key="d4">Specify its territorial and sectoral application and identify the supervisory authority or authorities</data>
    </node>
    <node id="SUBJ:The implementing act">
      <data key="d1">subject</data>
      <data key="d5">The implementing act</data>
    </node>
    <node id="COND:OBL-0255">
      <data key="d1">condition</data>
      <data key="d5">Where applicable</data>
    </node>
    <node id="OBL-0256">
      <data key="d1">obligation</data>
      <data key="d2">The implementing act shall be adopted in accordance with the examination
procedure referred to in Article 93(2).</data>
      <data key="d3">Article 45</data>
    </node>
    <node id="OBL-0257">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall, on an ongoing basis, monitor developments in third countries and international organ­
isations that could affect the functioning of decisions adopted pursuant to paragraph 3 of this Article and decisions
adopted on the basis of Article 25(6) of Directive 95/46/EC.</data>
      <data key="d3">Article 45</data>
      <data key="d4">monitor developments in third countries and international organisations</data>
    </node>
    <node id="COND:OBL-0257">
      <data key="d1">condition</data>
      <data key="d5">that could affect the functioning of decisions adopted pursuant to paragraph 3 of this Article and decisions adopted on the basis of Article 25(6) of Directive 95/46/EC</data>
    </node>
    <node id="DL:OBL-0257">
      <data key="d1">deadline</data>
      <data key="d5">on an ongoing basis</data>
    </node>
    <node id="OBL-0258">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall, where available information reveals, in particular following the review referred to in
paragraph 3 of this Article, that a third country, a territory or one or more specified sectors within a third country, or
an international organisation no longer ensures an adequate level of protection within the meaning of paragraph 2 of
this Article, to the extent necessary, repeal, amend or suspend the decision referred to in paragraph 3 of this Article by
means of implementing acts without retro-active effect.</data>
      <data key="d3">Article 45</data>
      <data key="d4">repeal, amend or suspend the decision referred to in paragraph 3 of this Article by means of implementing acts without retro-active effect</data>
    </node>
    <node id="COND:OBL-0258">
      <data key="d1">condition</data>
      <data key="d5">where available information reveals, in particular following the review referred to in paragraph 3 of this Article, that a third country, a territory or one or more specified sectors within a third country, or an international organisation no longer ensures an adequate level of protection within the meaning of paragraph 2 of this Article</data>
    </node>
    <node id="OBL-0259">
      <data key="d1">obligation</data>
      <data key="d2">Those implementing acts shall be adopted in accordance with
the examination procedure referred to in Article 93(2).</data>
      <data key="d3">Article 45</data>
      <data key="d4">Shall be adopted</data>
    </node>
    <node id="COND:OBL-0259">
      <data key="d1">condition</data>
      <data key="d5">In accordance with the examination procedure referred to in Article 93(2)</data>
    </node>
    <node id="OBL-0260">
      <data key="d1">obligation</data>
      <data key="d2">On duly justified imperative grounds of urgency, the Commission shall adopt immediately applicable implementing acts
in accordance with the procedure referred to in Article 93(3).</data>
      <data key="d3">Article 45</data>
      <data key="d4">Adopt immediately applicable implementing acts</data>
    </node>
    <node id="COND:OBL-0260">
      <data key="d1">condition</data>
      <data key="d5">On duly justified imperative grounds of urgency</data>
    </node>
    <node id="OBL-0261">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall enter into consultations with the third country or international organisation with a view to
remedying the situation giving rise to the decision made pursuant to paragraph 5.</data>
      <data key="d3">Article 45</data>
      <data key="d4">enter into consultations with the third country or international organisation</data>
    </node>
    <node id="COND:OBL-0261">
      <data key="d1">condition</data>
      <data key="d5">with a view to remedying the situation giving rise to the decision made pursuant to paragraph 5</data>
    </node>
    <node id="OBL-0262">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall publish in the Official Journal of the European Union and on its website a list of the third
countries, territories and specified sectors within a third country and international organisations for which it has decided
that an adequate level of protection is or is no longer ensured.</data>
      <data key="d3">Article 45</data>
      <data key="d4">publish a list of the third countries, territories and specified sectors within a third country and international organisations</data>
    </node>
    <node id="COND:OBL-0262">
      <data key="d1">condition</data>
      <data key="d5">for which it has decided that an adequate level of protection is or is no longer ensured</data>
    </node>
    <node id="OBL-0263">
      <data key="d1">obligation</data>
      <data key="d2">Decisions adopted by the Commission on the basis of Article 25(6) of Directive 95/46/EC shall remain in force
until amended, replaced or repealed by a Commission Decision adopted in accordance with paragraph 3 or 5 of this
Article.</data>
      <data key="d3">Article 46</data>
      <data key="d4">Shall remain in force</data>
    </node>
    <node id="SUBJ:Decisions adopted by the Commission">
      <data key="d1">subject</data>
      <data key="d5">Decisions adopted by the Commission</data>
    </node>
    <node id="COND:OBL-0263">
      <data key="d1">condition</data>
      <data key="d5">Until amended, replaced or repealed by a Commission Decision adopted in accordance with paragraph 3 or 5 of this Article</data>
    </node>
    <node id="OBL-0264">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authority shall apply the consistency mechanism referred to in Article 63 in the cases referred to
in paragraph 3 of this Article.</data>
      <data key="d3">Article 46</data>
      <data key="d4">apply the consistency mechanism referred to in Article 63</data>
    </node>
    <node id="COND:OBL-0264">
      <data key="d1">condition</data>
      <data key="d5">in the cases referred to in paragraph 3 of this Article</data>
    </node>
    <node id="OBL-0265">
      <data key="d1">obligation</data>
      <data key="d2">Authorisations by a Member State or supervisory authority on the basis of Article 26(2) of Directive 95/46/EC
shall remain valid until amended, replaced or repealed, if necessary, by that supervisory authority.</data>
      <data key="d3">Article 46</data>
      <data key="d4">Authorisations shall remain valid</data>
    </node>
    <node id="SUBJ:Member State or supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">Member State or supervisory authority</data>
    </node>
    <node id="COND:OBL-0265">
      <data key="d1">condition</data>
      <data key="d5">On the basis of Article 26(2) of Directive 95/46/EC</data>
    </node>
    <node id="DL:OBL-0265">
      <data key="d1">deadline</data>
      <data key="d5">Until amended, replaced or repealed</data>
    </node>
    <node id="OBL-0266">
      <data key="d1">obligation</data>
      <data key="d2">Decisions adopted by
the Commission on the basis of Article 26(4) of Directive 95/46/EC shall remain in force until amended, replaced or
repealed, if necessary, by a Commission Decision adopted in accordance with paragraph 2 of this Article.</data>
      <data key="d3">Article 46</data>
      <data key="d4">Shall remain in force</data>
    </node>
    <node id="COND:OBL-0266">
      <data key="d1">condition</data>
      <data key="d5">Until amended, replaced or repealed by a Commission Decision</data>
    </node>
    <node id="OBL-0267">
      <data key="d1">obligation</data>
      <data key="d2">The competent supervisory authority shall approve binding corporate rules in accordance with the consistency
mechanism set out in Article 63, provided that they:
(a) are legally binding and apply to and are enforced by every member concerned of the group of undertakings, or
group of enterprises engaged in a joint economic activity, including their employees;</data>
      <data key="d3">Article 46</data>
      <data key="d4">approve binding corporate rules</data>
    </node>
    <node id="COND:OBL-0267">
      <data key="d1">condition</data>
      <data key="d5">in accordance with the consistency mechanism set out in Article 63</data>
    </node>
    <node id="OBL-0268">
      <data key="d1">obligation</data>
      <data key="d2">The binding corporate rules referred to in paragraph 1 shall specify at least:
(a) the structure and contact details of the group of undertakings, or group of enterprises engaged in a joint economic
activity and of each of its members;</data>
      <data key="d3">Article 46</data>
      <data key="d4">Specify the structure and contact details of the group of undertakings or group of enterprises engaged in a joint economic activity and of each of its members</data>
    </node>
    <node id="SUBJ:The binding corporate rules">
      <data key="d1">subject</data>
      <data key="d5">The binding corporate rules</data>
    </node>
    <node id="COND:OBL-0268">
      <data key="d1">condition</data>
      <data key="d5">Referred to in paragraph 1</data>
    </node>
    <node id="OBL-0269">
      <data key="d1">obligation</data>
      <data key="d2">the controller or
the processor shall be exempt from that liability, in whole or in part, only if it proves that that member is not
responsible for the event giving rise to the damage;</data>
      <data key="d3">Article 46</data>
      <data key="d4">shall be exempt from that liability, in whole or in part</data>
    </node>
    <node id="COND:OBL-0269">
      <data key="d1">condition</data>
      <data key="d5">if it proves that that member is not responsible for the event giving rise to the damage</data>
    </node>
    <node id="OBL-0270">
      <data key="d1">obligation</data>
      <data key="d2">Such mechanisms shall include data
protection audits and methods for ensuring corrective actions to protect the rights of the data subject.</data>
      <data key="d3">Article 46</data>
      <data key="d4">Include data protection audits and methods for ensuring corrective actions</data>
    </node>
    <node id="COND:OBL-0270">
      <data key="d1">condition</data>
      <data key="d5">To protect the rights of the data subject</data>
    </node>
    <node id="OBL-0271">
      <data key="d1">obligation</data>
      <data key="d2">Those
implementing acts shall be adopted in accordance with the examination procedure set out in Article 93(2).</data>
      <data key="d3">Article 48</data>
      <data key="d4">Adopt implementing acts in accordance with the examination procedure</data>
    </node>
    <node id="COND:OBL-0271">
      <data key="d1">condition</data>
      <data key="d5">Set out in Article 93(2)</data>
    </node>
    <node id="OBL-0272">
      <data key="d1">obligation</data>
      <data key="d2">In the absence of an adequacy decision pursuant to Article 45(3), or of appropriate safeguards pursuant to
Article 46, including binding corporate rules, a transfer or a set of transfers of personal data to a third country or an in­
ternational organisation shall take place only on one of the following conditions:
(a) the data subject has explicitly consented to the proposed transfer, after having been informed of the possible risks of
such transfers for the data subject due to the absence of an adequacy decision and appropriate safeguards;</data>
      <data key="d3">Article 48</data>
      <data key="d4">Shall take place only on one of the following conditions</data>
    </node>
    <node id="SUBJ:A transfer or a set of transfers of personal data">
      <data key="d1">subject</data>
      <data key="d5">A transfer or a set of transfers of personal data</data>
    </node>
    <node id="COND:OBL-0272">
      <data key="d1">condition</data>
      <data key="d5">In the absence of an adequacy decision pursuant to Article 45(3), or of appropriate safeguards pursuant to Article 46, including binding corporate rules</data>
    </node>
    <node id="EXC:OBL-0272">
      <data key="d1">exception</data>
      <data key="d5">The data subject has explicitly consented to the proposed transfer, after having been informed of the possible risks of such transfers for the data subject due to the absence of an adequacy decision and appropriate safeguards</data>
    </node>
    <node id="OBL-0273">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall inform the
supervisory authority of the transfer.</data>
      <data key="d3">Article 48</data>
      <data key="d4">inform the supervisory authority of the transfer</data>
    </node>
    <node id="OBL-0274">
      <data key="d1">obligation</data>
      <data key="d2">The controller shall, in addition to providing the information referred to in
Articles 13 and 14, inform the data subject of the transfer and on the compelling legitimate interests pursued.</data>
      <data key="d3">Article 48</data>
      <data key="d4">inform the data subject of the transfer and on the compelling legitimate interests pursued</data>
    </node>
    <node id="COND:OBL-0274">
      <data key="d1">condition</data>
      <data key="d5">in addition to providing the information referred to in Articles 13 and 14</data>
    </node>
    <node id="OBL-0275">
      <data key="d1">obligation</data>
      <data key="d2">A transfer pursuant to point (g) of the first subparagraph of paragraph 1 shall not involve the entirety of the
personal data or entire categories of the personal data contained in the register.</data>
      <data key="d3">Article 48</data>
      <data key="d4">shall not involve the entirety of the personal data or entire categories of the personal data contained in the register</data>
    </node>
    <node id="SUBJ:A transfer pursuant to point (g) of the first subparagraph of paragraph 1">
      <data key="d1">subject</data>
      <data key="d5">A transfer pursuant to point (g) of the first subparagraph of paragraph 1</data>
    </node>
    <node id="OBL-0276">
      <data key="d1">obligation</data>
      <data key="d2">Where the register is intended for
consultation by persons having a legitimate interest, the transfer shall be made only at the request of those persons or if
they are to be the recipients.</data>
      <data key="d3">Article 48</data>
      <data key="d4">The transfer shall be made</data>
    </node>
    <node id="COND:OBL-0276">
      <data key="d1">condition</data>
      <data key="d5">Where the register is intended for consultation by persons having a legitimate interest</data>
    </node>
    <node id="EXC:OBL-0276">
      <data key="d1">exception</data>
      <data key="d5">Only at the request of those persons or if they are to be the recipients</data>
    </node>
    <node id="OBL-0277">
      <data key="d1">obligation</data>
      <data key="d2">Points (a), (b) and (c) of the first subparagraph of paragraph 1 and the second subparagraph thereof shall not apply
to activities carried out by public authorities in the exercise of their public powers.</data>
      <data key="d3">Article 50</data>
    </node>
    <node id="COND:OBL-0277">
      <data key="d1">condition</data>
      <data key="d5">activities carried out in the exercise of their public powers</data>
    </node>
    <node id="EXC:OBL-0277">
      <data key="d1">exception</data>
      <data key="d5">Points (a), (b) and (c) of the first subparagraph of paragraph 1 and the second subparagraph thereof</data>
    </node>
    <node id="OBL-0278">
      <data key="d1">obligation</data>
      <data key="d2">The public interest referred to in point (d) of the first subparagraph of paragraph 1 shall be recognised in Union
law or in the law of the Member State to which the controller is subject.</data>
      <data key="d3">Article 50</data>
    </node>
    <node id="OBL-0279">
      <data key="d1">obligation</data>
      <data key="d2">Member States shall notify such provisions to the Commission.</data>
      <data key="d3">Article 50</data>
      <data key="d4">notify such provisions to the Commission</data>
    </node>
    <node id="OBL-0280">
      <data key="d1">obligation</data>
      <data key="d2">The controller or processor shall document the assessment as well as the suitable safeguards referred to in the
second subparagraph of paragraph 1 of this Article in the records referred to in Article 30.</data>
      <data key="d3">Article 50</data>
      <data key="d4">document the assessment as well as the suitable safeguards</data>
    </node>
    <node id="COND:OBL-0280">
      <data key="d1">condition</data>
      <data key="d5">referred to in the second subparagraph of paragraph 1 of this Article</data>
    </node>
    <node id="OBL-0281">
      <data key="d1">obligation</data>
      <data key="d2">Article 50
International cooperation for the protection of personal data
In relation to third countries and international organisations, the Commission and supervisory authorities shall take
appropriate steps to:
(a) develop international cooperation mechanisms to facilitate the effective enforcement of legislation for the protection
of personal data;</data>
      <data key="d3">Article 50</data>
      <data key="d4">Develop international cooperation mechanisms to facilitate the effective enforcement of legislation for the protection of personal data</data>
    </node>
    <node id="SUBJ:The Commission and supervisory authorities">
      <data key="d1">subject</data>
      <data key="d5">The Commission and supervisory authorities</data>
    </node>
    <node id="COND:OBL-0281">
      <data key="d1">condition</data>
      <data key="d5">In relation to third countries and international organisations</data>
    </node>
    <node id="OBL-0282">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall provide for one or more independent public authorities to be responsible for monitoring
the application of this Regulation, in order to protect the fundamental rights and freedoms of natural persons in relation
to processing and to facilitate the free flow of personal data within the Union (‘supervisory authority’).</data>
      <data key="d3">Article 50</data>
      <data key="d4">Provide for one or more independent public authorities to be responsible for monitoring the application of this Regulation</data>
    </node>
    <node id="SUBJ:Each Member State">
      <data key="d1">subject</data>
      <data key="d5">Each Member State</data>
    </node>
    <node id="COND:OBL-0282">
      <data key="d1">condition</data>
      <data key="d5">In order to protect the fundamental rights and freedoms of natural persons in relation to processing and to facilitate the free flow of personal data within the Union</data>
    </node>
    <node id="OBL-0283">
      <data key="d1">obligation</data>
      <data key="d2">Each supervisory authority shall contribute to the consistent application of this Regulation throughout the Union.</data>
      <data key="d3">Article 50</data>
      <data key="d4">contribute to the consistent application of this Regulation</data>
    </node>
    <node id="COND:OBL-0283">
      <data key="d1">condition</data>
      <data key="d5">throughout the Union</data>
    </node>
    <node id="OBL-0284">
      <data key="d1">obligation</data>
      <data key="d2">For that purpose, the supervisory authorities shall cooperate with each other and the Commission in accordance with
Chapter VII.</data>
      <data key="d3">Article 50</data>
      <data key="d4">cooperate with each other and the Commission</data>
    </node>
    <node id="COND:OBL-0284">
      <data key="d1">condition</data>
      <data key="d5">For that purpose</data>
    </node>
    <node id="OBL-0285">
      <data key="d1">obligation</data>
      <data key="d2">Where more than one supervisory authority is established in a Member State, that Member State shall designate
the supervisory authority which is to represent those authorities in the Board and shall set out the mechanism to ensure
compliance by the other authorities with the rules relating to the consistency mechanism referred to in Article 63.</data>
      <data key="d3">Article 50</data>
      <data key="d4">Designate the supervisory authority to represent those authorities in the Board and set out the mechanism to ensure compliance by the other authorities with the rules relating to the consistency mechanism</data>
    </node>
    <node id="SUBJ:Member State">
      <data key="d1">subject</data>
      <data key="d5">Member State</data>
    </node>
    <node id="COND:OBL-0285">
      <data key="d1">condition</data>
      <data key="d5">Where more than one supervisory authority is established in a Member State</data>
    </node>
    <node id="OBL-0286">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall notify to the Commission the provisions of its law which it adopts pursuant to this
Chapter, by 25 May 2018 and, without delay, any subsequent amendment affecting them.</data>
      <data key="d3">Article 50</data>
      <data key="d4">Notify to the Commission the provisions of its law which it adopts pursuant to this Chapter</data>
    </node>
    <node id="DL:OBL-0286">
      <data key="d1">deadline</data>
      <data key="d5">By 25 May 2018 and, without delay, any subsequent amendment affecting them</data>
    </node>
    <node id="OBL-0287">
      <data key="d1">obligation</data>
      <data key="d2">Each supervisory authority shall act with complete independence in performing its tasks and exercising its powers
in accordance with this Regulation.</data>
      <data key="d3">Article 52</data>
      <data key="d4">act with complete independence in performing its tasks and exercising its powers</data>
    </node>
    <node id="COND:OBL-0287">
      <data key="d1">condition</data>
      <data key="d5">in accordance with this Regulation</data>
    </node>
    <node id="OBL-0288">
      <data key="d1">obligation</data>
      <data key="d2">The member or members of each supervisory authority shall, in the performance of their tasks and exercise of
their powers in accordance with this Regulation, remain free from external influence, whether direct or indirect, and
shall neither seek nor take instructions from anybody.</data>
      <data key="d3">Article 52</data>
      <data key="d4">Remain free from external influence and shall neither seek nor take instructions from anybody</data>
    </node>
    <node id="SUBJ:The member or members of each supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">The member or members of each supervisory authority</data>
    </node>
    <node id="COND:OBL-0288">
      <data key="d1">condition</data>
      <data key="d5">In the performance of their tasks and exercise of their powers in accordance with this Regulation</data>
    </node>
    <node id="OBL-0289">
      <data key="d1">obligation</data>
      <data key="d2">Member or members of each supervisory authority shall refrain from any action incompatible with their duties
and shall not, during their term of office, engage in any incompatible occupation, whether gainful or not.</data>
      <data key="d3">Article 52</data>
      <data key="d4">Refrain from any action incompatible with their duties and shall not engage in any incompatible occupation</data>
    </node>
    <node id="SUBJ:Member or members of each supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">Member or members of each supervisory authority</data>
    </node>
    <node id="COND:OBL-0289">
      <data key="d1">condition</data>
      <data key="d5">During their term of office</data>
    </node>
    <node id="OBL-0290">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall ensure that each supervisory authority is provided with the human, technical and
financial resources, premises and infrastructure necessary for the effective performance of its tasks and exercise of its
powers, including those to be carried out in the context of mutual assistance, cooperation and participation in the
Board.</data>
      <data key="d3">Article 52</data>
      <data key="d4">Ensure that each supervisory authority is provided with the human, technical and financial resources, premises and infrastructure necessary for the effective performance of its tasks and exercise of its powers</data>
    </node>
    <node id="COND:OBL-0290">
      <data key="d1">condition</data>
      <data key="d5">Including those to be carried out in the context of mutual assistance, cooperation and participation in the Board</data>
    </node>
    <node id="OBL-0291">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall ensure that each supervisory authority chooses and has its own staff which shall be
subject to the exclusive direction of the member or members of the supervisory authority concerned.</data>
      <data key="d3">Article 52</data>
      <data key="d4">Ensure that each supervisory authority chooses and has its own staff</data>
    </node>
    <node id="COND:OBL-0291">
      <data key="d1">condition</data>
      <data key="d5">Subject to the exclusive direction of the member or members of the supervisory authority concerned</data>
    </node>
    <node id="OBL-0292">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall ensure that each supervisory authority is subject to financial control which does not
affect its independence and that it has separate, public annual budgets, which may be part of the overall state or national
budget.</data>
      <data key="d3">Article 52</data>
      <data key="d4">Ensure that each supervisory authority is subject to financial control which does not affect its independence and that it has separate, public annual budgets</data>
    </node>
    <node id="EXC:OBL-0292">
      <data key="d1">exception</data>
      <data key="d5">which may be part of the overall state or national budget</data>
    </node>
    <node id="OBL-0293">
      <data key="d1">obligation</data>
      <data key="d2">Member States shall provide for each member of their supervisory authorities to be appointed by means of a
transparent procedure by:
— their parliament;</data>
      <data key="d3">Article 52</data>
      <data key="d4">Provide for each member of their supervisory authorities to be appointed by means of a transparent procedure</data>
    </node>
    <node id="OBL-0294">
      <data key="d1">obligation</data>
      <data key="d2">Each member shall have the qualifications, experience and skills, in particular in the area of the protection of
personal data, required to perform its duties and exercise its powers.</data>
      <data key="d3">Article 52</data>
      <data key="d4">Have the qualifications, experience and skills required to perform its duties and exercise its powers</data>
    </node>
    <node id="SUBJ:Each member">
      <data key="d1">subject</data>
      <data key="d5">Each member</data>
    </node>
    <node id="COND:OBL-0294">
      <data key="d1">condition</data>
      <data key="d5">In the area of the protection of personal data</data>
    </node>
    <node id="OBL-0295">
      <data key="d1">obligation</data>
      <data key="d2">The duties of a member shall end in the event of the expiry of the term of office, resignation or compulsory
retirement, in accordance with the law of the Member State concerned.</data>
      <data key="d3">Article 52</data>
      <data key="d4">end duties</data>
    </node>
    <node id="SUBJ:member">
      <data key="d1">subject</data>
      <data key="d5">member</data>
    </node>
    <node id="COND:OBL-0295">
      <data key="d1">condition</data>
      <data key="d5">expiry of the term of office, resignation or compulsory retirement</data>
    </node>
    <node id="EXC:OBL-0295">
      <data key="d1">exception</data>
      <data key="d5">in accordance with the law of the Member State concerned</data>
    </node>
    <node id="OBL-0296">
      <data key="d1">obligation</data>
      <data key="d2">A member shall be dismissed only in cases of serious misconduct or if the member no longer fulfils the conditions
required for the performance of the duties.</data>
      <data key="d3">Article 52</data>
      <data key="d4">shall be dismissed</data>
    </node>
    <node id="COND:OBL-0296">
      <data key="d1">condition</data>
      <data key="d5">in cases of serious misconduct or if the member no longer fulfils the conditions required for the performance of the duties</data>
    </node>
    <node id="OBL-0297">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall provide by law for all of the following:
(a) the establishment of each supervisory authority;</data>
      <data key="d3">Article 52</data>
      <data key="d4">Provide by law for the establishment of each supervisory authority</data>
    </node>
    <node id="OBL-0298">
      <data key="d1">obligation</data>
      <data key="d2">The member or members and the staff of each supervisory authority shall, in accordance with Union or Member
State law, be subject to a duty of professional secrecy both during and after their term of office, with regard to any
confidential information which has come to their knowledge in the course of the performance of their tasks or exercise
of their powers.</data>
      <data key="d3">Section 2</data>
      <data key="d4">Be subject to a duty of professional secrecy</data>
    </node>
    <node id="SUBJ:The member or members and the staff of each supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">The member or members and the staff of each supervisory authority</data>
    </node>
    <node id="COND:OBL-0298">
      <data key="d1">condition</data>
      <data key="d5">In accordance with Union or Member State law, with regard to any confidential information which has come to their knowledge in the course of the performance of their tasks or exercise of their powers</data>
    </node>
    <node id="DL:OBL-0298">
      <data key="d1">deadline</data>
      <data key="d5">Both during and after their term of office</data>
    </node>
    <node id="OBL-0299">
      <data key="d1">obligation</data>
      <data key="d2">During their term of office, that duty of professional secrecy shall in particular apply to reporting by
natural persons of infringements of this Regulation.</data>
      <data key="d3">Section 2</data>
      <data key="d4">duty of professional secrecy</data>
    </node>
    <node id="SUBJ:natural persons">
      <data key="d1">subject</data>
      <data key="d5">natural persons</data>
    </node>
    <node id="COND:OBL-0299">
      <data key="d1">condition</data>
      <data key="d5">during their term of office</data>
    </node>
    <node id="OBL-0300">
      <data key="d1">obligation</data>
      <data key="d2">Each supervisory authority shall be competent for the performance of the tasks assigned to and the exercise of the
powers conferred on it in accordance with this Regulation on the territory of its own Member State.</data>
      <data key="d3">Section 2</data>
      <data key="d4">be competent for the performance of the tasks assigned and the exercise of the powers conferred</data>
    </node>
    <node id="COND:OBL-0300">
      <data key="d1">condition</data>
      <data key="d5">in accordance with this Regulation on the territory of its own Member State</data>
    </node>
    <node id="OBL-0301">
      <data key="d1">obligation</data>
      <data key="d2">Where processing is carried out by public authorities or private bodies acting on the basis of point (c) or (e) of
Article 6(1), the supervisory authority of the Member State concerned shall be competent.</data>
      <data key="d3">Section 2</data>
      <data key="d4">shall be competent</data>
    </node>
    <node id="SUBJ:supervisory authority of the Member State concerned">
      <data key="d1">subject</data>
      <data key="d5">supervisory authority of the Member State concerned</data>
    </node>
    <node id="COND:OBL-0301">
      <data key="d1">condition</data>
      <data key="d5">processing is carried out by public authorities or private bodies acting on the basis of point (c) or (e) of Article 6(1)</data>
    </node>
    <node id="OBL-0302">
      <data key="d1">obligation</data>
      <data key="d2">Supervisory authorities shall not be competent to supervise processing operations of courts acting in their judicial
capacity.</data>
      <data key="d3">Section 2</data>
      <data key="d4">shall not be competent to supervise processing operations</data>
    </node>
    <node id="SUBJ:Supervisory authorities">
      <data key="d1">subject</data>
      <data key="d5">Supervisory authorities</data>
    </node>
    <node id="COND:OBL-0302">
      <data key="d1">condition</data>
      <data key="d5">of courts acting in their judicial capacity</data>
    </node>
    <node id="OBL-0303">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to Article 55, the supervisory authority of the main establishment or of the single establishment
of the controller or processor shall be competent to act as lead supervisory authority for the cross-border processing
carried out by that controller or processor in accordance with the procedure provided in Article 60.</data>
      <data key="d3">Section 2</data>
      <data key="d4">act as lead supervisory authority for the cross-border processing</data>
    </node>
    <node id="SUBJ:supervisory authority of the main establishment or of the single establishment of the controller or processor">
      <data key="d1">subject</data>
      <data key="d5">supervisory authority of the main establishment or of the single establishment of the controller or processor</data>
    </node>
    <node id="COND:OBL-0303">
      <data key="d1">condition</data>
      <data key="d5">in accordance with the procedure provided in Article 60</data>
    </node>
    <node id="EXC:OBL-0303">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to Article 55</data>
    </node>
    <node id="OBL-0304">
      <data key="d1">obligation</data>
      <data key="d2">By derogation from paragraph 1, each supervisory authority shall be competent to handle a complaint lodged with
it or a possible infringement of this Regulation, if the subject matter relates only to an establishment in its Member State
or substantially affects data subjects only in its Member State.</data>
      <data key="d3">Section 2</data>
      <data key="d4">handle a complaint lodged with it or a possible infringement of this Regulation</data>
    </node>
    <node id="COND:OBL-0304">
      <data key="d1">condition</data>
      <data key="d5">if the subject matter relates only to an establishment in its Member State or substantially affects data subjects only in its Member State</data>
    </node>
    <node id="EXC:OBL-0304">
      <data key="d1">exception</data>
      <data key="d5">By derogation from paragraph 1</data>
    </node>
    <node id="OBL-0305">
      <data key="d1">obligation</data>
      <data key="d2">In the cases referred to in paragraph 2 of this Article, the supervisory authority shall inform the lead supervisory
authority without delay on that matter.</data>
      <data key="d3">Section 2</data>
      <data key="d4">inform the lead supervisory authority on that matter</data>
    </node>
    <node id="COND:OBL-0305">
      <data key="d1">condition</data>
      <data key="d5">In the cases referred to in paragraph 2 of this Article</data>
    </node>
    <node id="DL:OBL-0305">
      <data key="d1">deadline</data>
      <data key="d5">without delay</data>
    </node>
    <node id="OBL-0306">
      <data key="d1">obligation</data>
      <data key="d2">Within a period of three weeks after being informed the lead supervisory
authority shall decide whether or not it will handle the case in accordance with the procedure provided in Article 60,
taking into account whether or not there is an establishment of the controller or processor in the Member State of
which the supervisory authority informed it.</data>
      <data key="d3">Section 2</data>
      <data key="d4">decide whether or not it will handle the case in accordance with the procedure provided in Article 60</data>
    </node>
    <node id="SUBJ:lead supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">lead supervisory authority</data>
    </node>
    <node id="COND:OBL-0306">
      <data key="d1">condition</data>
      <data key="d5">after being informed</data>
    </node>
    <node id="DL:OBL-0306">
      <data key="d1">deadline</data>
      <data key="d5">within a period of three weeks</data>
    </node>
    <node id="OBL-0307">
      <data key="d1">obligation</data>
      <data key="d2">Where the lead supervisory authority decides to handle the case, the procedure provided in Article 60 shall apply.</data>
      <data key="d3">Article 57</data>
      <data key="d4">handle the case</data>
    </node>
    <node id="COND:OBL-0307">
      <data key="d1">condition</data>
      <data key="d5">Where the lead supervisory authority decides to handle the case</data>
    </node>
    <node id="OBL-0308">
      <data key="d1">obligation</data>
      <data key="d2">The lead supervisory authority shall take utmost account of that draft when preparing the draft
decision referred to in Article 60(3).</data>
      <data key="d3">Article 57</data>
      <data key="d4">Take utmost account of that draft when preparing the draft decision</data>
    </node>
    <node id="SUBJ:The lead supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">The lead supervisory authority</data>
    </node>
    <node id="COND:OBL-0308">
      <data key="d1">condition</data>
      <data key="d5">Referred to in Article 60(3)</data>
    </node>
    <node id="OBL-0309">
      <data key="d1">obligation</data>
      <data key="d2">Where the lead supervisory authority decides not to handle the case, the supervisory authority which informed the
lead supervisory authority shall handle it according to Articles 61 and 62.</data>
      <data key="d3">Article 57</data>
      <data key="d4">Shall handle the case according to Articles 61 and 62</data>
    </node>
    <node id="SUBJ:The supervisory authority which informed the lead supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">The supervisory authority which informed the lead supervisory authority</data>
    </node>
    <node id="COND:OBL-0309">
      <data key="d1">condition</data>
      <data key="d5">Where the lead supervisory authority decides not to handle the case</data>
    </node>
    <node id="OBL-0310">
      <data key="d1">obligation</data>
      <data key="d2">The lead supervisory authority shall be the sole interlocutor of the controller or processor for the cross-border
processing carried out by that controller or processor.</data>
      <data key="d3">Article 57</data>
      <data key="d4">be the sole interlocutor of the controller or processor</data>
    </node>
    <node id="COND:OBL-0310">
      <data key="d1">condition</data>
      <data key="d5">for the cross-border processing carried out by that controller or processor</data>
    </node>
    <node id="OBL-0311">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to other tasks set out under this Regulation, each supervisory authority shall on its territory:
(a) monitor and enforce the application of this Regulation;</data>
      <data key="d3">Article 57</data>
      <data key="d4">monitor and enforce the application of this Regulation</data>
    </node>
    <node id="COND:OBL-0311">
      <data key="d1">condition</data>
      <data key="d5">on its territory</data>
    </node>
    <node id="OBL-0312">
      <data key="d1">obligation</data>
      <data key="d2">Activities addressed specifically to children shall receive specific attention;</data>
      <data key="d3">Article 57</data>
      <data key="d4">shall receive specific attention</data>
    </node>
    <node id="SUBJ:Activities addressed specifically to children">
      <data key="d1">subject</data>
      <data key="d5">Activities addressed specifically to children</data>
    </node>
    <node id="OBL-0313">
      <data key="d1">obligation</data>
      <data key="d2">Each supervisory authority shall facilitate the submission of complaints referred to in point (f) of paragraph 1 by
measures such as a complaint submission form which can also be completed electronically, without excluding other
means of communication.</data>
      <data key="d3">Article 58</data>
      <data key="d4">facilitate the submission of complaints</data>
    </node>
    <node id="COND:OBL-0313">
      <data key="d1">condition</data>
      <data key="d5">referred to in point (f) of paragraph 1</data>
    </node>
    <node id="EXC:OBL-0313">
      <data key="d1">exception</data>
      <data key="d5">without excluding other means of communication</data>
    </node>
    <node id="OBL-0314">
      <data key="d1">obligation</data>
      <data key="d2">The performance of the tasks of each supervisory authority shall be free of charge for the data subject and, where
applicable, for the data protection officer.</data>
      <data key="d3">Article 58</data>
      <data key="d4">Perform tasks free of charge</data>
    </node>
    <node id="COND:OBL-0314">
      <data key="d1">condition</data>
      <data key="d5">For the data subject and, where applicable, for the data protection officer</data>
    </node>
    <node id="OBL-0315">
      <data key="d1">obligation</data>
      <data key="d2">The
supervisory authority shall bear the burden of demonstrating the manifestly unfounded or excessive character of the
request.</data>
      <data key="d3">Article 58</data>
      <data key="d4">bear the burden of demonstrating the manifestly unfounded or excessive character of the request</data>
    </node>
    <node id="OBL-0316">
      <data key="d1">obligation</data>
      <data key="d2">Each supervisory authority shall have all of the following investigative powers:
(a) to order the controller and the processor, and, where applicable, the controller's or the processor's representative to
provide any information it requires for the performance of its tasks;</data>
      <data key="d3">Article 58</data>
      <data key="d4">order the controller and the processor, and, where applicable, the controller's or the processor's representative to provide any information it requires for the performance of its tasks</data>
    </node>
    <node id="OBL-0317">
      <data key="d1">obligation</data>
      <data key="d2">Each supervisory authority shall have all of the following corrective powers:
(a) to issue warnings to a controller or processor that intended processing operations are likely to infringe provisions of
this Regulation;</data>
      <data key="d3">Article 58</data>
      <data key="d4">issue warnings to a controller or processor</data>
    </node>
    <node id="COND:OBL-0317">
      <data key="d1">condition</data>
      <data key="d5">intended processing operations are likely to infringe provisions of this Regulation</data>
    </node>
    <node id="OBL-0318">
      <data key="d1">obligation</data>
      <data key="d2">Each supervisory authority shall have all of the following authorisation and advisory powers:
(a) to advise the controller in accordance with the prior consultation procedure referred to in Article 36;</data>
      <data key="d3">Article 17</data>
      <data key="d4">advise the controller</data>
    </node>
    <node id="COND:OBL-0318">
      <data key="d1">condition</data>
      <data key="d5">in accordance with the prior consultation procedure referred to in Article 36</data>
    </node>
    <node id="OBL-0319">
      <data key="d1">obligation</data>
      <data key="d2">The exercise of the powers conferred on the supervisory authority pursuant to this Article shall be subject to
appropriate safeguards, including effective judicial remedy and due process, set out in Union and Member State law in
accordance with the Charter.</data>
      <data key="d3">Article 17</data>
      <data key="d4">Exercise powers with appropriate safeguards</data>
    </node>
    <node id="COND:OBL-0319">
      <data key="d1">condition</data>
      <data key="d5">Pursuant to this Article</data>
    </node>
    <node id="OBL-0320">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall provide by law that its supervisory authority shall have the power to bring infringements
of this Regulation to the attention of the judicial authorities and where appropriate, to commence or engage otherwise
in legal proceedings, in order to enforce the provisions of this Regulation.</data>
      <data key="d3">Article 17</data>
      <data key="d4">Provide by law that its supervisory authority shall have the power to bring infringements of this Regulation to the attention of the judicial authorities and where appropriate, to commence or engage otherwise in legal proceedings</data>
    </node>
    <node id="COND:OBL-0320">
      <data key="d1">condition</data>
      <data key="d5">In order to enforce the provisions of this Regulation</data>
    </node>
    <node id="OBL-0321">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State may provide by law that its supervisory authority shall have additional powers to those
referred to in paragraphs 1, 2 and 3.</data>
      <data key="d3">Article 17</data>
      <data key="d4">Provide by law that its supervisory authority shall have additional powers</data>
    </node>
    <node id="COND:OBL-0321">
      <data key="d1">condition</data>
      <data key="d5">To those referred to in paragraphs 1, 2 and 3</data>
    </node>
    <node id="OBL-0322">
      <data key="d1">obligation</data>
      <data key="d2">The exercise of those powers shall not impair the effective operation of
Chapter VII.</data>
      <data key="d3">Article 17</data>
      <data key="d4">shall not impair the effective operation of Chapter VII</data>
    </node>
    <node id="COND:OBL-0322">
      <data key="d1">condition</data>
      <data key="d5">The exercise of those powers</data>
    </node>
    <node id="OBL-0323">
      <data key="d1">obligation</data>
      <data key="d2">Article 59
Activity reports
Each supervisory authority shall draw up an annual report on its activities, which may include a list of types of
infringement notified and types of measures taken in accordance with Article 58(2).</data>
      <data key="d3">Article 17</data>
      <data key="d4">Draw up an annual report on its activities</data>
    </node>
    <node id="SUBJ:Each supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">Each supervisory authority</data>
    </node>
    <node id="DL:OBL-0323">
      <data key="d1">deadline</data>
      <data key="d5">Annually</data>
    </node>
    <node id="OBL-0324">
      <data key="d1">obligation</data>
      <data key="d2">Those reports shall be transmitted
to the national parliament, the government and other authorities as designated by Member State law.</data>
      <data key="d3">Article 17</data>
      <data key="d4">shall be transmitted to the national parliament, the government and other authorities</data>
    </node>
    <node id="SUBJ:Those reports">
      <data key="d1">subject</data>
      <data key="d5">Those reports</data>
    </node>
    <node id="COND:OBL-0324">
      <data key="d1">condition</data>
      <data key="d5">as designated by Member State law</data>
    </node>
    <node id="OBL-0325">
      <data key="d1">obligation</data>
      <data key="d2">They shall be made
available to the public, to the Commission and to the Board.</data>
      <data key="d3">Article 17</data>
      <data key="d4">Make available to the public, to the Commission and to the Board</data>
    </node>
    <node id="OBL-0326">
      <data key="d1">obligation</data>
      <data key="d2">The lead supervisory authority shall cooperate with the other supervisory authorities concerned in accordance
with this Article in an endeavour to reach consensus.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">cooperate with the other supervisory authorities concerned</data>
    </node>
    <node id="COND:OBL-0326">
      <data key="d1">condition</data>
      <data key="d5">in accordance with this Article</data>
    </node>
    <node id="OBL-0327">
      <data key="d1">obligation</data>
      <data key="d2">The lead supervisory authority and the supervisory authorities
concerned shall exchange all relevant information with each other.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">shall exchange all relevant information with each other</data>
    </node>
    <node id="SUBJ:The lead supervisory authority and the supervisory authorities concerned">
      <data key="d1">subject</data>
      <data key="d5">The lead supervisory authority and the supervisory authorities concerned</data>
    </node>
    <node id="OBL-0328">
      <data key="d1">obligation</data>
      <data key="d2">The lead supervisory authority shall, without delay, communicate the relevant information on the matter to the
other supervisory authorities concerned.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">communicate the relevant information on the matter to the other supervisory authorities concerned</data>
    </node>
    <node id="DL:OBL-0328">
      <data key="d1">deadline</data>
      <data key="d5">without delay</data>
    </node>
    <node id="OBL-0329">
      <data key="d1">obligation</data>
      <data key="d2">It shall without delay submit a draft decision to the other supervisory
authorities concerned for their opinion and take due account of their views.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">Submit a draft decision to the other supervisory authorities concerned for their opinion and take due account of their views</data>
    </node>
    <node id="DL:OBL-0329">
      <data key="d1">deadline</data>
      <data key="d5">Without delay</data>
    </node>
    <node id="OBL-0330">
      <data key="d1">obligation</data>
      <data key="d2">Where any of the other supervisory authorities concerned within a period of four weeks after having been
consulted in accordance with paragraph 3 of this Article, expresses a relevant and reasoned objection to the draft
decision, the lead supervisory authority shall, if it does not follow the relevant and reasoned objection or is of the
opinion that the objection is not relevant or reasoned, submit the matter to the consistency mechanism referred to in
Article 63.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">submit the matter to the consistency mechanism referred to in Article 63</data>
    </node>
    <node id="COND:OBL-0330">
      <data key="d1">condition</data>
      <data key="d5">if it does not follow the relevant and reasoned objection or is of the opinion that the objection is not relevant or reasoned</data>
    </node>
    <node id="DL:OBL-0330">
      <data key="d1">deadline</data>
      <data key="d5">within a period of four weeks after having been consulted</data>
    </node>
    <node id="OBL-0331">
      <data key="d1">obligation</data>
      <data key="d2">Where the lead supervisory authority intends to follow the relevant and reasoned objection made, it shall submit
to the other supervisory authorities concerned a revised draft decision for their opinion.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">Submit a revised draft decision for opinion</data>
    </node>
    <node id="COND:OBL-0331">
      <data key="d1">condition</data>
      <data key="d5">Intends to follow the relevant and reasoned objection made</data>
    </node>
    <node id="OBL-0332">
      <data key="d1">obligation</data>
      <data key="d2">That revised draft decision shall
be subject to the procedure referred to in paragraph 4 within a period of two weeks.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">Be subject to the procedure referred to in paragraph 4</data>
    </node>
    <node id="DL:OBL-0332">
      <data key="d1">deadline</data>
      <data key="d5">Within a period of two weeks</data>
    </node>
    <node id="OBL-0333">
      <data key="d1">obligation</data>
      <data key="d2">Where none of the other supervisory authorities concerned has objected to the draft decision submitted by the
lead supervisory authority within the period referred to in paragraphs 4 and 5, the lead supervisory authority and the
supervisory authorities concerned shall be deemed to be in agreement with that draft decision and shall be bound by it.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">shall be deemed to be in agreement with the draft decision and shall be bound by it</data>
    </node>
    <node id="SUBJ:lead supervisory authority and the supervisory authorities concerned">
      <data key="d1">subject</data>
      <data key="d5">lead supervisory authority and the supervisory authorities concerned</data>
    </node>
    <node id="COND:OBL-0333">
      <data key="d1">condition</data>
      <data key="d5">none of the other supervisory authorities concerned has objected to the draft decision within the period referred to in paragraphs 4 and 5</data>
    </node>
    <node id="OBL-0334">
      <data key="d1">obligation</data>
      <data key="d2">The lead supervisory authority shall adopt and notify the decision to the main establishment or single
establishment of the controller or processor, as the case may be and inform the other supervisory authorities concerned
and the Board of the decision in question, including a summary of the relevant facts and grounds.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">Adopt and notify the decision to the main establishment or single establishment of the controller or processor and inform the other supervisory authorities concerned and the Board of the decision, including a summary of the relevant facts and grounds</data>
    </node>
    <node id="OBL-0335">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory
authority with which a complaint has been lodged shall inform the complainant on the decision.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">Inform the complainant on the decision</data>
    </node>
    <node id="COND:OBL-0335">
      <data key="d1">condition</data>
      <data key="d5">A complaint has been lodged</data>
    </node>
    <node id="OBL-0336">
      <data key="d1">obligation</data>
      <data key="d2">By derogation from paragraph 7, where a complaint is dismissed or rejected, the supervisory authority with which
the complaint was lodged shall adopt the decision and notify it to the complainant and shall inform the controller
thereof.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">adopt the decision and notify it to the complainant and inform the controller</data>
    </node>
    <node id="COND:OBL-0336">
      <data key="d1">condition</data>
      <data key="d5">where a complaint is dismissed or rejected</data>
    </node>
    <node id="EXC:OBL-0336">
      <data key="d1">exception</data>
      <data key="d5">By derogation from paragraph 7</data>
    </node>
    <node id="OBL-0337">
      <data key="d1">obligation</data>
      <data key="d2">Where the lead supervisory authority and the supervisory authorities concerned agree to dismiss or reject parts of
a complaint and to act on other parts of that complaint, a separate decision shall be adopted for each of those parts of
the matter.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">adopt a separate decision for each of those parts of the matter</data>
    </node>
    <node id="COND:OBL-0337">
      <data key="d1">condition</data>
      <data key="d5">agree to dismiss or reject parts of a complaint and to act on other parts of that complaint</data>
    </node>
    <node id="OBL-0338">
      <data key="d1">obligation</data>
      <data key="d2">The lead supervisory authority shall adopt the decision for the part concerning actions in relation to the
controller, shall notify it to the main establishment or single establishment of the controller or processor on the territory
of its Member State and shall inform the complainant thereof, while the supervisory authority of the complainant shall
adopt the decision for the part concerning dismissal or rejection of that complaint, and shall notify it to that
complainant and shall inform the controller or processor thereof.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">Adopt the decision for the part concerning actions in relation to the controller, notify it to the main establishment or single establishment of the controller or processor on the territory of its Member State, and inform the complainant thereof</data>
    </node>
    <node id="OBL-0339">
      <data key="d1">obligation</data>
      <data key="d2">After being notified of the decision of the lead supervisory authority pursuant to paragraphs 7 and 9, the
controller or processor shall take the necessary measures to ensure compliance with the decision as regards processing
activities in the context of all its establishments in the Union.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">take the necessary measures to ensure compliance with the decision</data>
    </node>
    <node id="COND:OBL-0339">
      <data key="d1">condition</data>
      <data key="d5">After being notified of the decision of the lead supervisory authority pursuant to paragraphs 7 and 9</data>
    </node>
    <node id="OBL-0340">
      <data key="d1">obligation</data>
      <data key="d2">The controller or processor shall notify the measures
taken for complying with the decision to the lead supervisory authority, which shall inform the other supervisory
authorities concerned.</data>
      <data key="d3">CHAPTER VII</data>
      <data key="d4">notify the measures taken for complying with the decision to the lead supervisory authority</data>
    </node>
    <node id="OBL-0341">
      <data key="d1">obligation</data>
      <data key="d2">Where, in exceptional circumstances, a supervisory authority concerned has reasons to consider that there is an
urgent need to act in order to protect the interests of data subjects, the urgency procedure referred to in Article 66 shall
apply.</data>
      <data key="d3">Article 61</data>
      <data key="d4">apply the urgency procedure referred to in Article 66</data>
    </node>
    <node id="COND:OBL-0341">
      <data key="d1">condition</data>
      <data key="d5">in exceptional circumstances, has reasons to consider that there is an urgent need to act in order to protect the interests of data subjects</data>
    </node>
    <node id="OBL-0342">
      <data key="d1">obligation</data>
      <data key="d2">The lead supervisory authority and the other supervisory authorities concerned shall supply the information
required under this Article to each other by electronic means, using a standardised format.</data>
      <data key="d3">Article 61</data>
      <data key="d4">shall supply the information required under this Article to each other by electronic means, using a standardised format</data>
    </node>
    <node id="SUBJ:The lead supervisory authority and the other supervisory authorities concerned">
      <data key="d1">subject</data>
      <data key="d5">The lead supervisory authority and the other supervisory authorities concerned</data>
    </node>
    <node id="OBL-0343">
      <data key="d1">obligation</data>
      <data key="d2">Supervisory authorities shall provide each other with relevant information and mutual assistance in order to
implement and apply this Regulation in a consistent manner, and shall put in place measures for effective cooperation
with one another.</data>
      <data key="d3">Article 61</data>
      <data key="d4">Provide each other with relevant information and mutual assistance and put in place measures for effective cooperation</data>
    </node>
    <node id="COND:OBL-0343">
      <data key="d1">condition</data>
      <data key="d5">In order to implement and apply this Regulation in a consistent manner</data>
    </node>
    <node id="OBL-0344">
      <data key="d1">obligation</data>
      <data key="d2">Mutual assistance shall cover, in particular, information requests and supervisory measures, such as
requests to carry out prior authorisations and consultations, inspections and investigations.</data>
      <data key="d3">Article 61</data>
      <data key="d4">Cover information requests and supervisory measures</data>
    </node>
    <node id="SUBJ:Mutual assistance">
      <data key="d1">subject</data>
      <data key="d5">Mutual assistance</data>
    </node>
    <node id="COND:OBL-0344">
      <data key="d1">condition</data>
      <data key="d5">In particular, such as requests to carry out prior authorisations and consultations, inspections and investigations</data>
    </node>
    <node id="OBL-0345">
      <data key="d1">obligation</data>
      <data key="d2">Each supervisory authority shall take all appropriate measures required to reply to a request of another supervisory
authority without undue delay and no later than one month after receiving the request.</data>
      <data key="d3">Article 61</data>
      <data key="d4">Take all appropriate measures required to reply to a request of another supervisory authority</data>
    </node>
    <node id="COND:OBL-0345">
      <data key="d1">condition</data>
      <data key="d5">Upon receiving a request from another supervisory authority</data>
    </node>
    <node id="DL:OBL-0345">
      <data key="d1">deadline</data>
      <data key="d5">Without undue delay and no later than one month after receiving the request</data>
    </node>
    <node id="OBL-0346">
      <data key="d1">obligation</data>
      <data key="d2">Requests for assistance shall contain all the necessary information, including the purpose of and reasons for the
request.</data>
      <data key="d3">Article 61</data>
      <data key="d4">Contain all the necessary information, including the purpose of and reasons for the request</data>
    </node>
    <node id="SUBJ:Requests for assistance">
      <data key="d1">subject</data>
      <data key="d5">Requests for assistance</data>
    </node>
    <node id="OBL-0347">
      <data key="d1">obligation</data>
      <data key="d2">Information exchanged shall be used only for the purpose for which it was requested.</data>
      <data key="d3">Article 61</data>
      <data key="d4">shall be used only for the purpose for which it was requested</data>
    </node>
    <node id="SUBJ:Information exchanged">
      <data key="d1">subject</data>
      <data key="d5">Information exchanged</data>
    </node>
    <node id="OBL-0348">
      <data key="d1">obligation</data>
      <data key="d2">The requested supervisory authority shall not refuse to comply with the request unless:
(a) it is not competent for the subject-matter of the request or for the measures it is requested to execute;</data>
      <data key="d3">Article 61</data>
      <data key="d4">Shall not refuse to comply with the request</data>
    </node>
    <node id="SUBJ:The requested supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">The requested supervisory authority</data>
    </node>
    <node id="COND:OBL-0348">
      <data key="d1">condition</data>
      <data key="d5">Unless it is not competent for the subject-matter of the request or for the measures it is requested to execute</data>
    </node>
    <node id="OBL-0349">
      <data key="d1">obligation</data>
      <data key="d2">The requested supervisory authority shall inform the requesting supervisory authority of the results or, as the case
may be, of the progress of the measures taken in order to respond to the request.</data>
      <data key="d3">Article 61</data>
      <data key="d4">Inform the requesting supervisory authority of the results or progress of the measures taken</data>
    </node>
    <node id="COND:OBL-0349">
      <data key="d1">condition</data>
      <data key="d5">In order to respond to the request</data>
    </node>
    <node id="OBL-0350">
      <data key="d1">obligation</data>
      <data key="d2">The requested supervisory authority
shall provide reasons for any refusal to comply with a request pursuant to paragraph 4.</data>
      <data key="d3">Article 61</data>
      <data key="d4">provide reasons for any refusal to comply with a request</data>
    </node>
    <node id="COND:OBL-0350">
      <data key="d1">condition</data>
      <data key="d5">pursuant to paragraph 4</data>
    </node>
    <node id="OBL-0351">
      <data key="d1">obligation</data>
      <data key="d2">Requested supervisory authorities shall, as a rule, supply the information requested by other supervisory
authorities by electronic means, using a standardised format.</data>
      <data key="d3">Article 61</data>
      <data key="d4">Supply the information requested by other supervisory authorities by electronic means, using a standardised format</data>
    </node>
    <node id="SUBJ:Requested supervisory authorities">
      <data key="d1">subject</data>
      <data key="d5">Requested supervisory authorities</data>
    </node>
    <node id="COND:OBL-0351">
      <data key="d1">condition</data>
      <data key="d5">As a rule</data>
    </node>
    <node id="OBL-0352">
      <data key="d1">obligation</data>
      <data key="d2">Requested supervisory authorities shall not charge a fee for any action taken by them pursuant to a request for
mutual assistance.</data>
      <data key="d3">Article 61</data>
      <data key="d4">shall not charge a fee for any action taken</data>
    </node>
    <node id="COND:OBL-0352">
      <data key="d1">condition</data>
      <data key="d5">pursuant to a request for mutual assistance</data>
    </node>
    <node id="OBL-0353">
      <data key="d1">obligation</data>
      <data key="d2">In that case, the urgent need
to act under Article 66(1) shall be presumed to be met and require an urgent binding decision from the Board pursuant
to Article 66(2).</data>
      <data key="d3">Article 61</data>
      <data key="d4">Require an urgent binding decision</data>
    </node>
    <node id="COND:OBL-0353">
      <data key="d1">condition</data>
      <data key="d5">The urgent need to act under Article 66(1) is presumed to be met</data>
    </node>
    <node id="OBL-0354">
      <data key="d1">obligation</data>
      <data key="d2">Those implementing acts shall be adopted in accordance with the examination
procedure referred to in Article 93(2).</data>
      <data key="d3">Article 61</data>
      <data key="d4">Adopt implementing acts</data>
    </node>
    <node id="COND:OBL-0354">
      <data key="d1">condition</data>
      <data key="d5">In accordance with the examination procedure referred to in Article 93(2)</data>
    </node>
    <node id="OBL-0355">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authorities shall, where appropriate, conduct joint operations including joint investigations and
joint enforcement measures in which members or staff of the supervisory authorities of other Member States are
involved.</data>
      <data key="d3">Article 61</data>
      <data key="d4">conduct joint operations including joint investigations and joint enforcement measures</data>
    </node>
    <node id="COND:OBL-0355">
      <data key="d1">condition</data>
      <data key="d5">where appropriate</data>
    </node>
    <node id="OBL-0356">
      <data key="d1">obligation</data>
      <data key="d2">Where the controller or processor has establishments in several Member States or where a significant number of
data subjects in more than one Member State are likely to be substantially affected by processing operations, a
supervisory authority of each of those Member States shall have the right to participate in joint operations.</data>
      <data key="d3">Section 2</data>
      <data key="d4">have the right to participate in joint operations</data>
    </node>
    <node id="SUBJ:supervisory authority of each of those Member States">
      <data key="d1">subject</data>
      <data key="d5">supervisory authority of each of those Member States</data>
    </node>
    <node id="COND:OBL-0356">
      <data key="d1">condition</data>
      <data key="d5">controller or processor has establishments in several Member States or a significant number of data subjects in more than one Member State are likely to be substantially affected by processing operations</data>
    </node>
    <node id="OBL-0357">
      <data key="d1">obligation</data>
      <data key="d2">The
supervisory authority which is competent pursuant to Article 56(1) or (4) shall invite the supervisory authority of each
of those Member States to take part in the joint operations and shall respond without delay to the request of a
supervisory authority to participate.</data>
      <data key="d3">Section 2</data>
      <data key="d4">Invite the supervisory authority of each of those Member States to take part in the joint operations and respond without delay to the request of a supervisory authority to participate</data>
    </node>
    <node id="SUBJ:The supervisory authority which is competent pursuant to Article 56(1) or (4)">
      <data key="d1">subject</data>
      <data key="d5">The supervisory authority which is competent pursuant to Article 56(1) or (4)</data>
    </node>
    <node id="DL:OBL-0357">
      <data key="d1">deadline</data>
      <data key="d5">Without delay</data>
    </node>
    <node id="OBL-0358">
      <data key="d1">obligation</data>
      <data key="d2">The
seconding supervisory authority's members or staff shall be subject to the Member State law of the host supervisory
authority.</data>
      <data key="d3">Section 2</data>
      <data key="d4">Shall be subject to the Member State law of the host supervisory authority</data>
    </node>
    <node id="SUBJ:The seconding supervisory authority's members or staff">
      <data key="d1">subject</data>
      <data key="d5">The seconding supervisory authority's members or staff</data>
    </node>
    <node id="OBL-0359">
      <data key="d1">obligation</data>
      <data key="d2">Where, in accordance with paragraph 1, staff of a seconding supervisory authority operate in another Member
State, the Member State of the host supervisory authority shall assume responsibility for their actions, including liability,
for any damage caused by them during their operations, in accordance with the law of the Member State in whose
territory they are operating.</data>
      <data key="d3">Section 2</data>
      <data key="d4">Assume responsibility for the actions of seconding supervisory authority staff, including liability for any damage caused</data>
    </node>
    <node id="SUBJ:The Member State of the host supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">The Member State of the host supervisory authority</data>
    </node>
    <node id="COND:OBL-0359">
      <data key="d1">condition</data>
      <data key="d5">Where staff of a seconding supervisory authority operate in another Member State</data>
    </node>
    <node id="OBL-0360">
      <data key="d1">obligation</data>
      <data key="d2">The Member State in whose territory the damage was caused shall make good such damage under the conditions
applicable to damage caused by its own staff.</data>
      <data key="d3">Section 2</data>
      <data key="d4">make good such damage</data>
    </node>
    <node id="SUBJ:The Member State">
      <data key="d1">subject</data>
      <data key="d5">The Member State</data>
    </node>
    <node id="COND:OBL-0360">
      <data key="d1">condition</data>
      <data key="d5">in whose territory the damage was caused</data>
    </node>
    <node id="EXC:OBL-0360">
      <data key="d1">exception</data>
      <data key="d5">under the conditions applicable to damage caused by its own staff</data>
    </node>
    <node id="OBL-0361">
      <data key="d1">obligation</data>
      <data key="d2">The Member State of the seconding supervisory authority whose staff has
caused damage to any person in the territory of another Member State shall reimburse that other Member State in full
any sums it has paid to the persons entitled on their behalf.</data>
      <data key="d3">Section 2</data>
      <data key="d4">reimburse that other Member State in full any sums it has paid to the persons entitled on their behalf</data>
    </node>
    <node id="SUBJ:The Member State of the seconding supervisory authority">
      <data key="d1">subject</data>
      <data key="d5">The Member State of the seconding supervisory authority</data>
    </node>
    <node id="COND:OBL-0361">
      <data key="d1">condition</data>
      <data key="d5">whose staff has caused damage to any person in the territory of another Member State</data>
    </node>
    <node id="OBL-0362">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to the exercise of its rights vis-à-vis third parties and with the exception of paragraph 5, each
Member State shall refrain, in the case provided for in paragraph 1, from requesting reimbursement from another
Member State in relation to damage referred to in paragraph 4.</data>
      <data key="d3">Section 2</data>
      <data key="d4">Refrain from requesting reimbursement from another Member State</data>
    </node>
    <node id="COND:OBL-0362">
      <data key="d1">condition</data>
      <data key="d5">In the case provided for in paragraph 1</data>
    </node>
    <node id="EXC:OBL-0362">
      <data key="d1">exception</data>
      <data key="d5">With the exception of paragraph 5</data>
    </node>
    <node id="OBL-0363">
      <data key="d1">obligation</data>
      <data key="d2">Where a joint operation is intended and a supervisory authority does not, within one month, comply with the
obligation laid down in the second sentence of paragraph 2 of this Article, the other supervisory authorities may adopt
a provisional measure on the territory of its Member State in accordance with Article 55.</data>
      <data key="d3">Section 2</data>
      <data key="d4">comply with the obligation laid down in the second sentence of paragraph 2 of this Article</data>
    </node>
    <node id="COND:OBL-0363">
      <data key="d1">condition</data>
      <data key="d5">Where a joint operation is intended</data>
    </node>
    <node id="DL:OBL-0363">
      <data key="d1">deadline</data>
      <data key="d5">within one month</data>
    </node>
    <node id="OBL-0364">
      <data key="d1">obligation</data>
      <data key="d2">In that case, the urgent need
to act under Article 66(1) shall be presumed to be met and require an opinion or an urgent binding decision from the
Board pursuant to Article 66(2).</data>
      <data key="d3">Section 2</data>
      <data key="d4">Require an opinion or an urgent binding decision</data>
    </node>
    <node id="COND:OBL-0364">
      <data key="d1">condition</data>
      <data key="d5">The urgent need to act under Article 66(1) is presumed to be met</data>
    </node>
    <node id="OBL-0365">
      <data key="d1">obligation</data>
      <data key="d2">Section 2
Consistency
Article 63
Consistency mechanism
In order to contribute to the consistent application of this Regulation throughout the Union, the supervisory authorities
shall cooperate with each other and, where relevant, with the Commission, through the consistency mechanism as set
out in this Section.</data>
      <data key="d3">Section 2</data>
      <data key="d4">cooperate with each other and, where relevant, with the Commission, through the consistency mechanism</data>
    </node>
    <node id="COND:OBL-0365">
      <data key="d1">condition</data>
      <data key="d5">In order to contribute to the consistent application of this Regulation throughout the Union</data>
    </node>
    <node id="OBL-0366">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall issue an opinion where a competent supervisory authority intends to adopt any of the measures
below.</data>
      <data key="d3">Section 2</data>
      <data key="d4">issue an opinion</data>
    </node>
    <node id="COND:OBL-0366">
      <data key="d1">condition</data>
      <data key="d5">where a competent supervisory authority intends to adopt any of the measures below</data>
    </node>
    <node id="OBL-0367">
      <data key="d1">obligation</data>
      <data key="d2">To that end, the competent supervisory authority shall communicate the draft decision to the Board, when it:
(a) aims to adopt a list of the processing operations subject to the requirement for a data protection impact assessment
pursuant to Article 35(4);</data>
      <data key="d3">Section 2</data>
      <data key="d4">Communicate the draft decision to the Board</data>
    </node>
    <node id="COND:OBL-0367">
      <data key="d1">condition</data>
      <data key="d5">When it aims to adopt a list of the processing operations subject to the requirement for a data protection impact assessment pursuant to Article 35(4)</data>
    </node>
    <node id="OBL-0368">
      <data key="d1">obligation</data>
      <data key="d2">In the cases referred to in paragraphs 1 and 2, the Board shall issue an opinion on the matter submitted to it
provided that it has not already issued an opinion on the same matter.</data>
      <data key="d3">Article 43</data>
      <data key="d4">shall issue an opinion on the matter submitted to it</data>
    </node>
    <node id="COND:OBL-0368">
      <data key="d1">condition</data>
      <data key="d5">In the cases referred to in paragraphs 1 and 2, provided that it has not already issued an opinion on the same matter</data>
    </node>
    <node id="OBL-0369">
      <data key="d1">obligation</data>
      <data key="d2">That opinion shall be adopted within eight weeks
by simple majority of the members of the Board.</data>
      <data key="d3">Article 43</data>
      <data key="d4">Adopt the opinion</data>
    </node>
    <node id="THRESH:OBL-0369">
      <data key="d1">threshold</data>
      <data key="d5">Simple majority of the members</data>
    </node>
    <node id="DL:OBL-0369">
      <data key="d1">deadline</data>
      <data key="d5">Within eight weeks</data>
    </node>
    <node id="OBL-0370">
      <data key="d1">obligation</data>
      <data key="d2">Regarding the draft decision referred to in paragraph 1 circulated to the
members of the Board in accordance with paragraph 5, a member which has not objected within a reasonable period
indicated by the Chair, shall be deemed to be in agreement with the draft decision.</data>
      <data key="d3">Article 43</data>
      <data key="d4">Shall be deemed to be in agreement with the draft decision</data>
    </node>
    <node id="SUBJ:A member of the Board">
      <data key="d1">subject</data>
      <data key="d5">A member of the Board</data>
    </node>
    <node id="COND:OBL-0370">
      <data key="d1">condition</data>
      <data key="d5">If the member has not objected within a reasonable period indicated by the Chair</data>
    </node>
    <node id="OBL-0371">
      <data key="d1">obligation</data>
      <data key="d2">Supervisory authorities and the Commission shall, without undue delay, communicate by electronic means to the
Board, using a standardised format any relevant information, including as the case may be a summary of the facts, the
draft decision, the grounds which make the enactment of such measure necessary, and the views of other supervisory
authorities concerned.</data>
      <data key="d3">Article 43</data>
      <data key="d4">Communicate by electronic means to the Board using a standardised format any relevant information</data>
    </node>
    <node id="SUBJ:Supervisory authorities and the Commission">
      <data key="d1">subject</data>
      <data key="d5">Supervisory authorities and the Commission</data>
    </node>
    <node id="COND:OBL-0371">
      <data key="d1">condition</data>
      <data key="d5">Without undue delay</data>
    </node>
    <node id="OBL-0372">
      <data key="d1">obligation</data>
      <data key="d2">The Chair of the Board shall, without undue, delay inform by electronic means:
(a) the members of the Board and the Commission of any relevant information which has been communicated to it
using a standardised format.</data>
      <data key="d3">Article 43</data>
      <data key="d4">inform by electronic means the members of the Board and the Commission of any relevant information</data>
    </node>
    <node id="SUBJ:The Chair of the Board">
      <data key="d1">subject</data>
      <data key="d5">The Chair of the Board</data>
    </node>
    <node id="COND:OBL-0372">
      <data key="d1">condition</data>
      <data key="d5">which has been communicated to it using a standardised format</data>
    </node>
    <node id="DL:OBL-0372">
      <data key="d1">deadline</data>
      <data key="d5">without undue delay</data>
    </node>
    <node id="OBL-0373">
      <data key="d1">obligation</data>
      <data key="d2">The secretariat of the Board shall, where necessary, provide translations of relevant
information;</data>
      <data key="d3">Article 43</data>
      <data key="d4">Provide translations of relevant information</data>
    </node>
    <node id="SUBJ:The secretariat of the Board">
      <data key="d1">subject</data>
      <data key="d5">The secretariat of the Board</data>
    </node>
    <node id="COND:OBL-0373">
      <data key="d1">condition</data>
      <data key="d5">Where necessary</data>
    </node>
    <node id="OBL-0374">
      <data key="d1">obligation</data>
      <data key="d2">The competent supervisory authority shall not adopt its draft decision referred to in paragraph 1 within the period
referred to in paragraph 3.</data>
      <data key="d3">Article 43</data>
      <data key="d4">shall not adopt its draft decision</data>
    </node>
    <node id="COND:OBL-0374">
      <data key="d1">condition</data>
      <data key="d5">referred to in paragraph 1</data>
    </node>
    <node id="DL:OBL-0374">
      <data key="d1">deadline</data>
      <data key="d5">within the period referred to in paragraph 3</data>
    </node>
    <node id="OBL-0375">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authority referred to in paragraph 1 shall take utmost account of the opinion of the Board and
shall, within two weeks after receiving the opinion, communicate to the Chair of the Board by electronic means whether
it will maintain or amend its draft decision and, if any, the amended draft decision, using a standardised format.</data>
      <data key="d3">Article 43</data>
      <data key="d4">Communicate to the Chair of the Board by electronic means whether it will maintain or amend its draft decision and, if any, the amended draft decision, using a standardised format</data>
    </node>
    <node id="COND:OBL-0375">
      <data key="d1">condition</data>
      <data key="d5">After receiving the opinion of the Board</data>
    </node>
    <node id="DL:OBL-0375">
      <data key="d1">deadline</data>
      <data key="d5">Within two weeks</data>
    </node>
    <node id="OBL-0376">
      <data key="d1">obligation</data>
      <data key="d2">Where the supervisory authority concerned informs the Chair of the Board within the period referred to in
paragraph 7 of this Article that it does not intend to follow the opinion of the Board, in whole or in part, providing the
relevant grounds, Article 65(1) shall apply.</data>
      <data key="d3">Article 43</data>
      <data key="d4">inform the Chair of the Board that it does not intend to follow the opinion of the Board, providing the relevant grounds</data>
    </node>
    <node id="COND:OBL-0376">
      <data key="d1">condition</data>
      <data key="d5">within the period referred to in paragraph 7 of this Article</data>
    </node>
    <node id="OBL-0377">
      <data key="d1">obligation</data>
      <data key="d2">In order to ensure the correct and consistent application of this Regulation in individual cases, the Board shall
adopt a binding decision in the following cases:
(a) where, in a case referred to in Article 60(4), a supervisory authority concerned has raised a relevant and reasoned
objection to a draft decision of the lead authority or the lead authority has rejected such an objection as being not
relevant or reasoned.</data>
      <data key="d3">Article 43</data>
      <data key="d4">Adopt a binding decision</data>
    </node>
    <node id="COND:OBL-0377">
      <data key="d1">condition</data>
      <data key="d5">In a case referred to in Article 60(4) where a supervisory authority concerned has raised a relevant and reasoned objection to a draft decision of the lead authority or the lead authority has rejected such an objection as being not relevant or reasoned</data>
    </node>
    <node id="OBL-0378">
      <data key="d1">obligation</data>
      <data key="d2">The binding decision shall concern all the matters which are the subject of the relevant and
reasoned objection, in particular whether there is an infringement of this Regulation;</data>
      <data key="d3">Article 43</data>
      <data key="d4">The binding decision shall concern all the matters which are the subject of the relevant and reasoned objection</data>
    </node>
    <node id="COND:OBL-0378">
      <data key="d1">condition</data>
      <data key="d5">whether there is an infringement of this Regulation</data>
    </node>
    <node id="OBL-0379">
      <data key="d1">obligation</data>
      <data key="d2">The decision referred to in paragraph 1 shall be adopted within one month from the referral of the subject-matter
by a two-thirds majority of the members of the Board.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Adopt the decision referred to in paragraph 1</data>
    </node>
    <node id="COND:OBL-0379">
      <data key="d1">condition</data>
      <data key="d5">Referral of the subject-matter</data>
    </node>
    <node id="THRESH:OBL-0379">
      <data key="d1">threshold</data>
      <data key="d5">Two-thirds majority of the members</data>
    </node>
    <node id="DL:OBL-0379">
      <data key="d1">deadline</data>
      <data key="d5">Within one month from the referral</data>
    </node>
    <node id="OBL-0380">
      <data key="d1">obligation</data>
      <data key="d2">The decision referred to in paragraph 1 shall be reasoned and addressed to the lead
supervisory authority and all the supervisory authorities concerned and binding on them.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Shall be reasoned and addressed to the lead supervisory authority and all the supervisory authorities concerned and binding on them</data>
    </node>
    <node id="SUBJ:The decision">
      <data key="d1">subject</data>
      <data key="d5">The decision</data>
    </node>
    <node id="COND:OBL-0380">
      <data key="d1">condition</data>
      <data key="d5">Referred to in paragraph 1</data>
    </node>
    <node id="OBL-0381">
      <data key="d1">obligation</data>
      <data key="d2">Where the Board has been unable to adopt a decision within the periods referred to in paragraph 2, it shall adopt
its decision within two weeks following the expiration of the second month referred to in paragraph 2 by a simple
majority of the members of the Board.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Adopt its decision</data>
    </node>
    <node id="COND:OBL-0381">
      <data key="d1">condition</data>
      <data key="d5">Where the Board has been unable to adopt a decision within the periods referred to in paragraph 2</data>
    </node>
    <node id="THRESH:OBL-0381">
      <data key="d1">threshold</data>
      <data key="d5">By a simple majority of the members of the Board</data>
    </node>
    <node id="DL:OBL-0381">
      <data key="d1">deadline</data>
      <data key="d5">Within two weeks following the expiration of the second month referred to in paragraph 2</data>
    </node>
    <node id="OBL-0382">
      <data key="d1">obligation</data>
      <data key="d2">Where the members of the Board are split, the decision shall by adopted by the
vote of its Chair.</data>
      <data key="d3">Article 64</data>
      <data key="d4">The decision shall be adopted by the vote of its Chair</data>
    </node>
    <node id="COND:OBL-0382">
      <data key="d1">condition</data>
      <data key="d5">Where the members of the Board are split</data>
    </node>
    <node id="OBL-0383">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authorities concerned shall not adopt a decision on the subject matter submitted to the Board
under paragraph 1 during the periods referred to in paragraphs 2 and 3.</data>
      <data key="d3">Article 64</data>
      <data key="d4">shall not adopt a decision on the subject matter submitted to the Board</data>
    </node>
    <node id="SUBJ:The supervisory authorities concerned">
      <data key="d1">subject</data>
      <data key="d5">The supervisory authorities concerned</data>
    </node>
    <node id="COND:OBL-0383">
      <data key="d1">condition</data>
      <data key="d5">during the periods referred to in paragraphs 2 and 3</data>
    </node>
    <node id="OBL-0384">
      <data key="d1">obligation</data>
      <data key="d2">The Chair of the Board shall notify, without undue delay, the decision referred to in paragraph 1 to the supervisory
authorities concerned.</data>
      <data key="d3">Article 64</data>
      <data key="d4">notify the decision referred to in paragraph 1 to the supervisory authorities concerned</data>
    </node>
    <node id="DL:OBL-0384">
      <data key="d1">deadline</data>
      <data key="d5">without undue delay</data>
    </node>
    <node id="OBL-0385">
      <data key="d1">obligation</data>
      <data key="d2">It shall inform the Commission thereof.</data>
      <data key="d3">Article 64</data>
      <data key="d4">inform the Commission</data>
    </node>
    <node id="OBL-0386">
      <data key="d1">obligation</data>
      <data key="d2">The decision shall be published on the website of the
Board without delay after the supervisory authority has notified the final decision referred to in paragraph 6.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Publish the decision on the website</data>
    </node>
    <node id="COND:OBL-0386">
      <data key="d1">condition</data>
      <data key="d5">After the supervisory authority has notified the final decision referred to in paragraph 6</data>
    </node>
    <node id="DL:OBL-0386">
      <data key="d1">deadline</data>
      <data key="d5">Without delay</data>
    </node>
    <node id="OBL-0387">
      <data key="d1">obligation</data>
      <data key="d2">The lead supervisory authority or, as the case may be, the supervisory authority with which the complaint has
been lodged shall adopt its final decision on the basis of the decision referred to in paragraph 1 of this Article, without
undue delay and at the latest by one month after the Board has notified its decision.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Adopt its final decision on the basis of the decision referred to in paragraph 1 of this Article</data>
    </node>
    <node id="SUBJ:The lead supervisory authority or the supervisory authority with which the complaint has been lodged">
      <data key="d1">subject</data>
      <data key="d5">The lead supervisory authority or the supervisory authority with which the complaint has been lodged</data>
    </node>
    <node id="DL:OBL-0387">
      <data key="d1">deadline</data>
      <data key="d5">Without undue delay and at the latest by one month after the Board has notified its decision</data>
    </node>
    <node id="OBL-0388">
      <data key="d1">obligation</data>
      <data key="d2">The lead supervisory authority or,
as the case may be, the supervisory authority with which the complaint has been lodged, shall inform the Board of the
date when its final decision is notified respectively to the controller or the processor and to the data subject.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Inform the Board of the date when its final decision is notified to the controller or the processor and to the data subject</data>
    </node>
    <node id="OBL-0389">
      <data key="d1">obligation</data>
      <data key="d2">The final
decision of the supervisory authorities concerned shall be adopted under the terms of Article 60(7), (8) and (9).</data>
      <data key="d3">Article 64</data>
    </node>
    <node id="OBL-0390">
      <data key="d1">obligation</data>
      <data key="d2">The
final decision shall refer to the decision referred to in paragraph 1 of this Article and shall specify that the decision
referred to in that paragraph will be published on the website of the Board in accordance with paragraph 5 of this
Article.</data>
      <data key="d3">Article 64</data>
    </node>
    <node id="OBL-0391">
      <data key="d1">obligation</data>
      <data key="d2">The final decision shall attach the decision referred to in paragraph 1 of this Article.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Attach the decision referred to in paragraph 1 of this Article</data>
    </node>
    <node id="COND:OBL-0391">
      <data key="d1">condition</data>
      <data key="d5">Final decision</data>
    </node>
    <node id="OBL-0392">
      <data key="d1">obligation</data>
      <data key="d2">In exceptional circumstances, where a supervisory authority concerned considers that there is an urgent need to
act in order to protect the rights and freedoms of data subjects, it may, by way of derogation from the consistency
mechanism referred to in Articles 63, 64 and 65 or the procedure referred to in Article 60, immediately adopt
provisional measures intended to produce legal effects on its own territory with a specified period of validity which shall
not exceed three months.</data>
      <data key="d3">Article 64</data>
      <data key="d4">immediately adopt provisional measures intended to produce legal effects on its own territory</data>
    </node>
    <node id="COND:OBL-0392">
      <data key="d1">condition</data>
      <data key="d5">exceptional circumstances where there is an urgent need to act to protect the rights and freedoms of data subjects</data>
    </node>
    <node id="THRESH:OBL-0392">
      <data key="d1">threshold</data>
      <data key="d5">specified period of validity which shall not exceed three months</data>
    </node>
    <node id="EXC:OBL-0392">
      <data key="d1">exception</data>
      <data key="d5">by way of derogation from the consistency mechanism referred to in Articles 63, 64 and 65 or the procedure referred to in Article 60</data>
    </node>
    <node id="OBL-0393">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authority shall, without delay, communicate those measures and the reasons
for adopting them to the other supervisory authorities concerned, to the Board and to the Commission.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Communicate those measures and the reasons for adopting them</data>
    </node>
    <node id="DL:OBL-0393">
      <data key="d1">deadline</data>
      <data key="d5">Without delay</data>
    </node>
    <node id="OBL-0394">
      <data key="d1">obligation</data>
      <data key="d2">By derogation from Article 64(3) and Article 65(2), an urgent opinion or an urgent binding decision referred to in
paragraphs 2 and 3 of this Article shall be adopted within two weeks by simple majority of the members of the Board.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Adopt an urgent opinion or an urgent binding decision</data>
    </node>
    <node id="COND:OBL-0394">
      <data key="d1">condition</data>
      <data key="d5">Referred to in paragraphs 2 and 3 of this Article</data>
    </node>
    <node id="THRESH:OBL-0394">
      <data key="d1">threshold</data>
      <data key="d5">Simple majority of the members</data>
    </node>
    <node id="DL:OBL-0394">
      <data key="d1">deadline</data>
      <data key="d5">Within two weeks</data>
    </node>
    <node id="EXC:OBL-0394">
      <data key="d1">exception</data>
      <data key="d5">By derogation from Article 64(3) and Article 65(2)</data>
    </node>
    <node id="OBL-0395">
      <data key="d1">obligation</data>
      <data key="d2">Those implementing acts shall be adopted in accordance with the examination procedure referred to in Article 93(2).</data>
      <data key="d3">Article 67</data>
      <data key="d4">Shall be adopted in accordance with the examination procedure</data>
    </node>
    <node id="COND:OBL-0395">
      <data key="d1">condition</data>
      <data key="d5">Referred to in Article 93(2)</data>
    </node>
    <node id="OBL-0396">
      <data key="d1">obligation</data>
      <data key="d2">The European Data Protection Board (the ‘Board’) is hereby established as a body of the Union and shall have legal
personality.</data>
      <data key="d3">Article 67</data>
    </node>
    <node id="OBL-0397">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall be represented by its Chair.</data>
      <data key="d3">Article 67</data>
      <data key="d4">shall be represented by its Chair</data>
    </node>
    <node id="OBL-0398">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall be composed of the head of one supervisory authority of each Member State and of the European
Data Protection Supervisor, or their respective representatives.</data>
      <data key="d3">Article 67</data>
      <data key="d4">Shall be composed of the head of one supervisory authority of each Member State and of the European Data Protection Supervisor, or their respective representatives</data>
    </node>
    <node id="OBL-0399">
      <data key="d1">obligation</data>
      <data key="d2">Where in a Member State more than one supervisory authority is responsible for monitoring the application of
the provisions pursuant to this Regulation, a joint representative shall be appointed in accordance with that Member
State's law.</data>
      <data key="d3">Article 67</data>
      <data key="d4">Appoint a joint representative</data>
    </node>
    <node id="COND:OBL-0399">
      <data key="d1">condition</data>
      <data key="d5">More than one supervisory authority is responsible for monitoring the application of the provisions pursuant to this Regulation</data>
    </node>
    <node id="OBL-0400">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall have the right to participate in the activities and meetings of the Board without voting
right.</data>
      <data key="d3">Article 67</data>
      <data key="d4">Participate in the activities and meetings of the Board</data>
    </node>
    <node id="COND:OBL-0400">
      <data key="d1">condition</data>
      <data key="d5">Without voting right</data>
    </node>
    <node id="OBL-0401">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall designate a representative.</data>
      <data key="d3">Article 67</data>
      <data key="d4">designate a representative</data>
    </node>
    <node id="OBL-0402">
      <data key="d1">obligation</data>
      <data key="d2">The Chair of the Board shall communicate to the Commission
the activities of the Board.</data>
      <data key="d3">Article 67</data>
      <data key="d4">communicate to the Commission the activities of the Board</data>
    </node>
    <node id="OBL-0403">
      <data key="d1">obligation</data>
      <data key="d2">In the cases referred to in Article 65, the European Data Protection Supervisor shall have voting rights only on
decisions which concern principles and rules applicable to the Union institutions, bodies, offices and agencies which
correspond in substance to those of this Regulation.</data>
      <data key="d3">Article 67</data>
      <data key="d4">shall have voting rights only on decisions</data>
    </node>
    <node id="SUBJ:European Data Protection Supervisor">
      <data key="d1">subject</data>
      <data key="d5">European Data Protection Supervisor</data>
    </node>
    <node id="COND:OBL-0403">
      <data key="d1">condition</data>
      <data key="d5">decisions which concern principles and rules applicable to the Union institutions, bodies, offices and agencies which correspond in substance to those of this Regulation</data>
    </node>
    <node id="EXC:OBL-0403">
      <data key="d1">exception</data>
      <data key="d5">In the cases referred to in Article 65</data>
    </node>
    <node id="OBL-0404">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall act independently when performing its tasks or exercising its powers pursuant to Articles 70
and 71.</data>
      <data key="d3">Article 67</data>
      <data key="d4">act independently when performing its tasks or exercising its powers</data>
    </node>
    <node id="COND:OBL-0404">
      <data key="d1">condition</data>
      <data key="d5">pursuant to Articles 70 and 71</data>
    </node>
    <node id="OBL-0405">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to requests by the Commission referred to in point (b) of Article 70(1) and in Article 70(2), the
Board shall, in the performance of its tasks or the exercise of its powers, neither seek nor take instructions from
anybody.</data>
      <data key="d3">Article 67</data>
      <data key="d4">Neither seek nor take instructions from anybody</data>
    </node>
    <node id="COND:OBL-0405">
      <data key="d1">condition</data>
      <data key="d5">In the performance of its tasks or the exercise of its powers</data>
    </node>
    <node id="EXC:OBL-0405">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to requests by the Commission referred to in point (b) of Article 70(1) and in Article 70(2)</data>
    </node>
    <node id="OBL-0406">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall ensure the consistent application of this Regulation.</data>
      <data key="d3">Article 67</data>
      <data key="d4">ensure the consistent application of this Regulation</data>
    </node>
    <node id="OBL-0407">
      <data key="d1">obligation</data>
      <data key="d2">To that end, the Board shall, on its own
initiative or, where relevant, at the request of the Commission, in particular:
(a) monitor and ensure the correct application of this Regulation in the cases provided for in Articles 64 and 65
without prejudice to the tasks of national supervisory authorities;</data>
      <data key="d3">Article 67</data>
      <data key="d4">Monitor and ensure the correct application of this Regulation</data>
    </node>
    <node id="COND:OBL-0407">
      <data key="d1">condition</data>
      <data key="d5">In the cases provided for in Articles 64 and 65</data>
    </node>
    <node id="EXC:OBL-0407">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to the tasks of national supervisory authorities</data>
    </node>
    <node id="OBL-0408">
      <data key="d1">obligation</data>
      <data key="d2">(g) issue guidelines, recommendations and best practices in accordance with point (e) of this paragraph for establishing
the personal data breaches and determining the undue delay referred to in Article 33(1) and (2) and for the
particular circumstances in which a controller or a processor is required to notify the personal data breach;</data>
      <data key="d3">Article 42</data>
      <data key="d4">Issue guidelines, recommendations and best practices</data>
    </node>
    <node id="SUBJ:The regulatory authority">
      <data key="d1">subject</data>
      <data key="d5">The regulatory authority</data>
    </node>
    <node id="COND:OBL-0408">
      <data key="d1">condition</data>
      <data key="d5">For establishing the personal data breaches and determining the undue delay referred to in Article 33(1) and (2) and for the particular circumstances in which a controller or a processor is required to notify the personal data breach</data>
    </node>
    <node id="OBL-0409">
      <data key="d1">obligation</data>
      <data key="d2">To that end, the Commission shall provide the Board with all necessary documentation,
including correspondence with the government of the third country, with regard to that third country, territory or
specified sector, or with the international organisation.</data>
      <data key="d3">Article 42</data>
      <data key="d4">Provide the Board with all necessary documentation, including correspondence with the government of the third country</data>
    </node>
    <node id="COND:OBL-0409">
      <data key="d1">condition</data>
      <data key="d5">With regard to that third country, territory or specified sector, or with the international organisation</data>
    </node>
    <node id="OBL-0410">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall forward its opinions, guidelines, recommendations, and best practices to the Commission and to
the committee referred to in Article 93 and make them public.</data>
      <data key="d3">Article 64</data>
      <data key="d4">forward its opinions, guidelines, recommendations, and best practices to the Commission and to the committee referred to in Article 93 and make them public</data>
    </node>
    <node id="OBL-0411">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall, where appropriate, consult interested parties and give them the opportunity to comment within a
reasonable period.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Consult interested parties and give them the opportunity to comment</data>
    </node>
    <node id="COND:OBL-0411">
      <data key="d1">condition</data>
      <data key="d5">Where appropriate</data>
    </node>
    <node id="DL:OBL-0411">
      <data key="d1">deadline</data>
      <data key="d5">Within a reasonable period</data>
    </node>
    <node id="OBL-0412">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall, without prejudice to Article 76, make the results of the consultation procedure
publicly available.</data>
      <data key="d3">Article 64</data>
      <data key="d4">make the results of the consultation procedure publicly available</data>
    </node>
    <node id="COND:OBL-0412">
      <data key="d1">condition</data>
      <data key="d5">without prejudice to Article 76</data>
    </node>
    <node id="OBL-0413">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall draw up an annual report regarding the protection of natural persons with regard to processing in
the Union and, where relevant, in third countries and international organisations.</data>
      <data key="d3">Article 64</data>
      <data key="d4">draw up an annual report regarding the protection of natural persons with regard to processing</data>
    </node>
    <node id="COND:OBL-0413">
      <data key="d1">condition</data>
      <data key="d5">in the Union and, where relevant, in third countries and international organisations</data>
    </node>
    <node id="DL:OBL-0413">
      <data key="d1">deadline</data>
      <data key="d5">annual</data>
    </node>
    <node id="OBL-0414">
      <data key="d1">obligation</data>
      <data key="d2">The report shall be made public and
be transmitted to the European Parliament, to the Council and to the Commission.</data>
      <data key="d3">Article 64</data>
      <data key="d4">shall be made public and be transmitted to the European Parliament, to the Council and to the Commission</data>
    </node>
    <node id="SUBJ:The report">
      <data key="d1">subject</data>
      <data key="d5">The report</data>
    </node>
    <node id="OBL-0415">
      <data key="d1">obligation</data>
      <data key="d2">The annual report shall include a review of the practical application of the guidelines, recommendations and best
practices referred to in point (l) of Article 70(1) as well as of the binding decisions referred to in Article 65.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Include a review of the practical application of the guidelines, recommendations and best practices referred to in point (l) of Article 70(1) as well as of the binding decisions referred to in Article 65</data>
    </node>
    <node id="SUBJ:The annual report">
      <data key="d1">subject</data>
      <data key="d5">The annual report</data>
    </node>
    <node id="OBL-0416">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall take decisions by a simple majority of its members, unless otherwise provided for in this
Regulation.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Take decisions by a simple majority of its members</data>
    </node>
    <node id="COND:OBL-0416">
      <data key="d1">condition</data>
      <data key="d5">Unless otherwise provided for in this Regulation</data>
    </node>
    <node id="OBL-0417">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall adopt its own rules of procedure by a two-thirds majority of its members and organise its own
operational arrangements.</data>
      <data key="d3">Article 64</data>
      <data key="d4">adopt its own rules of procedure and organise its own operational arrangements</data>
    </node>
    <node id="THRESH:OBL-0417">
      <data key="d1">threshold</data>
      <data key="d5">two-thirds majority of its members</data>
    </node>
    <node id="OBL-0418">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall elect a chair and two deputy chairs from amongst its members by simple majority.</data>
      <data key="d3">Article 64</data>
      <data key="d4">elect a chair and two deputy chairs from amongst its members</data>
    </node>
    <node id="THRESH:OBL-0418">
      <data key="d1">threshold</data>
      <data key="d5">simple majority</data>
    </node>
    <node id="OBL-0419">
      <data key="d1">obligation</data>
      <data key="d2">The term of office of the Chair and of the deputy chairs shall be five years and be renewable once.</data>
      <data key="d3">Article 64</data>
      <data key="d4">Term of office shall be five years and be renewable once</data>
    </node>
    <node id="SUBJ:Chair and deputy chairs">
      <data key="d1">subject</data>
      <data key="d5">Chair and deputy chairs</data>
    </node>
    <node id="THRESH:OBL-0419">
      <data key="d1">threshold</data>
      <data key="d5">Five years</data>
    </node>
    <node id="OBL-0420">
      <data key="d1">obligation</data>
      <data key="d2">The Chair shall have the following tasks:
(a) to convene the meetings of the Board and prepare its agenda;</data>
      <data key="d3">Article 74</data>
      <data key="d4">to convene the meetings of the Board and prepare its agenda</data>
    </node>
    <node id="SUBJ:The Chair">
      <data key="d1">subject</data>
      <data key="d5">The Chair</data>
    </node>
    <node id="OBL-0421">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall lay down the allocation of tasks between the Chair and the deputy chairs in its rules of procedure.</data>
      <data key="d3">Article 74</data>
      <data key="d4">lay down the allocation of tasks between the Chair and the deputy chairs</data>
    </node>
    <node id="COND:OBL-0421">
      <data key="d1">condition</data>
      <data key="d5">in its rules of procedure</data>
    </node>
    <node id="OBL-0422">
      <data key="d1">obligation</data>
      <data key="d2">The Board shall have a secretariat, which shall be provided by the European Data Protection Supervisor.</data>
      <data key="d3">Article 74</data>
      <data key="d4">shall have a secretariat</data>
    </node>
    <node id="OBL-0423">
      <data key="d1">obligation</data>
      <data key="d2">The secretariat shall perform its tasks exclusively under the instructions of the Chair of the Board.</data>
      <data key="d3">Article 74</data>
      <data key="d4">Perform its tasks exclusively under the instructions of the Chair of the Board</data>
    </node>
    <node id="SUBJ:The secretariat">
      <data key="d1">subject</data>
      <data key="d5">The secretariat</data>
    </node>
    <node id="OBL-0424">
      <data key="d1">obligation</data>
      <data key="d2">The staff of the European Data Protection Supervisor involved in carrying out the tasks conferred on the Board by
this Regulation shall be subject to separate reporting lines from the staff involved in carrying out tasks conferred on the
European Data Protection Supervisor.</data>
      <data key="d3">Article 74</data>
      <data key="d4">Be subject to separate reporting lines</data>
    </node>
    <node id="SUBJ:The staff of the European Data Protection Supervisor">
      <data key="d1">subject</data>
      <data key="d5">The staff of the European Data Protection Supervisor</data>
    </node>
    <node id="COND:OBL-0424">
      <data key="d1">condition</data>
      <data key="d5">Involved in carrying out the tasks conferred on the Board by this Regulation</data>
    </node>
    <node id="OBL-0425">
      <data key="d1">obligation</data>
      <data key="d2">Where appropriate, the Board and the European Data Protection Supervisor shall establish and publish a
Memorandum of Understanding implementing this Article, determining the terms of their cooperation, and applicable
to the staff of the European Data Protection Supervisor involved in carrying out the tasks conferred on the Board by this
Regulation.</data>
      <data key="d3">Article 74</data>
      <data key="d4">Establish and publish a Memorandum of Understanding</data>
    </node>
    <node id="SUBJ:The Board and the European Data Protection Supervisor">
      <data key="d1">subject</data>
      <data key="d5">The Board and the European Data Protection Supervisor</data>
    </node>
    <node id="COND:OBL-0425">
      <data key="d1">condition</data>
      <data key="d5">Where appropriate</data>
    </node>
    <node id="OBL-0426">
      <data key="d1">obligation</data>
      <data key="d2">The secretariat shall provide analytical, administrative and logistical support to the Board.</data>
      <data key="d3">Article 74</data>
      <data key="d4">provide analytical, administrative and logistical support to the Board</data>
    </node>
    <node id="OBL-0427">
      <data key="d1">obligation</data>
      <data key="d2">The secretariat shall be responsible in particular for:
(a) the day-to-day business of the Board;</data>
      <data key="d3">Article 74</data>
      <data key="d4">Be responsible for the day-to-day business of the Board</data>
    </node>
    <node id="OBL-0428">
      <data key="d1">obligation</data>
      <data key="d2">The discussions of the Board shall be confidential where the Board deems it necessary, as provided for in its rules
of procedure.</data>
      <data key="d3">Article 74</data>
      <data key="d4">Maintain confidentiality of discussions</data>
    </node>
    <node id="SUBJ:Board">
      <data key="d1">subject</data>
      <data key="d5">Board</data>
    </node>
    <node id="COND:OBL-0428">
      <data key="d1">condition</data>
      <data key="d5">Where the Board deems it necessary</data>
    </node>
    <node id="EXC:OBL-0428">
      <data key="d1">exception</data>
      <data key="d5">As provided for in its rules of procedure</data>
    </node>
    <node id="OBL-0429">
      <data key="d1">obligation</data>
      <data key="d2">Access to documents submitted to members of the Board, experts and representatives of third parties shall be
governed by Regulation (EC) No 1049/2001 of the European Parliament and of the Council (1).</data>
      <data key="d3">CHAPTER VIII</data>
      <data key="d4">Shall be governed by Regulation (EC) No 1049/2001 of the European Parliament and of the Council</data>
    </node>
    <node id="SUBJ:Access to documents submitted to members of the Board, experts and representatives of third parties">
      <data key="d1">subject</data>
      <data key="d5">Access to documents submitted to members of the Board, experts and representatives of third parties</data>
    </node>
    <node id="OBL-0430">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to any other administrative or judicial remedy, every data subject shall have the right to lodge a
complaint with a supervisory authority, in particular in the Member State of his or her habitual residence, place of work
or place of the alleged infringement if the data subject considers that the processing of personal data relating to him or
her infringes this Regulation.</data>
      <data key="d3">CHAPTER VIII</data>
      <data key="d4">have the right to lodge a complaint with a supervisory authority</data>
    </node>
    <node id="COND:OBL-0430">
      <data key="d1">condition</data>
      <data key="d5">if the data subject considers that the processing of personal data relating to him or her infringes this Regulation</data>
    </node>
    <node id="OBL-0431">
      <data key="d1">obligation</data>
      <data key="d2">The supervisory authority with which the complaint has been lodged shall inform the complainant on the progress
and the outcome of the complaint including the possibility of a judicial remedy pursuant to Article 78.</data>
      <data key="d3">CHAPTER VIII</data>
      <data key="d4">Inform the complainant on the progress and the outcome of the complaint including the possibility of a judicial remedy</data>
    </node>
    <node id="COND:OBL-0431">
      <data key="d1">condition</data>
      <data key="d5">With which the complaint has been lodged</data>
    </node>
    <node id="OBL-0432">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to any other administrative or non-judicial remedy, each natural or legal person shall have the
right to an effective judicial remedy against a legally binding decision of a supervisory authority concerning them.</data>
      <data key="d3">CHAPTER VIII</data>
      <data key="d4">have the right to an effective judicial remedy</data>
    </node>
    <node id="SUBJ:each natural or legal person">
      <data key="d1">subject</data>
      <data key="d5">each natural or legal person</data>
    </node>
    <node id="COND:OBL-0432">
      <data key="d1">condition</data>
      <data key="d5">against a legally binding decision of a supervisory authority concerning them</data>
    </node>
    <node id="EXC:OBL-0432">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to any other administrative or non-judicial remedy</data>
    </node>
    <node id="OBL-0433">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to any other administrative or non-judicial remedy, each data subject shall have the right to a an
effective judicial remedy where the supervisory authority which is competent pursuant to Articles 55 and 56 does not
handle a complaint or does not inform the data subject within three months on the progress or outcome of the
complaint lodged pursuant to Article 77.</data>
      <data key="d3">CHAPTER VIII</data>
      <data key="d4">have the right to an effective judicial remedy</data>
    </node>
    <node id="COND:OBL-0433">
      <data key="d1">condition</data>
      <data key="d5">where the supervisory authority does not handle a complaint or does not inform the data subject on the progress or outcome of the complaint</data>
    </node>
    <node id="DL:OBL-0433">
      <data key="d1">deadline</data>
      <data key="d5">within three months</data>
    </node>
    <node id="EXC:OBL-0433">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to any other administrative or non-judicial remedy</data>
    </node>
    <node id="OBL-0434">
      <data key="d1">obligation</data>
      <data key="d2">Proceedings against a supervisory authority shall be brought before the courts of the Member State where the
supervisory authority is established.</data>
      <data key="d3">CHAPTER VIII</data>
      <data key="d4">shall be brought before the courts</data>
    </node>
    <node id="SUBJ:Proceedings">
      <data key="d1">subject</data>
      <data key="d5">Proceedings</data>
    </node>
    <node id="COND:OBL-0434">
      <data key="d1">condition</data>
      <data key="d5">against a supervisory authority</data>
    </node>
    <node id="OBL-0435">
      <data key="d1">obligation</data>
      <data key="d2">Where proceedings are brought against a decision of a supervisory authority which was preceded by an opinion or
a decision of the Board in the consistency mechanism, the supervisory authority shall forward that opinion or decision
to the court.</data>
      <data key="d3">CHAPTER VIII</data>
      <data key="d4">forward that opinion or decision to the court</data>
    </node>
    <node id="COND:OBL-0435">
      <data key="d1">condition</data>
      <data key="d5">proceedings are brought against a decision of a supervisory authority which was preceded by an opinion or a decision of the Board in the consistency mechanism</data>
    </node>
    <node id="OBL-0436">
      <data key="d1">obligation</data>
      <data key="d2">Without prejudice to any available administrative or non-judicial remedy, including the right to lodge a complaint
with a supervisory authority pursuant to Article 77, each data subject shall have the right to an effective judicial remedy
where he or she considers that his or her rights under this Regulation have been infringed as a result of the processing
of his or her personal data in non-compliance with this Regulation.</data>
      <data key="d3">CHAPTER VIII</data>
      <data key="d4">have the right to an effective judicial remedy</data>
    </node>
    <node id="COND:OBL-0436">
      <data key="d1">condition</data>
      <data key="d5">where he or she considers that his or her rights under this Regulation have been infringed as a result of the processing of his or her personal data in non-compliance with this Regulation</data>
    </node>
    <node id="EXC:OBL-0436">
      <data key="d1">exception</data>
      <data key="d5">Without prejudice to any available administrative or non-judicial remedy, including the right to lodge a complaint with a supervisory authority pursuant to Article 77</data>
    </node>
    <node id="OBL-0437">
      <data key="d1">obligation</data>
      <data key="d2">Proceedings against a controller or a processor shall be brought before the courts of the Member State where the
controller or processor has an establishment.</data>
      <data key="d3">CHAPTER VIII</data>
      <data key="d4">Proceedings shall be brought before the courts</data>
    </node>
    <node id="COND:OBL-0437">
      <data key="d1">condition</data>
      <data key="d5">where the controller or processor has an establishment</data>
    </node>
    <node id="OBL-0438">
      <data key="d1">obligation</data>
      <data key="d2">The data subject shall have the right to mandate a not-for-profit body, organisation or association which has been
properly constituted in accordance with the law of a Member State, has statutory objectives which are in the public
interest, and is active in the field of the protection of data subjects' rights and freedoms with regard to the protection of
their personal data to lodge the complaint on his or her behalf, to exercise the rights referred to in Articles 77, 78 and
79 on his or her behalf, and to exercise the right to receive compensation referred to in Article 82 on his or her behalf
where provided for by Member State law.</data>
      <data key="d3">Article 80</data>
      <data key="d4">Mandate a not-for-profit body, organisation or association to lodge the complaint, exercise rights referred to in Articles 77, 78 and 79, and exercise the right to receive compensation referred to in Article 82 on his or her behalf</data>
    </node>
    <node id="COND:OBL-0438">
      <data key="d1">condition</data>
      <data key="d5">The body, organisation or association must be properly constituted in accordance with the law of a Member State, have statutory objectives in the public interest, and be active in the field of the protection of data subjects' rights and freedoms with regard to the protection of their personal data</data>
    </node>
    <node id="EXC:OBL-0438">
      <data key="d1">exception</data>
      <data key="d5">Where provided for by Member State law</data>
    </node>
    <node id="OBL-0439">
      <data key="d1">obligation</data>
      <data key="d2">Where a competent court of a Member State has information on proceedings, concerning the same subject matter
as regards processing by the same controller or processor, that are pending in a court in another Member State, it shall
contact that court in the other Member State to confirm the existence of such proceedings.</data>
      <data key="d3">Article 80</data>
      <data key="d4">Contact that court in the other Member State to confirm the existence of such proceedings</data>
    </node>
    <node id="SUBJ:A competent court of a Member State">
      <data key="d1">subject</data>
      <data key="d5">A competent court of a Member State</data>
    </node>
    <node id="COND:OBL-0439">
      <data key="d1">condition</data>
      <data key="d5">Where a competent court of a Member State has information on proceedings concerning the same subject matter as regards processing by the same controller or processor that are pending in a court in another Member State</data>
    </node>
    <node id="OBL-0440">
      <data key="d1">obligation</data>
      <data key="d2">Any person who has suffered material or non-material damage as a result of an infringement of this Regulation
shall have the right to receive compensation from the controller or processor for the damage suffered.</data>
      <data key="d3">Article 80</data>
      <data key="d4">Receive compensation from the controller or processor for the damage suffered</data>
    </node>
    <node id="SUBJ:Any person who has suffered material or non-material damage">
      <data key="d1">subject</data>
      <data key="d5">Any person who has suffered material or non-material damage</data>
    </node>
    <node id="COND:OBL-0440">
      <data key="d1">condition</data>
      <data key="d5">As a result of an infringement of this Regulation</data>
    </node>
    <node id="OBL-0441">
      <data key="d1">obligation</data>
      <data key="d2">Any controller involved in processing shall be liable for the damage caused by processing which infringes this
Regulation.</data>
      <data key="d3">Article 80</data>
      <data key="d4">liable for the damage caused by processing</data>
    </node>
    <node id="COND:OBL-0441">
      <data key="d1">condition</data>
      <data key="d5">processing which infringes this Regulation</data>
    </node>
    <node id="OBL-0442">
      <data key="d1">obligation</data>
      <data key="d2">A processor shall be liable for the damage caused by processing only where it has not complied with
obligations of this Regulation specifically directed to processors or where it has acted outside or contrary to lawful
instructions of the controller.</data>
      <data key="d3">Article 80</data>
      <data key="d4">liable for the damage caused by processing</data>
    </node>
    <node id="COND:OBL-0442">
      <data key="d1">condition</data>
      <data key="d5">where it has not complied with obligations of this Regulation specifically directed to processors or where it has acted outside or contrary to lawful instructions of the controller</data>
    </node>
    <node id="OBL-0443">
      <data key="d1">obligation</data>
      <data key="d2">A controller or processor shall be exempt from liability under paragraph 2 if it proves that it is not in any way
responsible for the event giving rise to the damage.</data>
      <data key="d3">Article 80</data>
      <data key="d4">exempt from liability</data>
    </node>
    <node id="COND:OBL-0443">
      <data key="d1">condition</data>
      <data key="d5">proves that it is not in any way responsible for the event giving rise to the damage</data>
    </node>
    <node id="OBL-0444">
      <data key="d1">obligation</data>
      <data key="d2">Where more than one controller or processor, or both a controller and a processor, are involved in the same
processing and where they are, under paragraphs 2 and 3, responsible for any damage caused by processing, each
controller or processor shall be held liable for the entire damage in order to ensure effective compensation of the data
subject.</data>
      <data key="d3">Article 80</data>
      <data key="d4">shall be held liable for the entire damage</data>
    </node>
    <node id="COND:OBL-0444">
      <data key="d1">condition</data>
      <data key="d5">more than one controller or processor, or both a controller and a processor, are involved in the same processing and are responsible for any damage caused by processing</data>
    </node>
    <node id="OBL-0445">
      <data key="d1">obligation</data>
      <data key="d2">Where a controller or processor has, in accordance with paragraph 4, paid full compensation for the damage
suffered, that controller or processor shall be entitled to claim back from the other controllers or processors involved in
the same processing that part of the compensation corresponding to their part of responsibility for the damage, in
accordance with the conditions set out in paragraph 2.</data>
      <data key="d3">Article 80</data>
      <data key="d4">claim back from the other controllers or processors involved in the same processing that part of the compensation corresponding to their part of responsibility for the damage</data>
    </node>
    <node id="COND:OBL-0445">
      <data key="d1">condition</data>
      <data key="d5">has, in accordance with paragraph 4, paid full compensation for the damage suffered</data>
    </node>
    <node id="OBL-0446">
      <data key="d1">obligation</data>
      <data key="d2">Court proceedings for exercising the right to receive compensation shall be brought before the courts competent
under the law of the Member State referred to in Article 79(2).</data>
      <data key="d3">Article 83</data>
      <data key="d4">shall be brought before the courts competent under the law of the Member State</data>
    </node>
    <node id="SUBJ:Court proceedings">
      <data key="d1">subject</data>
      <data key="d5">Court proceedings</data>
    </node>
    <node id="COND:OBL-0446">
      <data key="d1">condition</data>
      <data key="d5">for exercising the right to receive compensation</data>
    </node>
    <node id="OBL-0447">
      <data key="d1">obligation</data>
      <data key="d2">Each supervisory authority shall ensure that the imposition of administrative fines pursuant to this Article in
respect of infringements of this Regulation referred to in paragraphs 4, 5 and 6 shall in each individual case be effective,
proportionate and dissuasive.</data>
      <data key="d3">Article 83</data>
      <data key="d4">ensure that the imposition of administrative fines is effective, proportionate and dissuasive</data>
    </node>
    <node id="COND:OBL-0447">
      <data key="d1">condition</data>
      <data key="d5">in respect of infringements of this Regulation referred to in paragraphs 4, 5 and 6</data>
    </node>
    <node id="OBL-0448">
      <data key="d1">obligation</data>
      <data key="d2">Administrative fines shall, depending on the circumstances of each individual case, be imposed in addition to, or
instead of, measures referred to in points (a) to (h) and (j) of Article 58(2).</data>
      <data key="d3">Article 83</data>
      <data key="d4">Administrative fines shall be imposed</data>
    </node>
    <node id="COND:OBL-0448">
      <data key="d1">condition</data>
      <data key="d5">Depending on the circumstances of each individual case</data>
    </node>
    <node id="EXC:OBL-0448">
      <data key="d1">exception</data>
      <data key="d5">In addition to, or instead of, measures referred to in points (a) to (h) and (j) of Article 58(2)</data>
    </node>
    <node id="OBL-0449">
      <data key="d1">obligation</data>
      <data key="d2">When deciding whether to impose an
administrative fine and deciding on the amount of the administrative fine in each individual case due regard shall be
given to the following:
(a) the nature, gravity and duration of the infringement taking into account the nature scope or purpose of the
processing concerned as well as the number of data subjects affected and the level of damage suffered by them;</data>
      <data key="d3">Article 83</data>
      <data key="d4">Give due regard to the nature, gravity, and duration of the infringement</data>
    </node>
    <node id="COND:OBL-0449">
      <data key="d1">condition</data>
      <data key="d5">When deciding whether to impose an administrative fine and deciding on the amount of the administrative fine in each individual case</data>
    </node>
    <node id="OBL-0450">
      <data key="d1">obligation</data>
      <data key="d2">If a controller or processor intentionally or negligently, for the same or linked processing operations, infringes
several provisions of this Regulation, the total amount of the administrative fine shall not exceed the amount specified
for the gravest infringement.</data>
      <data key="d3">Article 83</data>
      <data key="d4">The total amount of the administrative fine shall not exceed the amount specified for the gravest infringement</data>
    </node>
    <node id="COND:OBL-0450">
      <data key="d1">condition</data>
      <data key="d5">intentionally or negligently, for the same or linked processing operations, infringes several provisions of this Regulation</data>
    </node>
    <node id="OBL-0451">
      <data key="d1">obligation</data>
      <data key="d2">Infringements of the following provisions shall, in accordance with paragraph 2, be subject to administrative fines
up to 10 000 000 EUR, or in the case of an undertaking, up to 2 % of the total worldwide annual turnover of the
preceding financial year, whichever is higher:
(a) the obligations of the controller and the processor pursuant to Articles 8, 11, 25 to 39 and 42 and 43;</data>
      <data key="d3">Article 83</data>
      <data key="d4">comply with obligations pursuant to Articles 8, 11, 25 to 39 and 42 and 43</data>
    </node>
    <node id="COND:OBL-0451">
      <data key="d1">condition</data>
      <data key="d5">infringements of the provisions</data>
    </node>
    <node id="THRESH:OBL-0451">
      <data key="d1">threshold</data>
      <data key="d5">up to 10 000 000 EUR, or up to 2 % of the total worldwide annual turnover of the preceding financial year, whichever is higher</data>
    </node>
    <node id="OBL-0452">
      <data key="d1">obligation</data>
      <data key="d2">Infringements of the following provisions shall, in accordance with paragraph 2, be subject to administrative fines
up to 20 000 000 EUR, or in the case of an undertaking, up to 4 % of the total worldwide annual turnover of the
preceding financial year, whichever is higher:
(a) the basic principles for processing, including conditions for consent, pursuant to Articles 5, 6, 7 and 9;</data>
      <data key="d3">Article 84</data>
      <data key="d4">Avoid infringements of the basic principles for processing, including conditions for consent</data>
    </node>
    <node id="COND:OBL-0452">
      <data key="d1">condition</data>
      <data key="d5">In accordance with paragraph 2</data>
    </node>
    <node id="THRESH:OBL-0452">
      <data key="d1">threshold</data>
      <data key="d5">Up to 20 000 000 EUR, or up to 4% of the total worldwide annual turnover of the preceding financial year, whichever is higher</data>
    </node>
    <node id="OBL-0453">
      <data key="d1">obligation</data>
      <data key="d2">Non-compliance with an order by the supervisory authority as referred to in Article 58(2) shall, in accordance
with paragraph 2 of this Article, be subject to administrative fines up to 20 000 000 EUR, or in the case of an
undertaking, up to 4 % of the total worldwide annual turnover of the preceding financial year, whichever is higher.</data>
      <data key="d3">Article 84</data>
      <data key="d4">Be subject to administrative fines</data>
    </node>
    <node id="COND:OBL-0453">
      <data key="d1">condition</data>
      <data key="d5">Non-compliance with an order by the supervisory authority as referred to in Article 58(2)</data>
    </node>
    <node id="THRESH:OBL-0453">
      <data key="d1">threshold</data>
      <data key="d5">Up to 20 000 000 EUR, or up to 4% of the total worldwide annual turnover of the preceding financial year, whichever is higher</data>
    </node>
    <node id="OBL-0454">
      <data key="d1">obligation</data>
      <data key="d2">The exercise by the supervisory authority of its powers under this Article shall be subject to appropriate
procedural safeguards in accordance with Union and Member State law, including effective judicial remedy and due
process.</data>
      <data key="d3">Article 84</data>
      <data key="d4">exercise its powers under this Article</data>
    </node>
    <node id="COND:OBL-0454">
      <data key="d1">condition</data>
      <data key="d5">subject to appropriate procedural safeguards in accordance with Union and Member State law</data>
    </node>
    <node id="OBL-0455">
      <data key="d1">obligation</data>
      <data key="d2">In any event, the fines imposed shall be effective, proportionate and dissuasive.</data>
      <data key="d3">Article 84</data>
    </node>
    <node id="OBL-0456">
      <data key="d1">obligation</data>
      <data key="d2">Those Member States shall notify to the Commission the provisions of their laws which they adopt pursuant to this
paragraph by 25 May 2018 and, without delay, any subsequent amendment law or amendment affecting them.</data>
      <data key="d3">Article 84</data>
      <data key="d4">Notify to the Commission the provisions of their laws adopted pursuant to this paragraph and any subsequent amendment law or amendment affecting them</data>
    </node>
    <node id="DL:OBL-0456">
      <data key="d1">deadline</data>
      <data key="d5">By 25 May 2018 and without delay for subsequent amendments</data>
    </node>
    <node id="OBL-0457">
      <data key="d1">obligation</data>
      <data key="d2">Member States shall lay down the rules on other penalties applicable to infringements of this Regulation in
particular for infringements which are not subject to administrative fines pursuant to Article 83, and shall take all
measures necessary to ensure that they are implemented.</data>
      <data key="d3">Article 84</data>
      <data key="d4">Lay down the rules on other penalties applicable to infringements of this Regulation and take all measures necessary to ensure that they are implemented</data>
    </node>
    <node id="COND:OBL-0457">
      <data key="d1">condition</data>
      <data key="d5">Infringements which are not subject to administrative fines pursuant to Article 83</data>
    </node>
    <node id="OBL-0458">
      <data key="d1">obligation</data>
      <data key="d2">Such penalties shall be effective, proportionate and dissuasive.</data>
      <data key="d3">Article 84</data>
    </node>
    <node id="OBL-0459">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall notify to the Commission the provisions of its law which it adopts pursuant to
paragraph 1, by 25 May 2018 and, without delay, any subsequent amendment affecting them.</data>
      <data key="d3">Article 84</data>
      <data key="d4">notify to the Commission the provisions of its law which it adopts pursuant to paragraph 1</data>
    </node>
    <node id="DL:OBL-0459">
      <data key="d1">deadline</data>
      <data key="d5">by 25 May 2018 and, without delay, any subsequent amendment affecting them</data>
    </node>
    <node id="OBL-0460">
      <data key="d1">obligation</data>
      <data key="d2">Member States shall by law reconcile the right to the protection of personal data pursuant to this Regulation with
the right to freedom of expression and information, including processing for journalistic purposes and the purposes of
academic, artistic or literary expression.</data>
      <data key="d3">Article 84</data>
      <data key="d4">Reconcile the right to the protection of personal data with the right to freedom of expression and information</data>
    </node>
    <node id="COND:OBL-0460">
      <data key="d1">condition</data>
      <data key="d5">Pursuant to this Regulation</data>
    </node>
    <node id="EXC:OBL-0460">
      <data key="d1">exception</data>
      <data key="d5">Including processing for journalistic purposes and the purposes of academic, artistic or literary expression</data>
    </node>
    <node id="OBL-0461">
      <data key="d1">obligation</data>
      <data key="d2">For processing carried out for journalistic purposes or the purpose of academic artistic or literary expression,
Member States shall provide for exemptions or derogations from Chapter II (principles), Chapter III (rights of the data
subject), Chapter IV (controller and processor), Chapter V (transfer of personal data to third countries or international
organisations), Chapter VI (independent supervisory authorities), Chapter VII (cooperation and consistency) and
Chapter IX (specific data processing situations) if they are necessary to reconcile the right to the protection of personal
data with the freedom of expression and information.</data>
      <data key="d3">Chapter IX</data>
      <data key="d4">Provide for exemptions or derogations from Chapter II, Chapter III, Chapter IV, Chapter V, Chapter VI, Chapter VII, and Chapter IX</data>
    </node>
    <node id="COND:OBL-0461">
      <data key="d1">condition</data>
      <data key="d5">For processing carried out for journalistic purposes or the purpose of academic artistic or literary expression</data>
    </node>
    <node id="EXC:OBL-0461">
      <data key="d1">exception</data>
      <data key="d5">If they are necessary to reconcile the right to the protection of personal data with the freedom of expression and information</data>
    </node>
    <node id="OBL-0462">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall notify to the Commission the provisions of its law which it has adopted pursuant to
paragraph 2 and, without delay, any subsequent amendment law or amendment affecting them.</data>
      <data key="d3">Chapter IX</data>
      <data key="d4">notify to the Commission the provisions of its law which it has adopted pursuant to paragraph 2 and, without delay, any subsequent amendment law or amendment affecting them</data>
    </node>
    <node id="DL:OBL-0462">
      <data key="d1">deadline</data>
      <data key="d5">without delay</data>
    </node>
    <node id="OBL-0463">
      <data key="d1">obligation</data>
      <data key="d2">In that case the national identification number or any other identifier of
general application shall be used only under appropriate safeguards for the rights and freedoms of the data subject
pursuant to this Regulation.</data>
      <data key="d3">Chapter IX</data>
      <data key="d4">Use the national identification number or any other identifier of general application only under appropriate safeguards</data>
    </node>
    <node id="COND:OBL-0463">
      <data key="d1">condition</data>
      <data key="d5">For the rights and freedoms of the data subject pursuant to this Regulation</data>
    </node>
    <node id="OBL-0464">
      <data key="d1">obligation</data>
      <data key="d2">Those rules shall include suitable and specific measures to safeguard the data subject's human dignity, legitimate
interests and fundamental rights, with particular regard to the transparency of processing, the transfer of personal data
within a group of undertakings, or a group of enterprises engaged in a joint economic activity and monitoring systems
at the work place.</data>
      <data key="d3">Chapter IX</data>
      <data key="d4">include suitable and specific measures to safeguard the data subject's human dignity, legitimate interests and fundamental rights</data>
    </node>
    <node id="SUBJ:Those rules">
      <data key="d1">subject</data>
      <data key="d5">Those rules</data>
    </node>
    <node id="COND:OBL-0464">
      <data key="d1">condition</data>
      <data key="d5">with particular regard to the transparency of processing, the transfer of personal data within a group of undertakings, or a group of enterprises engaged in a joint economic activity and monitoring systems at the work place</data>
    </node>
    <node id="OBL-0465">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall notify to the Commission those provisions of its law which it adopts pursuant to
paragraph 1, by 25 May 2018 and, without delay, any subsequent amendment affecting them.</data>
      <data key="d3">Chapter IX</data>
      <data key="d4">notify to the Commission those provisions of its law which it adopts pursuant to paragraph 1</data>
    </node>
    <node id="DL:OBL-0465">
      <data key="d1">deadline</data>
      <data key="d5">by 25 May 2018 and, without delay, any subsequent amendment affecting them</data>
    </node>
    <node id="OBL-0466">
      <data key="d1">obligation</data>
      <data key="d2">Processing for archiving purposes in the public interest, scientific or historical research purposes or statistical
purposes, shall be subject to appropriate safeguards, in accordance with this Regulation, for the rights and freedoms of
the data subject.</data>
      <data key="d3">Chapter IX</data>
      <data key="d4">Shall be subject to appropriate safeguards</data>
    </node>
    <node id="SUBJ:Processing for archiving purposes in the public interest, scientific or historical research purposes or statistical purposes">
      <data key="d1">subject</data>
      <data key="d5">Processing for archiving purposes in the public interest, scientific or historical research purposes or statistical purposes</data>
    </node>
    <node id="COND:OBL-0466">
      <data key="d1">condition</data>
      <data key="d5">In accordance with this Regulation, for the rights and freedoms of the data subject</data>
    </node>
    <node id="OBL-0467">
      <data key="d1">obligation</data>
      <data key="d2">Those safeguards shall ensure that technical and organisational measures are in place in particular in</data>
      <data key="d3">Chapter IX</data>
      <data key="d4">Ensure that technical and organisational measures are in place</data>
    </node>
    <node id="COND:OBL-0467">
      <data key="d1">condition</data>
      <data key="d5">In particular</data>
    </node>
    <node id="OBL-0468">
      <data key="d1">obligation</data>
      <data key="d2">Where those purposes can be fulfilled by further processing which
does not permit or no longer permits the identification of data subjects, those purposes shall be fulfilled in that manner.</data>
      <data key="d3">Article 90</data>
      <data key="d4">Fulfill purposes by further processing which does not permit or no longer permits the identification of data subjects</data>
    </node>
    <node id="COND:OBL-0468">
      <data key="d1">condition</data>
      <data key="d5">Where those purposes can be fulfilled by further processing</data>
    </node>
    <node id="OBL-0469">
      <data key="d1">obligation</data>
      <data key="d2">Where processing referred to in paragraphs 2 and 3 serves at the same time another purpose, the derogations shall
apply only to processing for the purposes referred to in those paragraphs.</data>
      <data key="d3">Article 90</data>
      <data key="d4">Derogations shall apply only to processing for the purposes referred to in paragraphs 2 and 3</data>
    </node>
    <node id="COND:OBL-0469">
      <data key="d1">condition</data>
      <data key="d5">Processing serves at the same time another purpose</data>
    </node>
    <node id="OBL-0470">
      <data key="d1">obligation</data>
      <data key="d2">Member States may adopt specific rules to set out the powers of the supervisory authorities laid down in points (e)
and (f) of Article 58(1) in relation to controllers or processors that are subject, under Union or Member State law or
rules established by national competent bodies, to an obligation of professional secrecy or other equivalent obligations
of secrecy where this is necessary and proportionate to reconcile the right of the protection of personal data with the
obligation of secrecy.</data>
      <data key="d3">Article 90</data>
      <data key="d4">Adopt specific rules to set out the powers of the supervisory authorities</data>
    </node>
    <node id="COND:OBL-0470">
      <data key="d1">condition</data>
      <data key="d5">In relation to controllers or processors subject to an obligation of professional secrecy or other equivalent obligations of secrecy</data>
    </node>
    <node id="EXC:OBL-0470">
      <data key="d1">exception</data>
      <data key="d5">Where this is necessary and proportionate to reconcile the right of the protection of personal data with the obligation of secrecy</data>
    </node>
    <node id="OBL-0471">
      <data key="d1">obligation</data>
      <data key="d2">Those rules shall apply only with regard to personal data which the controller or processor has
received as a result of or has obtained in an activity covered by that obligation of secrecy.</data>
      <data key="d3">Article 90</data>
      <data key="d4">apply those rules</data>
    </node>
    <node id="COND:OBL-0471">
      <data key="d1">condition</data>
      <data key="d5">with regard to personal data received or obtained in an activity covered by that obligation of secrecy</data>
    </node>
    <node id="OBL-0472">
      <data key="d1">obligation</data>
      <data key="d2">Each Member State shall notify to the Commission the rules adopted pursuant to paragraph 1, by 25 May 2018
and, without delay, any subsequent amendment affecting them.</data>
      <data key="d3">Article 90</data>
      <data key="d4">notify to the Commission the rules adopted pursuant to paragraph 1 and any subsequent amendment affecting them</data>
    </node>
    <node id="DL:OBL-0472">
      <data key="d1">deadline</data>
      <data key="d5">by 25 May 2018 and without delay for subsequent amendments</data>
    </node>
    <node id="OBL-0473">
      <data key="d1">obligation</data>
      <data key="d2">Churches and religious associations which apply comprehensive rules in accordance with paragraph 1 of this
Article shall be subject to the supervision of an independent supervisory authority, which may be specific, provided that
it fulfils the conditions laid down in Chapter VI of this Regulation.</data>
      <data key="d3">Article 90</data>
      <data key="d4">Be subject to the supervision of an independent supervisory authority</data>
    </node>
    <node id="SUBJ:Churches and religious associations">
      <data key="d1">subject</data>
      <data key="d5">Churches and religious associations</data>
    </node>
    <node id="COND:OBL-0473">
      <data key="d1">condition</data>
      <data key="d5">Apply comprehensive rules in accordance with paragraph 1 of this Article</data>
    </node>
    <node id="EXC:OBL-0473">
      <data key="d1">exception</data>
      <data key="d5">The supervisory authority may be specific, provided that it fulfils the conditions laid down in Chapter VI of this Regulation</data>
    </node>
    <node id="OBL-0474">
      <data key="d1">obligation</data>
      <data key="d2">The delegation of power referred to in Article 12(8) and Article 43(8) shall be conferred on the Commission for
an indeterminate period of time from 24 May 2016.</data>
      <data key="d3">Article 93</data>
      <data key="d4">The delegation of power shall be conferred</data>
    </node>
    <node id="COND:OBL-0474">
      <data key="d1">condition</data>
      <data key="d5">Referred to in Article 12(8) and Article 43(8)</data>
    </node>
    <node id="DL:OBL-0474">
      <data key="d1">deadline</data>
      <data key="d5">From 24 May 2016</data>
    </node>
    <node id="OBL-0475">
      <data key="d1">obligation</data>
      <data key="d2">A decision of revocation shall put an end to the delegation of power specified in
that decision.</data>
      <data key="d3">Article 93</data>
      <data key="d4">Put an end to the delegation of power</data>
    </node>
    <node id="COND:OBL-0475">
      <data key="d1">condition</data>
      <data key="d5">A decision of revocation</data>
    </node>
    <node id="OBL-0476">
      <data key="d1">obligation</data>
      <data key="d2">It shall take effect the day following that of its publication in the Official Journal of the European Union or at
a later date specified therein.</data>
      <data key="d3">Article 93</data>
    </node>
    <node id="OBL-0477">
      <data key="d1">obligation</data>
      <data key="d2">It shall not affect the validity of any delegated acts already in force.</data>
      <data key="d3">Article 93</data>
      <data key="d4">shall not affect the validity of any delegated acts already in force</data>
    </node>
    <node id="OBL-0478">
      <data key="d1">obligation</data>
      <data key="d2">As soon as it adopts a delegated act, the Commission shall notify it simultaneously to the European Parliament and
to the Council.</data>
      <data key="d3">Article 93</data>
      <data key="d4">Notify the delegated act</data>
    </node>
    <node id="COND:OBL-0478">
      <data key="d1">condition</data>
      <data key="d5">As soon as it adopts a delegated act</data>
    </node>
    <node id="OBL-0479">
      <data key="d1">obligation</data>
      <data key="d2">A delegated act adopted pursuant to Article 12(8) and Article 43(8) shall enter into force only if no objection has
been expressed by either the European Parliament or the Council within a period of three months of notification of that
act to the European Parliament and the Council or if, before the expiry of that period, the European Parliament and the
Council have both informed the Commission that they will not object.</data>
      <data key="d3">Article 93</data>
      <data key="d4">Express objection to the delegated act</data>
    </node>
    <node id="SUBJ:European Parliament or the Council">
      <data key="d1">subject</data>
      <data key="d5">European Parliament or the Council</data>
    </node>
    <node id="COND:OBL-0479">
      <data key="d1">condition</data>
      <data key="d5">Within a period of three months of notification of that act</data>
    </node>
    <node id="DL:OBL-0479">
      <data key="d1">deadline</data>
      <data key="d5">Three months from notification</data>
    </node>
    <node id="EXC:OBL-0479">
      <data key="d1">exception</data>
      <data key="d5">If both the European Parliament and the Council inform the Commission that they will not object before the expiry of that period</data>
    </node>
    <node id="OBL-0480">
      <data key="d1">obligation</data>
      <data key="d2">That period shall be extended by three months at
the initiative of the European Parliament or of the Council.</data>
      <data key="d3">Article 93</data>
      <data key="d4">Extend the period by three months</data>
    </node>
    <node id="COND:OBL-0480">
      <data key="d1">condition</data>
      <data key="d5">At the initiative of the European Parliament or of the Council</data>
    </node>
    <node id="OBL-0481">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall be assisted by a committee.</data>
      <data key="d3">Article 93</data>
      <data key="d4">shall be assisted by a committee</data>
    </node>
    <node id="OBL-0482">
      <data key="d1">obligation</data>
      <data key="d2">That committee shall be a committee within the meaning of
Regulation (EU) No 182/2011.</data>
      <data key="d3">Article 93</data>
    </node>
    <node id="OBL-0483">
      <data key="d1">obligation</data>
      <data key="d2">Where reference is made to this paragraph, Article 5 of Regulation (EU) No 182/2011 shall apply.</data>
      <data key="d3">Article 93</data>
    </node>
    <node id="OBL-0484">
      <data key="d1">obligation</data>
      <data key="d2">Where reference is made to this paragraph, Article 8 of Regulation (EU) No 182/2011, in conjunction with
Article 5 thereof, shall apply.</data>
      <data key="d3">Article 93</data>
    </node>
    <node id="OBL-0485">
      <data key="d1">obligation</data>
      <data key="d2">References to the repealed Directive shall be construed as references to this Regulation.</data>
      <data key="d3">Article 93</data>
      <data key="d4">References to the repealed Directive shall be construed as references to this Regulation</data>
    </node>
    <node id="OBL-0486">
      <data key="d1">obligation</data>
      <data key="d2">References to the Working
Party on the Protection of Individuals with regard to the Processing of Personal Data established by Article 29 of
Directive 95/46/EC shall be construed as references to the European Data Protection Board established by this
Regulation.</data>
      <data key="d3">Article 93</data>
      <data key="d4">References to the Working Party on the Protection of Individuals with regard to the Processing of Personal Data shall be construed as references to the European Data Protection Board</data>
    </node>
    <node id="COND:OBL-0486">
      <data key="d1">condition</data>
      <data key="d5">established by Article 29 of Directive 95/46/EC</data>
    </node>
    <node id="OBL-0487">
      <data key="d1">obligation</data>
      <data key="d2">Article 95
Relationship with Directive 2002/58/EC
This Regulation shall not impose additional obligations on natural or legal persons in relation to processing in
connection with the provision of publicly available electronic communications services in public communication
networks in the Union in relation to matters for which they are subject to specific obligations with the same objective
set out in Directive 2002/58/EC.</data>
      <data key="d3">Article 93</data>
      <data key="d4">shall not impose additional obligations</data>
    </node>
    <node id="SUBJ:natural or legal persons">
      <data key="d1">subject</data>
      <data key="d5">natural or legal persons</data>
    </node>
    <node id="COND:OBL-0487">
      <data key="d1">condition</data>
      <data key="d5">in relation to processing in connection with the provision of publicly available electronic communications services in public communication networks in the Union</data>
    </node>
    <node id="EXC:OBL-0487">
      <data key="d1">exception</data>
      <data key="d5">in relation to matters for which they are subject to specific obligations with the same objective set out in Directive 2002/58/EC</data>
    </node>
    <node id="OBL-0488">
      <data key="d1">obligation</data>
      <data key="d2">4.5.2016 EN Official Journal of the European Union L 119/87
Article 96
Relationship with previously concluded Agreements
International agreements involving the transfer of personal data to third countries or international organisations which
were concluded by Member States prior to 24 May 2016, and which comply with Union law as applicable prior to that
date, shall remain in force until amended, replaced or revoked.</data>
      <data key="d3">Article 96</data>
      <data key="d4">Shall remain in force</data>
    </node>
    <node id="SUBJ:International agreements involving the transfer of personal data to third countries or international organisations">
      <data key="d1">subject</data>
      <data key="d5">International agreements involving the transfer of personal data to third countries or international organisations</data>
    </node>
    <node id="COND:OBL-0488">
      <data key="d1">condition</data>
      <data key="d5">Concluded by Member States prior to 24 May 2016 and comply with Union law as applicable prior to that date</data>
    </node>
    <node id="DL:OBL-0488">
      <data key="d1">deadline</data>
      <data key="d5">Until amended, replaced or revoked</data>
    </node>
    <node id="OBL-0489">
      <data key="d1">obligation</data>
      <data key="d2">By 25 May 2020 and every four years thereafter, the Commission shall submit a report on the evaluation and
review of this Regulation to the European Parliament and to the Council.</data>
      <data key="d3">Article 96</data>
      <data key="d4">submit a report on the evaluation and review of this Regulation</data>
    </node>
    <node id="DL:OBL-0489">
      <data key="d1">deadline</data>
      <data key="d5">By 25 May 2020 and every four years thereafter</data>
    </node>
    <node id="OBL-0490">
      <data key="d1">obligation</data>
      <data key="d2">The reports shall be made public.</data>
      <data key="d3">Article 96</data>
      <data key="d4">The reports shall be made public</data>
    </node>
    <node id="OBL-0491">
      <data key="d1">obligation</data>
      <data key="d2">In the context of the evaluations and reviews referred to in paragraph 1, the Commission shall examine, in
particular, the application and functioning of:
(a) Chapter V on the transfer of personal data to third countries or international organisations with particular regard to
decisions adopted pursuant to Article 45(3) of this Regulation and decisions adopted on the basis of Article 25(6) of
Directive 95/46/EC;</data>
      <data key="d3">Article 96</data>
      <data key="d4">Examine the application and functioning of Chapter V on the transfer of personal data to third countries or international organisations</data>
    </node>
    <node id="COND:OBL-0491">
      <data key="d1">condition</data>
      <data key="d5">In the context of the evaluations and reviews referred to in paragraph 1</data>
    </node>
    <node id="OBL-0492">
      <data key="d1">obligation</data>
      <data key="d2">In carrying out the evaluations and reviews referred to in paragraphs 1 and 2, the Commission shall take into
account the positions and findings of the European Parliament, of the Council, and of other relevant bodies or sources.</data>
      <data key="d3">Article 96</data>
      <data key="d4">Take into account the positions and findings of the European Parliament, of the Council, and of other relevant bodies or sources</data>
    </node>
    <node id="COND:OBL-0492">
      <data key="d1">condition</data>
      <data key="d5">In carrying out the evaluations and reviews referred to in paragraphs 1 and 2</data>
    </node>
    <node id="OBL-0493">
      <data key="d1">obligation</data>
      <data key="d2">The Commission shall, if necessary, submit appropriate proposals to amend this Regulation, in particular taking
into account of developments in information technology and in the light of the state of progress in the information
society.</data>
      <data key="d3">Article 96</data>
      <data key="d4">Submit appropriate proposals to amend this Regulation</data>
    </node>
    <node id="COND:OBL-0493">
      <data key="d1">condition</data>
      <data key="d5">If necessary, taking into account developments in information technology and the state of progress in the information society</data>
    </node>
    <node id="OBL-0494">
      <data key="d1">obligation</data>
      <data key="d2">Article 98
Review of other Union legal acts on data protection
The Commission shall, if appropriate, submit legislative proposals with a view to amending other Union legal acts on
the protection of personal data, in order to ensure uniform and consistent protection of natural persons with regard to
processing.</data>
      <data key="d3">Article 96</data>
      <data key="d4">Submit legislative proposals to amend other Union legal acts on the protection of personal data</data>
    </node>
    <node id="COND:OBL-0494">
      <data key="d1">condition</data>
      <data key="d5">If appropriate</data>
    </node>
    <node id="OBL-0495">
      <data key="d1">obligation</data>
      <data key="d2">This shall in particular concern the rules relating to the protection of natural persons with regard to
processing by Union institutions, bodies, offices and agencies and on the free movement of such data.</data>
      <data key="d3">Article 96</data>
      <data key="d4">Protection of natural persons with regard to processing</data>
    </node>
    <node id="SUBJ:Union institutions, bodies, offices and agencies">
      <data key="d1">subject</data>
      <data key="d5">Union institutions, bodies, offices and agencies</data>
    </node>
    <node id="COND:OBL-0495">
      <data key="d1">condition</data>
      <data key="d5">Relating to the free movement of such data</data>
    </node>
    <node id="OBL-0496">
      <data key="d1">obligation</data>
      <data key="d2">This Regulation shall enter into force on the twentieth day following that of its publication in the Official Journal of
the European Union.</data>
      <data key="d3">Article 96</data>
    </node>
    <node id="OBL-0497">
      <data key="d1">obligation</data>
      <data key="d2">It shall apply from 25 May 2018.</data>
      <data key="d3">Article 96</data>
    </node>
    <node id="DL:OBL-0497">
      <data key="d1">deadline</data>
      <data key="d5">25 May 2018</data>
    </node>
    <node id="OBL-0498">
      <data key="d1">obligation</data>
      <data key="d2">L 119/88 EN Official Journal of the European Union 4.5.2016
This Regulation shall be binding in its entirety and directly applicable in all Member States.</data>
      <data key="d3">Article 96</data>
      <data key="d4">Ensure the Regulation is binding and directly applicable</data>
    </node>
