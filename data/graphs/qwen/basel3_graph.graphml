    </node>
    <node id="THRE:OBL-0179">
      <data key="d2">threshold</data>
      <data key="d6">H FX (haircut appropriate for the currency mismatch)</data>
    </node>
    <node id="OBL-0180">
      <data key="d2">obligation</data>
      <data key="d3">This haircut must be scaled up using the square root of time formula, depending on the
frequency of revaluation of the credit protection as described in paragraph 172.</data>
