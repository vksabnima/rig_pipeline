    <node id="COND:OBL-0189">
      <data key="d2">condition</data>
      <data key="d6">where supervisors categorise certain types of commercial real estate exposures as HVCRE in their jurisdictions</data>
    </node>
    <node id="OBL-0190">
      <data key="d2">obligation</data>
      <data key="d3">Other supervisors need to ensure that
such treatment is then applied equally to banks under their supervision when making such HVCRE loans
in that jurisdiction.</data>
      <data key="d4">Preamble</data>
      <data key="d5">ensure that such treatment is applied equally to banks under their supervision when making such HVCRE loans</data>
    </node>
