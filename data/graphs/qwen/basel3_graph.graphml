      <data key="d2">condition</data>
      <data key="d6">the restructuring of the underlying obligation is not covered by the credit derivative and the other requirements in paragraph 195 are met</data>
    </node>
    <node id="OBL-0174">
      <data key="d2">obligation</data>
      <data key="d3">If the amount of the credit derivative is less than or equal to the amount of the underlying
obligation, 60% of the amount of the hedge can be recognised as covered.</data>
      <data key="d4">Preamble</data>
      <data key="d5">recognise 60% of the amount of the hedge as covered</data>
    </node>
    <node id="COND:OBL-0174">
      <data key="d2">condition</data>
      <data key="d6">the amount of the credit derivative is less than or equal to the amount of the underlying obligation</data>
    </node>
    <node id="THRE:OBL-0174">
      <data key="d2">threshold</data>
      <data key="d6">60%</data>
    </node>
    <node id="OBL-0175">
      <data key="d2">obligation</data>
      <data key="d3">If the amount of the credit
derivative is larger than that of the underlying obligation, then the amount of eligible hedge is capped at
60% of the amount of the underlying obligation.</data>
      <data key="d4">Preamble</data>
      <data key="d5">cap the amount of eligible hedge at 60% of the amount of the underlying obligation</data>
