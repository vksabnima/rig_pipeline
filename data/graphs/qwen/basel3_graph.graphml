      <data key="d4">Preamble</data>
      <data key="d5">rely on the income generated by the asset(s) as the primary source of repayment of the obligation</data>
    </node>
    <node id="COND:OBL-0188">
      <data key="d2">condition</data>
      <data key="d6">as a result of the preceding factors</data>
    </node>
    <node id="OBL-0189">
      <data key="d2">obligation</data>
      <data key="d3">Where supervisors categorise certain types of commercial real estate exposures as HVCRE in their
jurisdictions, they are required to make public such determinations.</data>
      <data key="d4">Preamble</data>
      <data key="d5">make public such determinations</data>
