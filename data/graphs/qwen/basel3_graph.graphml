      <data key="d6">the terms of the obligation</data>
    </node>
    <node id="OBL-0039">
      <data key="d2">obligation</data>
      <data key="d3">Issuer ratings must not be used (ie paragraph 107
does not apply in the case of specialised lending exposures).</data>
      <data key="d4">Preamble</data>
      <data key="d5">must not be used</data>
    </node>
    <node id="SUBJ:Issuer ratings">
      <data key="d2">subject</data>
